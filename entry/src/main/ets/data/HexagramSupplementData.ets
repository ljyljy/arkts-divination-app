// 合并补充数据到主卦象数组
export function mergeSupplementData(hexagrams: Hexagram[]): void {
  hexagrams.forEach((hexagram: Hexagram) => {
    const supplement = SUPPLEMENT_DATA[hexagram.id];
    if (supplement) {
      if (supplement.classicComment) {
        hexagram.classicComment = supplement.classicComment;
      }
      if (supplement.takashiCase) {
        hexagram.takashiCase = supplement.takashiCase;
      }
      if (supplement.lines) {
        hexagram.lines.forEach((line: HexagramLine) => {
          const lineSupplement = supplement.lines![line.position];
          if (lineSupplement) {
            if (lineSupplement.classicComment) {
              line.classicComment = lineSupplement.classicComment;
            }
            if (lineSupplement.takashiCase) {
              line.takashiCase = lineSupplement.takashiCase;
            }
          }
        });
      }
    }
  });
}