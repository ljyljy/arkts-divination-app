  { id: 2, name: '坤为地', symbol: '䷁', upperTrigram: 'kun', lowerTrigram: 'kun', number: 2, judgment: '元亨，利牝马之贞。君子有攸往，先迷后得主，利西南得朋，东北丧朋。安贞吉。', image: '至哉坤元，万物资生，乃顺承天。坤厚载物，德合无疆。', classicComment: '《彖》曰：坤为地，元亨，利牝马之贞。君子有攸往，先迷后得主。《象》曰：君子以至哉坤元，万物资生，乃顺承天。。', takashiCase: '某士人因事占问，得坤为地。高岛嘉右卫门断曰：「元亨，利牝马之贞。君子有攸往，先迷后得主」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦主柔顺承载之德，象征大地厚德载物。宜守柔持静，顺势而为。', career: '事业宜稳中求进，以柔克刚，注重积累与基础建设。', relationship: '感情宜温柔体贴，包容对方，以和为贵。', health: '注意脾胃消化系统，宜调养身心，避免过度操劳。', wealth: '财运平稳，宜稳健理财，不宜冒险投机。' }, lines: [{ position: 1, name: '初六', text: '履霜坚冰至。', interpretation: '踏霜而知冰将至，见微知著，防患于未然。', classicComment: '《象》曰：履霜坚冰至。...，阴居初位，踏霜而知冰将至，见微知著，防患。', takashiCase: '某商人占贸易，得坤为地之初六。高岛曰：「履霜坚冰至。...」踏霜而知冰将至，见微知著，防患于未然。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '直方大不习无不利。', interpretation: '正直方正广大，不学习亦无所不利，天赋之美德。', classicComment: '《象》曰：直方大不习无不利。...，阴居初位，正直方正广大，不学习亦无所不利。', takashiCase: '某商人占贸易，得坤为地之六二。高岛曰：「直方大不习无不利。...」正直方正广大，不学习亦无所不利，天赋之美。后事平平，无大得失。' }, { position: 3, name: '六三', text: '含章可贞，或从王事，无成有终。', interpretation: '内含美质，可守正道。从事王事虽无功亦有善终。', classicComment: '《象》曰：含章可贞，或从王事，无成...，阴居初位，内含美质，可守正道。从事王事虽。', takashiCase: '某商人占贸易，得坤为地之六三。高岛曰：「含章可贞，或从王事，无成...」内含美质，可守正道。从事王事虽无功亦有善。后事平平，无大得失。' }, { position: 4, name: '六四', text: '括囊无咎无誉。', interpretation: '束紧囊口，谨言慎行，虽无赞誉亦无过错。', classicComment: '《象》曰：括囊无咎无誉。...，阴居初位，束紧囊口，谨言慎行，虽无赞誉亦。', takashiCase: '某商人占贸易，得坤为地之六四。高岛曰：「括囊无咎无誉。...」束紧囊口，谨言慎行，虽无赞誉亦无过错。。后果大获其利。' }, { position: 5, name: '六五', text: '黄裳元吉。', interpretation: '身着黄裳，居尊位而守中道，大吉大利。', classicComment: '《象》曰：黄裳元吉。...，阴居初位，身着黄裳，居尊位而守中道，大吉。', takashiCase: '某商人占贸易，得坤为地之六五。高岛曰：「黄裳元吉。...」身着黄裳，居尊位而守中道，大吉大利。。后果大获其利。' }, { position: 6, name: '上六', text: '龙战于野，其血玄黄。', interpretation: '二龙战于野外，血流玄黄，阴阳相争之象。', classicComment: '《象》曰：龙战于野，其血玄黄。...，阴居初位，二龙战于野外，血流玄黄，阴阳相。', takashiCase: '某商人占贸易，得坤为地之上六。高岛曰：「龙战于野，其血玄黄。...」二龙战于野外，血流玄黄，阴阳相争之象。。后事平平，无大得失。' }] },
  { id: 3, name: '水雷屯', symbol: '䷂', upperTrigram: 'kan', lowerTrigram: 'zhen', number: 3, judgment: '元亨利贞，勿用有攸往，利建侯。', image: '屯，刚柔始交而难生。', classicComment: '《彖》曰：水雷屯，元亨利贞，勿用有攸往，利建侯。。《象》曰：君子以屯，刚柔始交而难生。。', takashiCase: '某士人因事占问，得水雷屯。高岛嘉右卫门断曰：「元亨利贞，勿用有攸往，利建侯。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征事物初创之艰难，如草木萌芽破土而出。虽有困难但前景光明。', career: '创业初期困难重重，需坚韧不拔。宜建立根基，寻求盟友。', relationship: '感情处于萌芽阶段，需要耐心培养，不宜急躁。', health: '身体可能有小恙，宜注意休息调理。', wealth: '财务紧张，需谨慎规划，不宜大额支出。' }, lines: [{ position: 1, name: '初九', text: '磐桓，利居贞，利建侯。', interpretation: '徘徊不前，宜安居守正，利于建立基业。', classicComment: '《象》曰：磐桓，利居贞，利建侯。...，阳居初位，徘徊不前，宜安居守正，利于建立。', takashiCase: '某商人占贸易，得水雷屯之初九。高岛曰：「磐桓，利居贞，利建侯。...」徘徊不前，宜安居守正，利于建立基业。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '屯如邅如，乘马班如。匪寇婚媾，女子贞不字，十年乃字。', interpretation: '进退两难，骑马盘旋。非敌寇而是求婚，女子守贞十年才嫁。', classicComment: '《象》曰：屯如邅如，乘马班如。匪寇...，阴居初位，进退两难，骑马盘旋。非敌寇而是。', takashiCase: '某商人占贸易，得水雷屯之六二。高岛曰：「屯如邅如，乘马班如。匪寇...」进退两难，骑马盘旋。非敌寇而是求婚，女子。后事平平，无大得失。' }, { position: 3, name: '六三', text: '即鹿无虞，惟入于林中，君子不如舍，往吝。', interpretation: '追鹿无向导，入林迷失。君子不如放弃，前往会有遗憾。', classicComment: '《象》曰：即鹿无虞，惟入于林中，君...，阴居初位，追鹿无向导，入林迷失。君子不如。', takashiCase: '某商人占贸易，得水雷屯之六三。高岛曰：「即鹿无虞，惟入于林中，君...」追鹿无向导，入林迷失。君子不如放弃，前往。后事平平，无大得失。' }, { position: 4, name: '六四', text: '乘马班如，求婚媾往吉，无不利。', interpretation: '骑马盘旋，求婚前往吉利，无所不利。', classicComment: '《象》曰：乘马班如，求婚媾往吉，无...，阴居初位，骑马盘旋，求婚前往吉利，无所不。', takashiCase: '某商人占贸易，得水雷屯之六四。高岛曰：「乘马班如，求婚媾往吉，无...」骑马盘旋，求婚前往吉利，无所不利。。后果大获其利。' }, { position: 5, name: '九五', text: '屯其膏，小贞吉，大贞凶。', interpretation: '恩泽被阻隔，小事守正则吉，大事守正反凶。', classicComment: '《象》曰：屯其膏，小贞吉，大贞凶。...，阳居初位，恩泽被阻隔，小事守正则吉，大事。', takashiCase: '某商人占贸易，得水雷屯之九五。高岛曰：「屯其膏，小贞吉，大贞凶。...」恩泽被阻隔，小事守正则吉，大事守正反凶。。后果大获其利。' }, { position: 6, name: '上六', text: '乘马班如，泣血涟如。', interpretation: '骑马盘旋哭泣，血泪涟涟，穷途末路之象。', classicComment: '《象》曰：乘马班如，泣血涟如。...，阴居初位，骑马盘旋哭泣，血泪涟涟，穷途末。', takashiCase: '某商人占贸易，得水雷屯之上六。高岛曰：「乘马班如，泣血涟如。...」骑马盘旋哭泣，血泪涟涟，穷途末路之象。。后事平平，无大得失。' }] },
  { id: 4, name: '山水蒙', symbol: '䷃', upperTrigram: 'gen', lowerTrigram: 'kan', number: 4, judgment: '亨。匪我求童蒙，童蒙求我。初筮告，再三渎，渎则不告。利贞。', image: '蒙以养正，圣功也。', classicComment: '《彖》曰：山水蒙，亨。匪我求童蒙，童蒙求我。初筮告，再三渎。《象》曰：君子以蒙以养正，圣功也。。', takashiCase: '某士人因事占问，得山水蒙。高岛嘉右卫门断曰：「亨。匪我求童蒙，童蒙求我。初筮告，再三渎」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征启蒙教育之象。如山中出泉，需引导疏通。宜虚心求学，循序渐进。', career: '学习成长阶段，宜拜师学艺，谦虚求教。不宜急于求成。', relationship: '感情需互相了解磨合，如师生般共同成长。', health: '注意心理健康，保持好奇心和学习热情。', wealth: '知识就是财富，宜投资自身能力提升。' }, lines: [{ position: 1, name: '初六', text: '发蒙，利用刑人，用说桎梏，以往吝。', interpretation: '开启蒙昧，宜用法度约束，解脱枷锁锁链，前往有困难。', classicComment: '《象》曰：发蒙，利用刑人，用说桎梏...，阴居初位，开启蒙昧，宜用法度约束，解脱枷。', takashiCase: '某商人占贸易，得山水蒙之初六。高岛曰：「发蒙，利用刑人，用说桎梏...」开启蒙昧，宜用法度约束，解脱枷锁锁链，前。后事平平，无大得失。' }, { position: 2, name: '九二', text: '包蒙吉，纳妇吉，子克家。', interpretation: '包容蒙昧者吉祥，娶妻吉祥，子能治家。', classicComment: '《象》曰：包蒙吉，纳妇吉，子克家。...，阳居初位，包容蒙昧者吉祥，娶妻吉祥，子能。', takashiCase: '某商人占贸易，得山水蒙之九二。高岛曰：「包蒙吉，纳妇吉，子克家。...」包容蒙昧者吉祥，娶妻吉祥，子能治家。。后果大获其利。' }, { position: 3, name: '六三', text: '勿用取女，见金夫不有躬，无攸利。', interpretation: '不宜娶此女，见到有钱男子便失身，无所利益。', classicComment: '《象》曰：勿用取女，见金夫不有躬，...，阴居初位，不宜娶此女，见到有钱男子便失身。', takashiCase: '某商人占贸易，得山水蒙之六三。高岛曰：「勿用取女，见金夫不有躬，...」不宜娶此女，见到有钱男子便失身，无所利益。后事平平，无大得失。' }, { position: 4, name: '六四', text: '困蒙，吝。', interpretation: '困于蒙昧之中，有所憾惜。', classicComment: '《象》曰：困蒙，吝。...，阴居初位，困于蒙昧之中，有所憾惜。。', takashiCase: '某商人占贸易，得山水蒙之六四。高岛曰：「困蒙，吝。...」困于蒙昧之中，有所憾惜。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '童蒙，吉。', interpretation: '童稚蒙昧，谦逊好学，吉祥。', classicComment: '《象》曰：童蒙，吉。...，阴居初位，童稚蒙昧，谦逊好学，吉祥。。', takashiCase: '某商人占贸易，得山水蒙之六五。高岛曰：「童蒙，吉。...」童稚蒙昧，谦逊好学，吉祥。。后果大获其利。' }, { position: 6, name: '上九', text: '击蒙，不利为寇，利御寇。', interpretation: '猛击蒙昧，不利于做盗贼，有利于抵御盗贼。', classicComment: '《象》曰：击蒙，不利为寇，利御寇。...，阳居初位，猛击蒙昧，不利于做盗贼，有利于。', takashiCase: '某商人占贸易，得山水蒙之上九。高岛曰：「击蒙，不利为寇，利御寇。...」猛击蒙昧，不利于做盗贼，有利于抵御盗贼。。后事平平，无大得失。' }] },
  { id: 5, name: '水天需', symbol: '䷄', upperTrigram: 'kan', lowerTrigram: 'qian', number: 5, judgment: '有孚，光亨贞吉，利涉大川。', image: '需，须也，险在前也。刚健而不陷。', classicComment: '《彖》曰：水天需，有孚，光亨贞吉，利涉大川。。《象》曰：君子以需，须也，险在前也。刚健而不陷。', takashiCase: '某士人因事占问，得水天需。高岛嘉右卫门断曰：「有孚，光亨贞吉，利涉大川。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征等待时机之象。云上于天，待时降雨。宜耐心等待，蓄势待发。', career: '事业需等待良机，不宜急躁冒进。做好充分准备。', relationship: '感情需要时间培养，耐心等待缘分成熟。', health: '养生之道在于顺应时节，注意饮食起居规律。', wealth: '投资需耐心等待回报，不宜频繁操作。' }, lines: [{ position: 1, name: '初九', text: '需于郊，利用恒，无咎。', interpretation: '在郊外等待，宜持之以恒，无灾祸。', classicComment: '《象》曰：需于郊，利用恒，无咎。...，阳居初位，在郊外等待，宜持之以恒，无灾祸。', takashiCase: '某商人占贸易，得水天需之初九。高岛曰：「需于郊，利用恒，无咎。...」在郊外等待，宜持之以恒，无灾祸。。后果大获其利。' }, { position: 2, name: '九二', text: '需于沙，小有言，终吉。', interpretation: '在沙滩等待，稍有言语争执，最终吉祥。', classicComment: '《象》曰：需于沙，小有言，终吉。...，阳居初位，在沙滩等待，稍有言语争执，最终。', takashiCase: '某商人占贸易，得水天需之九二。高岛曰：「需于沙，小有言，终吉。...」在沙滩等待，稍有言语争执，最终吉祥。。后果大获其利。' }, { position: 3, name: '九三', text: '需于泥，致寇至。', interpretation: '在泥沼等待，招致强盗到来。', classicComment: '《象》曰：需于泥，致寇至。...，阳居初位，在泥沼等待，招致强盗到来。。', takashiCase: '某商人占贸易，得水天需之九三。高岛曰：「需于泥，致寇至。...」在泥沼等待，招致强盗到来。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '需于血，出自穴。', interpretation: '在血泊中等待，从洞穴中脱出。', classicComment: '《象》曰：需于血，出自穴。...，阴居初位，在血泊中等待，从洞穴中脱出。。', takashiCase: '某商人占贸易，得水天需之六四。高岛曰：「需于血，出自穴。...」在血泊中等待，从洞穴中脱出。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '需于酒食，贞吉。', interpretation: '在酒食宴乐中等待，守正吉祥。', classicComment: '《象》曰：需于酒食，贞吉。...，阳居初位，在酒食宴乐中等待，守正吉祥。。', takashiCase: '某商人占贸易，得水天需之九五。高岛曰：「需于酒食，贞吉。...」在酒食宴乐中等待，守正吉祥。。后果大获其利。' }, { position: 6, name: '上六', text: '入于穴，有不速之客三人来，敬之终吉。', interpretation: '进入洞穴，有不速之客三人来，恭敬对待最终吉祥。', classicComment: '《象》曰：入于穴，有不速之客三人来...，阴居初位，进入洞穴，有不速之客三人来，恭。', takashiCase: '某商人占贸易，得水天需之上六。高岛曰：「入于穴，有不速之客三人来...」进入洞穴，有不速之客三人来，恭敬对待最终。后果大获其利。' }] },
  { id: 6, name: '天水讼', symbol: '䷅', upperTrigram: 'qian', lowerTrigram: 'kan', number: 6, judgment: '有孚窒惕，中吉，终凶。利见大人，不利涉大川。', image: '讼，上刚下险，险而健，讼。', classicComment: '《彖》曰：天水讼，有孚窒惕，中吉，终凶。利见大人，不利涉大。《象》曰：君子以讼，上刚下险，险而健，讼。。', takashiCase: '某士人因事占问，得天水讼。高岛嘉右卫门断曰：「有孚窒惕，中吉，终凶。利见大人，不利涉大」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征争讼之象。天与水违行，意见相左。宜息事宁人，避免争端。', career: '职场易生纠纷，宜沟通协调，避免正面冲突。', relationship: '感情易有误解争吵，需坦诚沟通化解矛盾。', health: '情绪波动影响健康，宜保持平和心态。', wealth: '财务纠纷风险高，合同文书务必谨慎。' }, lines: [{ position: 1, name: '初六', text: '不永所事，小有言，终吉。', interpretation: '不将争端持久化，稍有口舌，最终吉祥。', classicComment: '《象》曰：不永所事，小有言，终吉。...，阴居初位，不将争端持久化，稍有口舌，最终。', takashiCase: '某商人占贸易，得天水讼之初六。高岛曰：「不永所事，小有言，终吉。...」不将争端持久化，稍有口舌，最终吉祥。。后果大获其利。' }, { position: 2, name: '九二', text: '不克讼，归而逋其邑人三百户，无眚。', interpretation: '争讼不胜，逃回封邑三百户人家，无灾祸。', classicComment: '《象》曰：不克讼，归而逋其邑人三百...，阳居初位，争讼不胜，逃回封邑三百户人家，。', takashiCase: '某商人占贸易，得天水讼之九二。高岛曰：「不克讼，归而逋其邑人三百...」争讼不胜，逃回封邑三百户人家，无灾祸。。后事平平，无大得失。' }, { position: 3, name: '六三', text: '食旧德，贞厉，终吉。或从王事，无成。', interpretation: '享用旧有恩德，守正虽有危险最终吉祥。', classicComment: '《象》曰：食旧德，贞厉，终吉。或从...，阴居初位，享用旧有恩德，守正虽有危险最终。', takashiCase: '某商人占贸易，得天水讼之六三。高岛曰：「食旧德，贞厉，终吉。或从...」享用旧有恩德，守正虽有危险最终吉祥。。后果大获其利。' }, { position: 4, name: '九四', text: '不克讼，复即命渝，安贞吉。', interpretation: '争讼不胜，回头改变初衷，安守正道吉祥。', classicComment: '《象》曰：不克讼，复即命渝，安贞吉...，阳居初位，争讼不胜，回头改变初衷，安守正。', takashiCase: '某商人占贸易，得天水讼之九四。高岛曰：「不克讼，复即命渝，安贞吉...」争讼不胜，回头改变初衷，安守正道吉祥。。后果大获其利。' }, { position: 5, name: '九五', text: '讼元吉。', interpretation: '争讼大吉，公正裁决。', classicComment: '《象》曰：讼元吉。...，阳居初位，争讼大吉，公正裁决。。', takashiCase: '某商人占贸易，得天水讼之九五。高岛曰：「讼元吉。...」争讼大吉，公正裁决。。后果大获其利。' }, { position: 6, name: '上九', text: '或锡之鞶带，终朝三褫之。', interpretation: '或许获赐腰带，一天之内三次被剥夺。', classicComment: '《象》曰：或锡之鞶带，终朝三褫之。...，阳居初位，或许获赐腰带，一天之内三次被剥。', takashiCase: '某商人占贸易，得天水讼之上九。高岛曰：「或锡之鞶带，终朝三褫之。...」或许获赐腰带，一天之内三次被剥夺。。后事平平，无大得失。' }] },
  { id: 7, name: '地水师', symbol: '䷆', upperTrigram: 'kun', lowerTrigram: 'kan', number: 7, judgment: '贞丈人吉，无咎。', image: '师，众也。贞正也能众服。', classicComment: '《彖》曰：地水师，贞丈人吉，无咎。。《象》曰：君子以师，众也。贞正也能众服。。', takashiCase: '某士人因事占问，得地水师。高岛嘉右卫门断曰：「贞丈人吉，无咎。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征军队行师之象。地中有水，容民畜众。宜纪律严明，统一指挥。', career: '团队管理重要时期，需明确分工，严明纪律。', relationship: '感情需有共同目标，相互支持配合。', health: '注意群体性健康问题，预防传染病。', wealth: '集体投资需选好领队，跟随明主。' }, lines: [{ position: 1, name: '初六', text: '师出以律，否臧凶。', interpretation: '军队出征要有纪律，否则无论善恶都凶险。', classicComment: '《象》曰：师出以律，否臧凶。...，阴居初位，军队出征要有纪律，否则无论善恶。', takashiCase: '某商人占贸易，得地水师之初六。高岛曰：「师出以律，否臧凶。...」军队出征要有纪律，否则无论善恶都凶险。。后事败，悔之晚矣。' }, { position: 2, name: '九二', text: '在师中吉，无咎，王三锡命。', interpretation: '在军中统帅吉祥，无灾祸，君王三次赐命嘉奖。', classicComment: '《象》曰：在师中吉，无咎，王三锡命...，阳居初位，在军中统帅吉祥，无灾祸，君王三。', takashiCase: '某商人占贸易，得地水师之九二。高岛曰：「在师中吉，无咎，王三锡命...」在军中统帅吉祥，无灾祸，君王三次赐命嘉奖。后果大获其利。' }, { position: 3, name: '六三', text: '师或舆尸，凶。', interpretation: '军队可能车载尸体而归，凶险。', classicComment: '《象》曰：师或舆尸，凶。...，阴居初位，军队可能车载尸体而归，凶险。。', takashiCase: '某商人占贸易，得地水师之六三。高岛曰：「师或舆尸，凶。...」军队可能车载尸体而归，凶险。。后事败，悔之晚矣。' }, { position: 4, name: '六四', text: '师左次，无咎。', interpretation: '军队驻扎左侧撤退，无灾祸。', classicComment: '《象》曰：师左次，无咎。...，阴居初位，军队驻扎左侧撤退，无灾祸。。', takashiCase: '某商人占贸易，得地水师之六四。高岛曰：「师左次，无咎。...」军队驻扎左侧撤退，无灾祸。。后果大获其利。' }, { position: 5, name: '六五', text: '田有禽，利执言，无咎。长子帅师，弟子舆尸，贞凶。', interpretation: '田野有猎物，宜捕捉声讨。长子统军，弟子败绩。', classicComment: '《象》曰：田有禽，利执言，无咎。长...，阴居初位，田野有猎物，宜捕捉声讨。长子统。', takashiCase: '某商人占贸易，得地水师之六五。高岛曰：「田有禽，利执言，无咎。长...」田野有猎物，宜捕捉声讨。长子统军，弟子败。后果大获其利。' }, { position: 6, name: '上六', text: '大君有命，开国承家，小人勿用。', interpretation: '国君颁布命令，开国承家，不可任用小人。', classicComment: '《象》曰：大君有命，开国承家，小人...，阴居初位，国君颁布命令，开国承家，不可任。', takashiCase: '某商人占贸易，得地水师之上六。高岛曰：「大君有命，开国承家，小人...」国君颁布命令，开国承家，不可任用小人。。后事平平，无大得失。' }] },
  { id: 8, name: '水地比', symbol: '䷇', upperTrigram: 'kan', lowerTrigram: 'kun', number: 8, judgment: '吉。原筮元永贞，无咎。不宁方来，后夫凶。', image: '比，辅也，下顺从也。', classicComment: '《彖》曰：水地比，吉。原筮元永贞，无咎。不宁方来，后夫凶。。《象》曰：君子以比，辅也，下顺从也。。', takashiCase: '某士人因事占问，得水地比。高岛嘉右卫门断曰：「吉。原筮元永贞，无咎。不宁方来，后夫凶。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征亲附团结之象。地上有水，相亲相助。宜广结善缘，和睦共处。', career: '事业宜合作共赢，建立良好人际关系网络。', relationship: '感情和谐美满，彼此亲近依赖。', health: '身心健康，人际关系良好有益健康。', wealth: '合作带来财富，合伙经营有利。' }, lines: [{ position: 1, name: '初六', text: '有孚比之，无咎。有孚盈缶，终来有它吉。', interpretation: '诚信亲附他人，无灾祸。诚信充盈如缶，终有意外之吉。', classicComment: '《象》曰：有孚比之，无咎。有孚盈缶...，阴居初位，诚信亲附他人，无灾祸。诚信充盈。', takashiCase: '某商人占贸易，得水地比之初六。高岛曰：「有孚比之，无咎。有孚盈缶...」诚信亲附他人，无灾祸。诚信充盈如缶，终有。后果大获其利。' }, { position: 2, name: '六二', text: '比之自内，贞吉。', interpretation: '发自内心亲附，守正吉祥。', classicComment: '《象》曰：比之自内，贞吉。...，阴居初位，发自内心亲附，守正吉祥。。', takashiCase: '某商人占贸易，得水地比之六二。高岛曰：「比之自内，贞吉。...」发自内心亲附，守正吉祥。。后果大获其利。' }, { position: 3, name: '六三', text: '比之匪人。', interpretation: '所亲附的人不正派。', classicComment: '《象》曰：比之匪人。...，阴居初位，所亲附的人不正派。。', takashiCase: '某商人占贸易，得水地比之六三。高岛曰：「比之匪人。...」所亲附的人不正派。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '外比之，贞吉。', interpretation: '向外亲附贤者，守正吉祥。', classicComment: '《象》曰：外比之，贞吉。...，阴居初位，向外亲附贤者，守正吉祥。。', takashiCase: '某商人占贸易，得水地比之六四。高岛曰：「外比之，贞吉。...」向外亲附贤者，守正吉祥。。后果大获其利。' }, { position: 5, name: '九五', text: '显比，王用三驱，失前禽，邑人不诫，吉。', interpretation: '光明正大地亲附，君王三面围猎，邑人不警觉，吉祥。', classicComment: '《象》曰：显比，王用三驱，失前禽，...，阳居初位，光明正大地亲附，君王三面围猎，。', takashiCase: '某商人占贸易，得水地比之九五。高岛曰：「显比，王用三驱，失前禽，...」光明正大地亲附，君王三面围猎，邑人不警觉。后果大获其利。' }, { position: 6, name: '上六', text: '比之无首，凶。', interpretation: '亲附没有首领，凶险。', classicComment: '《象》曰：比之无首，凶。...，阴居初位，亲附没有首领，凶险。。', takashiCase: '某商人占贸易，得水地比之上六。高岛曰：「比之无首，凶。...」亲附没有首领，凶险。。后事败，悔之晚矣。' }] },
  { id: 9, name: '风天小畜', symbol: '䷈', upperTrigram: 'xun', lowerTrigram: 'qian', number: 9, judgment: '亨。密云不雨，自我西郊。', image: '小畜，柔得位而上下应之。', classicComment: '《彖》曰：风天小畜，亨。密云不雨，自我西郊。。《象》曰：君子以小畜，柔得位而上下应之。。', takashiCase: '某士人因事占问，得风天小畜。高岛嘉右卫门断曰：「亨。密云不雨，自我西郊。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征小有积蓄之象。风行天上，密云未雨。宜积蓄力量，等待时机。', career: '事业处于积累期，小有成就但尚未大成。', relationship: '感情稳定发展，细水长流。', health: '注意小病早治，预防为主。', wealth: '小额储蓄积累，不宜大手笔投资。' }, lines: [{ position: 1, name: '初九', text: '复自道，何其咎？吉。', interpretation: '回到自己道路上来，有什么灾祸？吉祥。', classicComment: '《象》曰：复自道，何其咎？吉。...，阳居初位，回到自己道路上来，有什么灾祸？。', takashiCase: '某商人占贸易，得风天小畜之初九。高岛曰：「复自道，何其咎？吉。...」回到自己道路上来，有什么灾祸？吉祥。。后果大获其利。' }, { position: 2, name: '九二', text: '牵复，吉。', interpretation: '被牵连返回，吉祥。', classicComment: '《象》曰：牵复，吉。...，阳居初位，被牵连返回，吉祥。。', takashiCase: '某商人占贸易，得风天小畜之九二。高岛曰：「牵复，吉。...」被牵连返回，吉祥。。后果大获其利。' }, { position: 3, name: '九三', text: '舆说辐，夫妻反目。', interpretation: '车轮脱落车轴，夫妻反目成仇。', classicComment: '《象》曰：舆说辐，夫妻反目。...，阳居初位，车轮脱落车轴，夫妻反目成仇。。', takashiCase: '某商人占贸易，得风天小畜之九三。高岛曰：「舆说辐，夫妻反目。...」车轮脱落车轴，夫妻反目成仇。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '有孚，血去惕出，无咎。', interpretation: '有诚信，忧愁恐惧离去，无灾祸。', classicComment: '《象》曰：有孚，血去惕出，无咎。...，阴居初位，有诚信，忧愁恐惧离去，无灾祸。。', takashiCase: '某商人占贸易，得风天小畜之六四。高岛曰：「有孚，血去惕出，无咎。...」有诚信，忧愁恐惧离去，无灾祸。。后果大获其利。' }, { position: 5, name: '九五', text: '有孚挛如，富以其邻。', interpretation: '诚信紧密相连，与邻居共享富裕。', classicComment: '《象》曰：有孚挛如，富以其邻。...，阳居初位，诚信紧密相连，与邻居共享富裕。。', takashiCase: '某商人占贸易，得风天小畜之九五。高岛曰：「有孚挛如，富以其邻。...」诚信紧密相连，与邻居共享富裕。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '既雨既处，尚德载。妇贞厉，月几望，君子征凶。', interpretation: '已经下雨已经停止，崇尚德行承载。妇人守正有危险。', classicComment: '《象》曰：既雨既处，尚德载。妇贞厉...，阳居初位，已经下雨已经停止，崇尚德行承载。', takashiCase: '某商人占贸易，得风天小畜之上九。高岛曰：「既雨既处，尚德载。妇贞厉...」已经下雨已经停止，崇尚德行承载。妇人守正。后事败，悔之晚矣。' }] },
  { id: 10, name: '天泽履', symbol: '䷉', upperTrigram: 'qian', lowerTrigram: 'dui', number: 10, judgment: '履虎尾，不咥人，亨。', image: '履，柔履刚也。', classicComment: '《彖》曰：天泽履，履虎尾，不咥人，亨。。《象》曰：君子以履，柔履刚也。。', takashiCase: '某士人因事占问，得天泽履。高岛嘉右卫门断曰：「履虎尾，不咥人，亨。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征谨慎前行之象。踩虎尾巴而不被咬，小心行事可化险为夷。', career: '事业需谨慎行事，步步为营，遵守规则。', relationship: '感情需小心翼翼维护，尊重对方感受。', health: '行动安全第一，防止意外伤害。', wealth: '投资需谨慎评估风险，保守为宜。' }, lines: [{ position: 1, name: '初九', text: '素履往，无咎。', interpretation: '朴素坦率前往，无灾祸。', classicComment: '《象》曰：素履往，无咎。...，阳居初位，朴素坦率前往，无灾祸。。', takashiCase: '某商人占贸易，得天泽履之初九。高岛曰：「素履往，无咎。...」朴素坦率前往，无灾祸。。后果大获其利。' }, { position: 2, name: '九二', text: '履道坦坦，幽人贞吉。', interpretation: '行走大道平坦，隐士守正吉祥。', classicComment: '《象》曰：履道坦坦，幽人贞吉。...，阳居初位，行走大道平坦，隐士守正吉祥。。', takashiCase: '某商人占贸易，得天泽履之九二。高岛曰：「履道坦坦，幽人贞吉。...」行走大道平坦，隐士守正吉祥。。后果大获其利。' }, { position: 3, name: '六三', text: '眇能视，跛能履，履虎尾咥人，凶。武人为于大君。', interpretation: '眼盲能看，脚跛能走，踩虎尾被咬伤，凶险。', classicComment: '《象》曰：眇能视，跛能履，履虎尾咥...，阴居初位，眼盲能看，脚跛能走，踩虎尾被咬。', takashiCase: '某商人占贸易，得天泽履之六三。高岛曰：「眇能视，跛能履，履虎尾咥...」眼盲能看，脚跛能走，踩虎尾被咬伤，凶险。。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '履虎尾愬愬，终吉。', interpretation: '踩虎尾战战兢兢，最终吉祥。', classicComment: '《象》曰：履虎尾愬愬，终吉。...，阳居初位，踩虎尾战战兢兢，最终吉祥。。', takashiCase: '某商人占贸易，得天泽履之九四。高岛曰：「履虎尾愬愬，终吉。...」踩虎尾战战兢兢，最终吉祥。。后果大获其利。' }, { position: 5, name: '九五', text: '夬履，贞厉。', interpretation: '决然前行，守正有危险。', classicComment: '《象》曰：夬履，贞厉。...，阳居初位，决然前行，守正有危险。。', takashiCase: '某商人占贸易，得天泽履之九五。高岛曰：「夬履，贞厉。...」决然前行，守正有危险。。后事败，悔之晚矣。' }, { position: 6, name: '上九', text: '视履考祥，其旋元吉。', interpretation: '审视行为考察祥瑞，周旋圆满大吉。', classicComment: '《象》曰：视履考祥，其旋元吉。...，阳居初位，审视行为考察祥瑞，周旋圆满大吉。', takashiCase: '某商人占贸易，得天泽履之上九。高岛曰：「视履考祥，其旋元吉。...」审视行为考察祥瑞，周旋圆满大吉。。后果大获其利。' }] },
  { id: 11, name: '地天泰', symbol: '䷊', upperTrigram: 'kun', lowerTrigram: 'qian', number: 11, judgment: '小往大来，吉亨。', image: '泰，则是天地交而万物通也。', classicComment: '《彖》曰：地天泰，小往大来，吉亨。。《象》曰：君子以泰，则是天地交而万物通也。。', takashiCase: '某士人因事占问，得地天泰。高岛嘉右卫门断曰：「小往大来，吉亨。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦大吉！天地交感，万物通达。阴阳调和，诸事亨通之最佳卦象。', career: '事业鼎盛期，机遇连连，大展宏图。', relationship: '感情美满和谐，天人合一。', health: '身体健康，精神愉悦。', wealth: '财源广进，正财偏财皆旺。' }, lines: [{ position: 1, name: '初九', text: '拔茅茹以其汇，征吉。', interpretation: '拔茅草连带根部，前进吉祥。', classicComment: '《象》曰：拔茅茹以其汇，征吉。...，阳居初位，拔茅草连带根部，前进吉祥。。', takashiCase: '某商人占贸易，得地天泰之初九。高岛曰：「拔茅茹以其汇，征吉。...」拔茅草连带根部，前进吉祥。。后果大获其利。' }, { position: 2, name: '九二', text: '包荒，用冯河，不遐遗，朋亡，得尚于中行。', interpretation: '包容广阔，徒涉大河，不远遗弃，无私党，得助于中道。', classicComment: '《象》曰：包荒，用冯河，不遐遗，朋...，阳居初位，包容广阔，徒涉大河，不远遗弃，。', takashiCase: '某商人占贸易，得地天泰之九二。高岛曰：「包荒，用冯河，不遐遗，朋...」包容广阔，徒涉大河，不远遗弃，无私党，得。后事平平，无大得失。' }, { position: 3, name: '九三', text: '无平不陂，无往不复，艰贞无咎。勿恤其孚，于食有福。', interpretation: '没有平坦不变坡，没有去而不返，艰难守正无灾祸。', classicComment: '《象》曰：无平不陂，无往不复，艰贞...，阳居初位，没有平坦不变坡，没有去而不返，。', takashiCase: '某商人占贸易，得地天泰之九三。高岛曰：「无平不陂，无往不复，艰贞...」没有平坦不变坡，没有去而不返，艰难守正无。后果大获其利。' }, { position: 4, name: '六四', text: '翩翩不富以其邻，不戒以孚。', interpretation: '轻盈飞翔不以富裕夸耀邻里，不用戒备而有诚信。', classicComment: '《象》曰：翩翩不富以其邻，不戒以孚...，阴居初位，轻盈飞翔不以富裕夸耀邻里，不用。', takashiCase: '某商人占贸易，得地天泰之六四。高岛曰：「翩翩不富以其邻，不戒以孚...」轻盈飞翔不以富裕夸耀邻里，不用戒备而有诚。后事平平，无大得失。' }, { position: 5, name: '六五', text: '帝乙归妹，以祉元吉。', interpretation: '帝乙嫁女，以此得福大吉。', classicComment: '《象》曰：帝乙归妹，以祉元吉。...，阴居初位，帝乙嫁女，以此得福大吉。。', takashiCase: '某商人占贸易，得地天泰之六五。高岛曰：「帝乙归妹，以祉元吉。...」帝乙嫁女，以此得福大吉。。后果大获其利。' }, { position: 6, name: '上六', text: '城复于隍，勿用师，自邑告命，贞吝。', interpretation: '城墙倒塌于护城沟，不可用兵，自城邑宣告命令。', classicComment: '《象》曰：城复于隍，勿用师，自邑告...，阴居初位，城墙倒塌于护城沟，不可用兵，自。', takashiCase: '某商人占贸易，得地天泰之上六。高岛曰：「城复于隍，勿用师，自邑告...」城墙倒塌于护城沟，不可用兵，自城邑宣告命。后事平平，无大得失。' }] },
  { id: 12, name: '天地否', symbol: '䷋', upperTrigram: 'qian', lowerTrigram: 'kun', number: 12, judgment: '否之匪人，不利君子贞，大往小来。', image: '否，则是天地不交而万物不通也。', classicComment: '《彖》曰：天地否，否之匪人，不利君子贞，大往小来。。《象》曰：君子以否，则是天地不交而万物不通也。。', takashiCase: '某士人因事占问，得天地否。高岛嘉右卫门断曰：「否之匪人，不利君子贞，大往小来。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦闭塞不通之象。天地隔绝，阴阳失调。宜守静待变，韬光养晦。', career: '事业受阻，宜低调行事，保存实力。', relationship: '感情疏远冷淡，需耐心修复关系。', health: '注意身心健康，预防抑郁倾向。', wealth: '财运低迷，宜保守理财，减少开支。' }, lines: [{ position: 1, name: '初六', text: '拔茅茹以其汇，贞吉亨。', interpretation: '拔茅草连带根部，守正吉祥亨通。', classicComment: '《象》曰：拔茅茹以其汇，贞吉亨。...，阴居初位，拔茅草连带根部，守正吉祥亨通。。', takashiCase: '某商人占贸易，得天地否之初六。高岛曰：「拔茅茹以其汇，贞吉亨。...」拔茅草连带根部，守正吉祥亨通。。后果大获其利。' }, { position: 2, name: '六二', text: '包承，小人吉，大人否亨。', interpretation: '包容承受，小人吉祥，大人闭塞亨通。', classicComment: '《象》曰：包承，小人吉，大人否亨。...，阴居初位，包容承受，小人吉祥，大人闭塞亨。', takashiCase: '某商人占贸易，得天地否之六二。高岛曰：「包承，小人吉，大人否亨。...」包容承受，小人吉祥，大人闭塞亨通。。后果大获其利。' }, { position: 3, name: '六三', text: '包羞。', interpretation: '包含羞耻。', classicComment: '《象》曰：包羞。...，阴居初位，包含羞耻。。', takashiCase: '某商人占贸易，得天地否之六三。高岛曰：「包羞。...」包含羞耻。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '有命无咎，畴离祉。', interpretation: '有天命无灾祸，同类依附福祉。', classicComment: '《象》曰：有命无咎，畴离祉。...，阳居初位，有天命无灾祸，同类依附福祉。。', takashiCase: '某商人占贸易，得天地否之九四。高岛曰：「有命无咎，畴离祉。...」有天命无灾祸，同类依附福祉。。后果大获其利。' }, { position: 5, name: '九五', text: '休否，大人吉。其亡其亡，系于苞桑。', interpretation: '停止闭塞，大人吉祥。灭亡灭亡，系于桑树丛。', classicComment: '《象》曰：休否，大人吉。其亡其亡，...，阳居初位，停止闭塞，大人吉祥。灭亡灭亡，。', takashiCase: '某商人占贸易，得天地否之九五。高岛曰：「休否，大人吉。其亡其亡，...」停止闭塞，大人吉祥。灭亡灭亡，系于桑树丛。后果大获其利。' }, { position: 6, name: '上九', text: '倾否，先否后喜。', interpretation: '倾覆闭塞，先闭塞后喜悦。', classicComment: '《象》曰：倾否，先否后喜。...，阳居初位，倾覆闭塞，先闭塞后喜悦。。', takashiCase: '某商人占贸易，得天地否之上九。高岛曰：「倾否，先否后喜。...」倾覆闭塞，先闭塞后喜悦。。后事平平，无大得失。' }] },
  { id: 13, name: '天火同人', symbol: '䷌', upperTrigram: 'qian', lowerTrigram: 'li', number: 13, judgment: '同人于野，亨。利涉大川，利君子贞。', image: '同人，柔得位得中而应乎乾。', classicComment: '《彖》曰：天火同人，同人于野，亨。利涉大川，利君子贞。。《象》曰：君子以同人，柔得位得中而应乎乾。。', takashiCase: '某士人因事占问，得天火同人。高岛嘉右卫门断曰：「同人于野，亨。利涉大川，利君子贞。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征志同道合之象。天与火同辉，同心协力。宜合作共赢。', career: '团队合作顺利，志同道合者共谋大业。', relationship: '感情默契，心灵相通。', health: '心情开朗有益健康。', wealth: '合作创富，互利共赢。' }, lines: [{ position: 1, name: '初九', text: '同人于门，无咎。', interpretation: '在门口与人聚合，无灾祸。', classicComment: '《象》曰：同人于门，无咎。...，阳居初位，在门口与人聚合，无灾祸。。', takashiCase: '某商人占贸易，得天火同人之初九。高岛曰：「同人于门，无咎。...」在门口与人聚合，无灾祸。。后果大获其利。' }, { position: 2, name: '六二', text: '同人于宗，吝。', interpretation: '只在宗族内部聚合，有所憾惜。', classicComment: '《象》曰：同人于宗，吝。...，阴居初位，只在宗族内部聚合，有所憾惜。。', takashiCase: '某商人占贸易，得天火同人之六二。高岛曰：「同人于宗，吝。...」只在宗族内部聚合，有所憾惜。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '伏戎于莽，升其高陵，三岁不兴。', interpretation: '埋伏军队于草莽，登上高陵，三年不能兴起。', classicComment: '《象》曰：伏戎于莽，升其高陵，三岁...，阳居初位，埋伏军队于草莽，登上高陵，三年。', takashiCase: '某商人占贸易，得天火同人之九三。高岛曰：「伏戎于莽，升其高陵，三岁...」埋伏军队于草莽，登上高陵，三年不能兴起。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '乘其墉，弗克攻，吉。', interpretation: '登上城墙，不能攻克，吉祥。', classicComment: '《象》曰：乘其墉，弗克攻，吉。...，阳居初位，登上城墙，不能攻克，吉祥。。', takashiCase: '某商人占贸易，得天火同人之九四。高岛曰：「乘其墉，弗克攻，吉。...」登上城墙，不能攻克，吉祥。。后果大获其利。' }, { position: 5, name: '九五', text: '同人先号咷而后笑，大师克相遇。', interpretation: '聚合之人先哭后笑，大军胜利相遇。', classicComment: '《象》曰：同人先号咷而后笑，大师克...，阳居初位，聚合之人先哭后笑，大军胜利相遇。', takashiCase: '某商人占贸易，得天火同人之九五。高岛曰：「同人先号咷而后笑，大师克...」聚合之人先哭后笑，大军胜利相遇。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '同人于郊，无悔。', interpretation: '在郊外与人聚合，没有悔恨。', classicComment: '《象》曰：同人于郊，无悔。...，阳居初位，在郊外与人聚合，没有悔恨。。', takashiCase: '某商人占贸易，得天火同人之上九。高岛曰：「同人于郊，无悔。...」在郊外与人聚合，没有悔恨。。后事平平，无大得失。' }] },
  { id: 14, name: '火天大有', symbol: '䷍', upperTrigram: 'li', lowerTrigram: 'qian', number: 14, judgment: '元亨。', image: '大有，柔得尊位大中而上下应之。', classicComment: '《彖》曰：火天大有，元亨。。《象》曰：君子以大有，柔得尊位大中而上下应之。。', takashiCase: '某士人因事占问，得火天大有。高岛嘉右卫门断曰：「元亨。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦大富大有之象。火在天上，光照万物。丰盛昌隆，大有作为。', career: '事业辉煌，成就斐然，名利双收。', relationship: '感情充实丰富，幸福美满。', health: '精力充沛，健康状态佳。', wealth: '财运极佳，收入丰厚，资产增值。' }, lines: [{ position: 1, name: '初九', text: '无交害，匪咎，艰则无咎。', interpretation: '无交往之害，不是灾祸，艰难则无灾祸。', classicComment: '《象》曰：无交害，匪咎，艰则无咎。...，阳居初位，无交往之害，不是灾祸，艰难则无。', takashiCase: '某商人占贸易，得火天大有之初九。高岛曰：「无交害，匪咎，艰则无咎。...」无交往之害，不是灾祸，艰难则无灾祸。。后果大获其利。' }, { position: 2, name: '九二', text: '大车以载，有攸往，无咎。', interpretation: '大车载物，有所前往，无灾祸。', classicComment: '《象》曰：大车以载，有攸往，无咎。...，阳居初位，大车载物，有所前往，无灾祸。。', takashiCase: '某商人占贸易，得火天大有之九二。高岛曰：「大车以载，有攸往，无咎。...」大车载物，有所前往，无灾祸。。后果大获其利。' }, { position: 3, name: '九三', text: '公用亨于天子，小人弗克。', interpretation: '公侯向天子献礼，小人做不到。', classicComment: '《象》曰：公用亨于天子，小人弗克。...，阳居初位，公侯向天子献礼，小人做不到。。', takashiCase: '某商人占贸易，得火天大有之九三。高岛曰：「公用亨于天子，小人弗克。...」公侯向天子献礼，小人做不到。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '匪其彭，无咎。', interpretation: '不自我膨胀，无灾祸。', classicComment: '《象》曰：匪其彭，无咎。...，阳居初位，不自我膨胀，无灾祸。。', takashiCase: '某商人占贸易，得火天大有之九四。高岛曰：「匪其彭，无咎。...」不自我膨胀，无灾祸。。后果大获其利。' }, { position: 5, name: '六五', text: '厥孚交如威如，吉。', interpretation: '诚信交接有威严，吉祥。', classicComment: '《象》曰：厥孚交如威如，吉。...，阴居初位，诚信交接有威严，吉祥。。', takashiCase: '某商人占贸易，得火天大有之六五。高岛曰：「厥孚交如威如，吉。...」诚信交接有威严，吉祥。。后果大获其利。' }, { position: 6, name: '上九', text: '自天祐之，吉无不利。', interpretation: '上天保佑，吉祥无所不利。', classicComment: '《象》曰：自天祐之，吉无不利。...，阳居初位，上天保佑，吉祥无所不利。。', takashiCase: '某商人占贸易，得火天大有之上九。高岛曰：「自天祐之，吉无不利。...」上天保佑，吉祥无所不利。。后果大获其利。' }] },
  { id: 15, name: '地山谦', symbol: '䷎', upperTrigram: 'kun', lowerTrigram: 'gen', number: 15, judgment: '亨，君子有终。', image: '谦，亨天道下济而光明，地道卑而上行。', classicComment: '《彖》曰：地山谦，亨，君子有终。。《象》曰：君子以谦，亨天道下济而光明，地道卑而。', takashiCase: '某士人因事占问，得地山谦。高岛嘉右卫门断曰：「亨，君子有终。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征谦虚逊让之象。地中有山，内高外低。谦受益满招损。', career: '事业宜谦虚谨慎，不骄不躁，必有好结果。', relationship: '感情中互相尊重，谦和相处。', health: '心态平和，有利于身心健康。', wealth: '谦逊待人，人脉即财脉。' }, lines: [{ position: 1, name: '初六', text: '谦谦君子，用涉大川，吉。', interpretation: '谦虚再谦虚的君子，可以渡过大河，吉祥。', classicComment: '《象》曰：谦谦君子，用涉大川，吉。...，阴居初位，谦虚再谦虚的君子，可以渡过大河。', takashiCase: '某商人占贸易，得地山谦之初六。高岛曰：「谦谦君子，用涉大川，吉。...」谦虚再谦虚的君子，可以渡过大河，吉祥。。后果大获其利。' }, { position: 2, name: '六二', text: '鸣谦，贞吉。', interpretation: '名声谦逊，守正吉祥。', classicComment: '《象》曰：鸣谦，贞吉。...，阴居初位，名声谦逊，守正吉祥。。', takashiCase: '某商人占贸易，得地山谦之六二。高岛曰：「鸣谦，贞吉。...」名声谦逊，守正吉祥。。后果大获其利。' }, { position: 3, name: '九三', text: '劳谦君子，有终吉。', interpretation: '勤劳谦虚的君子，有好的结局吉祥。', classicComment: '《象》曰：劳谦君子，有终吉。...，阳居初位，勤劳谦虚的君子，有好的结局吉祥。', takashiCase: '某商人占贸易，得地山谦之九三。高岛曰：「劳谦君子，有终吉。...」勤劳谦虚的君子，有好的结局吉祥。。后果大获其利。' }, { position: 4, name: '六四', text: '无不利撝谦。', interpretation: '无不发挥谦虚之德。', classicComment: '《象》曰：无不利撝谦。...，阴居初位，无不发挥谦虚之德。。', takashiCase: '某商人占贸易，得地山谦之六四。高岛曰：「无不利撝谦。...」无不发挥谦虚之德。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '不富以其邻，利用侵伐，无不利。', interpretation: '不因富裕而傲慢邻居，利于征伐，无所不利。', classicComment: '《象》曰：不富以其邻，利用侵伐，无...，阴居初位，不因富裕而傲慢邻居，利于征伐，。', takashiCase: '某商人占贸易，得地山谦之六五。高岛曰：「不富以其邻，利用侵伐，无...」不因富裕而傲慢邻居，利于征伐，无所不利。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '鸣谦，利用行师征邑国。', interpretation: '名声谦逊，利于行军征伐邑国。', classicComment: '《象》曰：鸣谦，利用行师征邑国。...，阴居初位，名声谦逊，利于行军征伐邑国。。', takashiCase: '某商人占贸易，得地山谦之上六。高岛曰：「鸣谦，利用行师征邑国。...」名声谦逊，利于行军征伐邑国。。后事平平，无大得失。' }] },
  { id: 16, name: '雷地豫', symbol: '䷏', upperTrigram: 'zhen', lowerTrigram: 'kun', number: 16, judgment: '利建侯行师。', image: '豫，刚应而志行，顺以动，豫。', classicComment: '《彖》曰：雷地豫，利建侯行师。。《象》曰：君子以豫，刚应而志行，顺以动，豫。。', takashiCase: '某士人因事占问，得雷地豫。高岛嘉右卫门断曰：「利建侯行师。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征欢乐和悦之象。雷出地奋，欢乐舒畅。宜把握时机，积极行动。', career: '事业顺遂，心情愉快，适合开拓进取。', relationship: '感情欢愉甜蜜，享受当下美好时光。', health: '心情愉悦促进健康，但忌过度享乐。', wealth: '财运顺畅，宜积极把握机会。' }, lines: [{ position: 1, name: '初六', text: '鸣豫，凶。', interpretation: '自鸣得意享乐，凶险。', classicComment: '《象》曰：鸣豫，凶。...，阴居初位，自鸣得意享乐，凶险。。', takashiCase: '某商人占贸易，得雷地豫之初六。高岛曰：「鸣豫，凶。...」自鸣得意享乐，凶险。。后事败，悔之晚矣。' }, { position: 2, name: '六二', text: '介于石，不终日，贞吉。', interpretation: '耿介如石，不到一天就觉悟，守正吉祥。', classicComment: '《象》曰：介于石，不终日，贞吉。...，阴居初位，耿介如石，不到一天就觉悟，守正。', takashiCase: '某商人占贸易，得雷地豫之六二。高岛曰：「介于石，不终日，贞吉。...」耿介如石，不到一天就觉悟，守正吉祥。。后果大获其利。' }, { position: 3, name: '六三', text: '盱豫悔，迟有悔。', interpretation: '仰视享乐有悔恨，迟疑也有悔恨。', classicComment: '《象》曰：盱豫悔，迟有悔。...，阴居初位，仰视享乐有悔恨，迟疑也有悔恨。。', takashiCase: '某商人占贸易，得雷地豫之六三。高岛曰：「盱豫悔，迟有悔。...」仰视享乐有悔恨，迟疑也有悔恨。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '由豫，大有得。勿疑，朋盍簪。', interpretation: '由他带来欢乐，大有收获。不要怀疑，朋友聚集。', classicComment: '《象》曰：由豫，大有得。勿疑，朋盍...，阳居初位，由他带来欢乐，大有收获。不要怀。', takashiCase: '某商人占贸易，得雷地豫之九四。高岛曰：「由豫，大有得。勿疑，朋盍...」由他带来欢乐，大有收获。不要怀疑，朋友聚。后事平平，无大得失。' }, { position: 5, name: '六五', text: '贞疾，恒不死。', interpretation: '坚守正道有疾患，长久不死。', classicComment: '《象》曰：贞疾，恒不死。...，阴居初位，坚守正道有疾患，长久不死。。', takashiCase: '某商人占贸易，得雷地豫之六五。高岛曰：「贞疾，恒不死。...」坚守正道有疾患，长久不死。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '冥豫，成有渝，无咎。', interpretation: '昏暗享乐，已成之事有改变，无灾祸。', classicComment: '《象》曰：冥豫，成有渝，无咎。...，阴居初位，昏暗享乐，已成之事有改变，无灾。', takashiCase: '某商人占贸易，得雷地豫之上六。高岛曰：「冥豫，成有渝，无咎。...」昏暗享乐，已成之事有改变，无灾祸。。后果大获其利。' }] },
  { id: 17, name: '泽雷随', symbol: '䷐', upperTrigram: 'dui', lowerTrigram: 'zhen', number: 17, judgment: '元亨利贞，无咎。', image: '随，刚来而下柔，动而悦，随。', classicComment: '《彖》曰：泽雷随，元亨利贞，无咎。。《象》曰：君子以随，刚来而下柔，动而悦，随。。', takashiCase: '某士人因事占问，得泽雷随。高岛嘉右卫门断曰：「元亨利贞，无咎。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征随从追随之象。泽中有雷，随时而动。宜灵活应变，顺势而为。', career: '事业宜跟随趋势，灵活调整策略。', relationship: '感情随缘而来，顺其自然发展。', health: '顺应自然节律生活，有益健康。', wealth: '跟随市场趋势投资，顺势而为。' }, lines: [{ position: 1, name: '初九', text: '官有渝，贞吉，出门交有功。', interpretation: '职守有变动，守正吉祥，出门交往有功劳。', classicComment: '《象》曰：官有渝，贞吉，出门交有功...，阳居初位，职守有变动，守正吉祥，出门交往。', takashiCase: '某商人占贸易，得泽雷随之初九。高岛曰：「官有渝，贞吉，出门交有功...」职守有变动，守正吉祥，出门交往有功劳。。后果大获其利。' }, { position: 2, name: '六二', text: '系小子，失丈夫。', interpretation: '系恋小孩，失去丈夫。', classicComment: '《象》曰：系小子，失丈夫。...，阴居初位，系恋小孩，失去丈夫。。', takashiCase: '某商人占贸易，得泽雷随之六二。高岛曰：「系小子，失丈夫。...」系恋小孩，失去丈夫。。后事平平，无大得失。' }, { position: 3, name: '六三', text: '系丈夫，失小子，随有求得，利居贞。', interpretation: '系恋丈夫，失去小孩，随从有所求获得，宜安居守正。', classicComment: '《象》曰：系丈夫，失小子，随有求得...，阴居初位，系恋丈夫，失去小孩，随从有所求。', takashiCase: '某商人占贸易，得泽雷随之六三。高岛曰：「系丈夫，失小子，随有求得...」系恋丈夫，失去小孩，随从有所求获得，宜安。后事平平，无大得失。' }, { position: 4, name: '九四', text: '随有获，贞凶。有孚在道以明，何咎？', interpretation: '随从有收获，守正凶险。有诚信在道上光明，有什么灾祸？', classicComment: '《象》曰：随有获，贞凶。有孚在道以...，阳居初位，随从有收获，守正凶险。有诚信在。', takashiCase: '某商人占贸易，得泽雷随之九四。高岛曰：「随有获，贞凶。有孚在道以...」随从有收获，守正凶险。有诚信在道上光明，。后事败，悔之晚矣。' }, { position: 5, name: '九五', text: '孚于嘉，吉。', interpretation: '诚信于美好，吉祥。', classicComment: '《象》曰：孚于嘉，吉。...，阳居初位，诚信于美好，吉祥。。', takashiCase: '某商人占贸易，得泽雷随之九五。高岛曰：「孚于嘉，吉。...」诚信于美好，吉祥。。后果大获其利。' }, { position: 6, name: '上六', text: '拘系之，乃从维之，王用亨于西山。', interpretation: '拘禁维系他，君王在西山祭祀。', classicComment: '《象》曰：拘系之，乃从维之，王用亨...，阴居初位，拘禁维系他，君王在西山祭祀。。', takashiCase: '某商人占贸易，得泽雷随之上六。高岛曰：「拘系之，乃从维之，王用亨...」拘禁维系他，君王在西山祭祀。。后事平平，无大得失。' }] },
  { id: 18, name: '山风蛊', symbol: '䷑', upperTrigram: 'gen', lowerTrigram: 'xun', number: 18, judgment: '元亨，利涉大川，先甲三日，后甲三日。', image: '蛊，刚上而柔下，巽而止，蛊。', classicComment: '《彖》曰：山风蛊，元亨，利涉大川，先甲三日，后甲三日。。《象》曰：君子以蛊，刚上而柔下，巽而止，蛊。。', takashiCase: '某士人因事占问，得山风蛊。高岛嘉右卫门断曰：「元亨，利涉大川，先甲三日，后甲三日。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征腐败整治之象。山下有风，物久生虫。宜革除弊政，拨乱反正。', career: '事业面临整顿改革，清除积弊，重新出发。', relationship: '感情需清理过往问题，重新建立信任。', health: '注意体内毒素排出，排毒养生。', wealth: '清理不良资产，整顿财务状况。' }, lines: [{ position: 1, name: '初六', text: '干父之蛊，有子考无咎，厉终吉。', interpretation: '纠正父辈弊病，有儿子继承无灾祸，危险终吉祥。', classicComment: '《象》曰：干父之蛊，有子考无咎，厉...，阴居初位，纠正父辈弊病，有儿子继承无灾祸。', takashiCase: '某商人占贸易，得山风蛊之初六。高岛曰：「干父之蛊，有子考无咎，厉...」纠正父辈弊病，有儿子继承无灾祸，危险终吉。后果大获其利。' }, { position: 2, name: '九二', text: '干母之蛊，不可贞。', interpretation: '纠正母亲弊病，不可以固执。', classicComment: '《象》曰：干母之蛊，不可贞。...，阳居初位，纠正母亲弊病，不可以固执。。', takashiCase: '某商人占贸易，得山风蛊之九二。高岛曰：「干母之蛊，不可贞。...」纠正母亲弊病，不可以固执。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '干父之蛊，小有悔，无大咎。', interpretation: '纠正父辈弊病，稍有悔恨，无大灾祸。', classicComment: '《象》曰：干父之蛊，小有悔，无大咎...，阳居初位，纠正父辈弊病，稍有悔恨，无大灾。', takashiCase: '某商人占贸易，得山风蛊之九三。高岛曰：「干父之蛊，小有悔，无大咎...」纠正父辈弊病，稍有悔恨，无大灾祸。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '裕父之蛊，往见吝。', interpretation: '宽容父辈弊病，前往可见遗憾。', classicComment: '《象》曰：裕父之蛊，往见吝。...，阴居初位，宽容父辈弊病，前往可见遗憾。。', takashiCase: '某商人占贸易，得山风蛊之六四。高岛曰：「裕父之蛊，往见吝。...」宽容父辈弊病，前往可见遗憾。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '干父之蛊，用誉。', interpretation: '纠正父辈弊病，受到称誉。', classicComment: '《象》曰：干父之蛊，用誉。...，阴居初位，纠正父辈弊病，受到称誉。。', takashiCase: '某商人占贸易，得山风蛊之六五。高岛曰：「干父之蛊，用誉。...」纠正父辈弊病，受到称誉。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '不事王侯，高尚其事。', interpretation: '不侍奉王侯，崇尚高尚的事业。', classicComment: '《象》曰：不事王侯，高尚其事。...，阳居初位，不侍奉王侯，崇尚高尚的事业。。', takashiCase: '某商人占贸易，得山风蛊之上九。高岛曰：「不事王侯，高尚其事。...」不侍奉王侯，崇尚高尚的事业。。后事平平，无大得失。' }] },
  { id: 19, name: '地泽临', symbol: '䷒', upperTrigram: 'kun', lowerTrigram: 'dui', number: 19, judgment: '元亨利贞，至于八月有凶。', image: '临，刚浸而长，说而顺，刚中而应。', classicComment: '《彖》曰：地泽临，元亨利贞，至于八月有凶。。《象》曰：君子以临，刚浸而长，说而顺，刚中而应。', takashiCase: '某士人因事占问，得地泽临。高岛嘉右卫门断曰：「元亨利贞，至于八月有凶。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征居高临下之象。地在上泽在下，君临天下。宜把握时机，积极进取。', career: '事业上升期，地位提升，施展抱负的好时机。', relationship: '感情主动出击，掌握主导权。', health: '精力充沛，状态良好。', wealth: '财运上升，宜扩大投资规模。' }, lines: [{ position: 1, name: '初九', text: '咸临，贞吉。', interpretation: '感化临视，守正吉祥。', classicComment: '《象》曰：咸临，贞吉。...，阳居初位，感化临视，守正吉祥。。', takashiCase: '某商人占贸易，得地泽临之初九。高岛曰：「咸临，贞吉。...」感化临视，守正吉祥。。后果大获其利。' }, { position: 2, name: '九二', text: '咸临，吉无不利。', interpretation: '感化临视，吉祥无所不利。', classicComment: '《象》曰：咸临，吉无不利。...，阳居初位，感化临视，吉祥无所不利。。', takashiCase: '某商人占贸易，得地泽临之九二。高岛曰：「咸临，吉无不利。...」感化临视，吉祥无所不利。。后果大获其利。' }, { position: 3, name: '六三', text: '甘临，无攸利，既忧之，无咎。', interpretation: '甜言蜜语临视，无所利益，既然忧惧则无灾祸。', classicComment: '《象》曰：甘临，无攸利，既忧之，无...，阴居初位，甜言蜜语临视，无所利益，既然忧。', takashiCase: '某商人占贸易，得地泽临之六三。高岛曰：「甘临，无攸利，既忧之，无...」甜言蜜语临视，无所利益，既然忧惧则无灾祸。后果大获其利。' }, { position: 4, name: '六四', text: '至临，无咎。', interpretation: '亲自莅临，无灾祸。', classicComment: '《象》曰：至临，无咎。...，阴居初位，亲自莅临，无灾祸。。', takashiCase: '某商人占贸易，得地泽临之六四。高岛曰：「至临，无咎。...」亲自莅临，无灾祸。。后果大获其利。' }, { position: 5, name: '六五', text: '知临，大君之宜，吉。', interpretation: '智慧临视，大国君主之所宜，吉祥。', classicComment: '《象》曰：知临，大君之宜，吉。...，阴居初位，智慧临视，大国君主之所宜，吉祥。', takashiCase: '某商人占贸易，得地泽临之六五。高岛曰：「知临，大君之宜，吉。...」智慧临视，大国君主之所宜，吉祥。。后果大获其利。' }, { position: 6, name: '上六', text: '敦临，吉无咎。', interpretation: '敦厚临视，吉祥无灾祸。', classicComment: '《象》曰：敦临，吉无咎。...，阴居初位，敦厚临视，吉祥无灾祸。。', takashiCase: '某商人占贸易，得地泽临之上六。高岛曰：「敦临，吉无咎。...」敦厚临视，吉祥无灾祸。。后果大获其利。' }] },
  { id: 20, name: '风地观', symbol: '䷓', upperTrigram: 'xun', lowerTrigram: 'kun', number: 20, judgment: '盥而不荐，有孚颙若。', image: '观，盥而不荐，有孚颙若。', classicComment: '《彖》曰：风地观，盥而不荐，有孚颙若。。《象》曰：君子以观，盥而不荐，有孚颙若。。', takashiCase: '某士人因事占问，得风地观。高岛嘉右卫门断曰：「盥而不荐，有孚颙若。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征观察瞻仰之象。风行地上，遍观万物。宜深入观察，审慎决策。', career: '事业宜多观察分析，深入了解情况后再行动。', relationship: '感情需仔细观察对方，理性判断。', health: '关注身体信号，定期体检。', wealth: '观察市场走势，理性投资。' }, lines: [{ position: 1, name: '初六', text: '童观，小人无咎，君子吝。', interpretation: '幼稚的观察，小人无灾祸，君子有憾惜。', classicComment: '《象》曰：童观，小人无咎，君子吝。...，阴居初位，幼稚的观察，小人无灾祸，君子有。', takashiCase: '某商人占贸易，得风地观之初六。高岛曰：「童观，小人无咎，君子吝。...」幼稚的观察，小人无灾祸，君子有憾惜。。后果大获其利。' }, { position: 2, name: '六二', text: '窥观，利女贞。', interpretation: '从门缝偷看，利于女子守正。', classicComment: '《象》曰：窥观，利女贞。...，阴居初位，从门缝偷看，利于女子守正。。', takashiCase: '某商人占贸易，得风地观之六二。高岛曰：「窥观，利女贞。...」从门缝偷看，利于女子守正。。后事平平，无大得失。' }, { position: 3, name: '六三', text: '观我生进退。', interpretation: '观察我的生存进退之道。', classicComment: '《象》曰：观我生进退。...，阴居初位，观察我的生存进退之道。。', takashiCase: '某商人占贸易，得风地观之六三。高岛曰：「观我生进退。...」观察我的生存进退之道。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '观国之光，利用宾于王。', interpretation: '观光国家盛况，利于做君王的宾客。', classicComment: '《象》曰：观国之光，利用宾于王。...，阴居初位，观光国家盛况，利于做君王的宾客。', takashiCase: '某商人占贸易，得风地观之六四。高岛曰：「观国之光，利用宾于王。...」观光国家盛况，利于做君王的宾客。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '观我生，君子无咎。', interpretation: '观察我的生存之道，君子无灾祸。', classicComment: '《象》曰：观我生，君子无咎。...，阳居初位，观察我的生存之道，君子无灾祸。。', takashiCase: '某商人占贸易，得风地观之九五。高岛曰：「观我生，君子无咎。...」观察我的生存之道，君子无灾祸。。后果大获其利。' }, { position: 6, name: '上九', text: '观其生，君子无咎。', interpretation: '观察他的生存之道，君子无灾祸。', classicComment: '《象》曰：观其生，君子无咎。...，阳居初位，观察他的生存之道，君子无灾祸。。', takashiCase: '某商人占贸易，得风地观之上九。高岛曰：「观其生，君子无咎。...」观察他的生存之道，君子无灾祸。。后果大获其利。' }] },
  { id: 21, name: '火雷噬嗑', symbol: '䷔', upperTrigram: 'li', lowerTrigram: 'zhen', number: 21, judgment: '亨，利用狱。', image: '噬嗑，颐中有物曰噬嗑。', classicComment: '《彖》曰：火雷噬嗑，亨，利用狱。。《象》曰：君子以噬嗑，颐中有物曰噬嗑。。', takashiCase: '某士人因事占问，得火雷噬嗑。高岛嘉右卫门断曰：「亨，利用狱。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征决断刑罚之象。雷电交合，威明并用。宜果断处理障碍。', career: '事业遇到阻碍需坚决处理，清除障碍。', relationship: '感情中的问题需直面解决，不可回避。', health: '及时治疗疾病，不可拖延。', wealth: '处理债务纠纷，收回欠款。' }, lines: [{ position: 1, name: '初九', text: '屦校灭趾，无咎。', interpretation: '脚戴刑具遮没脚趾，无灾祸。', classicComment: '《象》曰：屦校灭趾，无咎。...，阳居初位，脚戴刑具遮没脚趾，无灾祸。。', takashiCase: '某商人占贸易，得火雷噬嗑之初九。高岛曰：「屦校灭趾，无咎。...」脚戴刑具遮没脚趾，无灾祸。。后果大获其利。' }, { position: 2, name: '六二', text: '噬肤灭鼻，无咎。', interpretation: '咬肉遮没鼻子，无灾祸。', classicComment: '《象》曰：噬肤灭鼻，无咎。...，阴居初位，咬肉遮没鼻子，无灾祸。。', takashiCase: '某商人占贸易，得火雷噬嗑之六二。高岛曰：「噬肤灭鼻，无咎。...」咬肉遮没鼻子，无灾祸。。后果大获其利。' }, { position: 3, name: '六三', text: '噬腊肉遇毒，小吝，无咎。', interpretation: '咬腊肉遇毒，小有遗憾，无灾祸。', classicComment: '《象》曰：噬腊肉遇毒，小吝，无咎。...，阴居初位，咬腊肉遇毒，小有遗憾，无灾祸。。', takashiCase: '某商人占贸易，得火雷噬嗑之六三。高岛曰：「噬腊肉遇毒，小吝，无咎。...」咬腊肉遇毒，小有遗憾，无灾祸。。后果大获其利。' }, { position: 4, name: '九四', text: '噬干胏得金矢，利艰贞吉。', interpretation: '咬带骨肉得铜箭头，宜艰难守正吉祥。', classicComment: '《象》曰：噬干胏得金矢，利艰贞吉。...，阳居初位，咬带骨肉得铜箭头，宜艰难守正吉。', takashiCase: '某商人占贸易，得火雷噬嗑之九四。高岛曰：「噬干胏得金矢，利艰贞吉。...」咬带骨肉得铜箭头，宜艰难守正吉祥。。后果大获其利。' }, { position: 5, name: '六五', text: '噬干肉得黄金，贞厉无咎。', interpretation: '咬干肉得黄金，守正有危险无灾祸。', classicComment: '《象》曰：噬干肉得黄金，贞厉无咎。...，阴居初位，咬干肉得黄金，守正有危险无灾祸。', takashiCase: '某商人占贸易，得火雷噬嗑之六五。高岛曰：「噬干肉得黄金，贞厉无咎。...」咬干肉得黄金，守正有危险无灾祸。。后果大获其利。' }, { position: 6, name: '上九', text: '荷校灭耳，凶。', interpretation: '肩扛刑具遮没耳朵，凶险。', classicComment: '《象》曰：荷校灭耳，凶。...，阳居初位，肩扛刑具遮没耳朵，凶险。。', takashiCase: '某商人占贸易，得火雷噬嗑之上九。高岛曰：「荷校灭耳，凶。...」肩扛刑具遮没耳朵，凶险。。后事败，悔之晚矣。' }] },
  { id: 22, name: '山火贲', symbol: '䷕', upperTrigram: 'gen', lowerTrigram: 'li', number: 22, judgment: '亨。小利有攸往。', image: '贲，柔来而文刚，故亨。', classicComment: '《彖》曰：山火贲，亨。小利有攸往。。《象》曰：君子以贲，柔来而文刚，故亨。。', takashiCase: '某士人因事占问，得山火贲。高岛嘉右卫门断曰：「亨。小利有攸往。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征文饰美化之象。山下有火，光彩照人。注重外在形象与内在实质平衡。', career: '事业宜包装宣传，但不可华而不实。', relationship: '感情浪漫温馨，注重仪式感。', health: '外表整洁美观，心情愉悦。', wealth: '合理装饰投资，提升价值。' }, lines: [{ position: 1, name: '初九', text: '贲其趾，舍车而徒。', interpretation: '修饰脚趾，舍弃车子步行。', classicComment: '《象》曰：贲其趾，舍车而徒。...，阳居初位，修饰脚趾，舍弃车子步行。。', takashiCase: '某商人占贸易，得山火贲之初九。高岛曰：「贲其趾，舍车而徒。...」修饰脚趾，舍弃车子步行。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '贲其须。', interpretation: '修饰胡须。', classicComment: '《象》曰：贲其须。...，阴居初位，修饰胡须。。', takashiCase: '某商人占贸易，得山火贲之六二。高岛曰：「贲其须。...」修饰胡须。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '贲如濡如，永贞吉。', interpretation: '修饰润泽的样子，永远守正吉祥。', classicComment: '《象》曰：贲如濡如，永贞吉。...，阳居初位，修饰润泽的样子，永远守正吉祥。。', takashiCase: '某商人占贸易，得山火贲之九三。高岛曰：「贲如濡如，永贞吉。...」修饰润泽的样子，永远守正吉祥。。后果大获其利。' }, { position: 4, name: '六四', text: '贲如皤如，白马翰如，匪寇婚媾。', interpretation: '修饰素白的样子，白马飞奔，非敌寇而是求婚。', classicComment: '《象》曰：贲如皤如，白马翰如，匪寇...，阴居初位，修饰素白的样子，白马飞奔，非敌。', takashiCase: '某商人占贸易，得山火贲之六四。高岛曰：「贲如皤如，白马翰如，匪寇...」修饰素白的样子，白马飞奔，非敌寇而是求婚。后事平平，无大得失。' }, { position: 5, name: '六五', text: '贲于丘园，束帛戋戋，吝，终吉。', interpretation: '修饰山丘园圃，礼物微薄，有憾惜终吉祥。', classicComment: '《象》曰：贲于丘园，束帛戋戋，吝，...，阴居初位，修饰山丘园圃，礼物微薄，有憾惜。', takashiCase: '某商人占贸易，得山火贲之六五。高岛曰：「贲于丘园，束帛戋戋，吝，...」修饰山丘园圃，礼物微薄，有憾惜终吉祥。。后果大获其利。' }, { position: 6, name: '上九', text: '白贲，无咎。', interpretation: '白色文饰，无灾祸。', classicComment: '《象》曰：白贲，无咎。...，阳居初位，白色文饰，无灾祸。。', takashiCase: '某商人占贸易，得山火贲之上九。高岛曰：「白贲，无咎。...」白色文饰，无灾祸。。后果大获其利。' }] },
  { id: 23, name: '山地剥', symbol: '䷖', upperTrigram: 'gen', lowerTrigram: 'kun', number: 23, judgment: '不利有攸往。', image: '剥，柔变刚也。', classicComment: '《彖》曰：山地剥，不利有攸往。。《象》曰：君子以剥，柔变刚也。。', takashiCase: '某士人因事占问，得山地剥。高岛嘉右卫门断曰：「不利有攸往。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征剥落衰败之象。山附于地，基础不稳。宜守不宜攻，静待转机。', career: '事业衰退期，宜收缩防守，保存实力。', relationship: '感情出现裂痕，需努力修补。', health: '身体虚弱，注意休息调养。', wealth: '资产缩水，宜止损保值。' }, lines: [{ position: 1, name: '初六', text: '剥床以足，蔑贞凶。', interpretation: '剥蚀床足，轻视守正凶险。', classicComment: '《象》曰：剥床以足，蔑贞凶。...，阴居初位，剥蚀床足，轻视守正凶险。。', takashiCase: '某商人占贸易，得山地剥之初六。高岛曰：「剥床以足，蔑贞凶。...」剥蚀床足，轻视守正凶险。。后事败，悔之晚矣。' }, { position: 2, name: '六二', text: '剥床以辨，蔑贞凶。', interpretation: '剥蚀床板，轻视守正凶险。', classicComment: '《象》曰：剥床以辨，蔑贞凶。...，阴居初位，剥蚀床板，轻视守正凶险。。', takashiCase: '某商人占贸易，得山地剥之六二。高岛曰：「剥床以辨，蔑贞凶。...」剥蚀床板，轻视守正凶险。。后事败，悔之晚矣。' }, { position: 3, name: '六三', text: '剥之，无咎。', interpretation: '剥蚀它，无灾祸。', classicComment: '《象》曰：剥之，无咎。...，阴居初位，剥蚀它，无灾祸。。', takashiCase: '某商人占贸易，得山地剥之六三。高岛曰：「剥之，无咎。...」剥蚀它，无灾祸。。后果大获其利。' }, { position: 4, name: '六四', text: '剥床以肤，凶。', interpretation: '剥蚀床身近肤，凶险。', classicComment: '《象》曰：剥床以肤，凶。...，阴居初位，剥蚀床身近肤，凶险。。', takashiCase: '某商人占贸易，得山地剥之六四。高岛曰：「剥床以肤，凶。...」剥蚀床身近肤，凶险。。后事败，悔之晚矣。' }, { position: 5, name: '六五', text: '贯鱼以宫人宠，无不利。', interpretation: '鱼贯而入宫人受宠，无所不利。', classicComment: '《象》曰：贯鱼以宫人宠，无不利。...，阴居初位，鱼贯而入宫人受宠，无所不利。。', takashiCase: '某商人占贸易，得山地剥之六五。高岛曰：「贯鱼以宫人宠，无不利。...」鱼贯而入宫人受宠，无所不利。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '硕果不食，君子得舆，小人剥庐。', interpretation: '大果实不被吃掉，君子得到车子，小人失去房屋。', classicComment: '《象》曰：硕果不食，君子得舆，小人...，阳居初位，大果实不被吃掉，君子得到车子，。', takashiCase: '某商人占贸易，得山地剥之上九。高岛曰：「硕果不食，君子得舆，小人...」大果实不被吃掉，君子得到车子，小人失去房。后事平平，无大得失。' }] },
  { id: 24, name: '地雷复', symbol: '䷗', upperTrigram: 'kun', lowerTrigram: 'zhen', number: 24, judgment: '亨。出入无疾，朋来无咎。反复其道，七日来复，利有攸往。', image: '复，其见天地之心乎。', classicComment: '《彖》曰：地雷复，亨。出入无疾，朋来无咎。反复其道，七日来。《象》曰：君子以复，其见天地之心乎。。', takashiCase: '某士人因事占问，得地雷复。高岛嘉右卫门断曰：「亨。出入无疾，朋来无咎。反复其道，七日来」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征一阳来复之象。雷在地中，万物复苏。绝处逢生，希望重现。', career: '事业触底反弹，迎来新的发展机遇。', relationship: '感情重归于好，破镜重圆。', health: '身体康复，生命力恢复。', wealth: '财运回升，投资迎来收获期。' }, lines: [{ position: 1, name: '初九', text: '不远复，无祗悔，元吉。', interpretation: '走出不远就返回，无大悔恨，大吉。', classicComment: '《象》曰：不远复，无祗悔，元吉。...，阳居初位，走出不远就返回，无大悔恨，大吉。', takashiCase: '某商人占贸易，得地雷复之初九。高岛曰：「不远复，无祗悔，元吉。...」走出不远就返回，无大悔恨，大吉。。后果大获其利。' }, { position: 2, name: '六二', text: '休复，吉。', interpretation: '美好的回归，吉祥。', classicComment: '《象》曰：休复，吉。...，阴居初位，美好的回归，吉祥。。', takashiCase: '某商人占贸易，得地雷复之六二。高岛曰：「休复，吉。...」美好的回归，吉祥。。后果大获其利。' }, { position: 3, name: '六三', text: '频复，厉无咎。', interpretation: '皱眉愁苦返回，危险无灾祸。', classicComment: '《象》曰：频复，厉无咎。...，阴居初位，皱眉愁苦返回，危险无灾祸。。', takashiCase: '某商人占贸易，得地雷复之六三。高岛曰：「频复，厉无咎。...」皱眉愁苦返回，危险无灾祸。。后果大获其利。' }, { position: 4, name: '六四', text: '中行独复。', interpretation: '中途独自返回。', classicComment: '《象》曰：中行独复。...，阴居初位，中途独自返回。。', takashiCase: '某商人占贸易，得地雷复之六四。高岛曰：「中行独复。...」中途独自返回。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '敦复，无悔。', interpretation: '敦厚返回，没有悔恨。', classicComment: '《象》曰：敦复，无悔。...，阴居初位，敦厚返回，没有悔恨。。', takashiCase: '某商人占贸易，得地雷复之六五。高岛曰：「敦复，无悔。...」敦厚返回，没有悔恨。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '迷复凶，有灾眚。用行师，终有大败。以其国君凶，至于十年不克征。', interpretation: '迷路返回凶险，有灾害。用兵征战终有大败。', classicComment: '《象》曰：迷复凶，有灾眚。用行师，...，阴居初位，迷路返回凶险，有灾害。用兵征战。', takashiCase: '某商人占贸易，得地雷复之上六。高岛曰：「迷复凶，有灾眚。用行师，...」迷路返回凶险，有灾害。用兵征战终有大败。。后事败，悔之晚矣。' }] },
  { id: 25, name: '天雷无妄', symbol: '䷘', upperTrigram: 'qian', lowerTrigram: 'zhen', number: 25, judgment: '元亨利贞。其匪正有眚，不利有攸往。', image: '无妄，刚自外来而为主于内。', classicComment: '《彖》曰：天雷无妄，元亨利贞。其匪正有眚，不利有攸往。。《象》曰：君子以无妄，刚自外来而为主于内。。', takashiCase: '某士人因事占问，得天雷无妄。高岛嘉右卫门断曰：「元亨利贞。其匪正有眚，不利有攸往。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征无妄而得之象。天下雷行，物与无妄。出乎意料之外的结果。', career: '事业可能有意外之喜或意外之惊，需随机应变。', relationship: '感情突如其来，意想不到的发展。', health: '注意突发性疾病，做好预防。', wealth: '意外之财或意外损失，需谨慎应对。' }, lines: [{ position: 1, name: '初九', text: '无妄往吉。', interpretation: '无妄前往吉祥。', classicComment: '《象》曰：无妄往吉。...，阳居初位，无妄前往吉祥。。', takashiCase: '某商人占贸易，得天雷无妄之初九。高岛曰：「无妄往吉。...」无妄前往吉祥。。后果大获其利。' }, { position: 2, name: '六二', text: '不耕获，不菑畬，则利有攸往。', interpretation: '不耕种就有收获，不开垦就有熟田，利于前往。', classicComment: '《象》曰：不耕获，不菑畬，则利有攸...，阴居初位，不耕种就有收获，不开垦就有熟田。', takashiCase: '某商人占贸易，得天雷无妄之六二。高岛曰：「不耕获，不菑畬，则利有攸...」不耕种就有收获，不开垦就有熟田，利于前往。后事平平，无大得失。' }, { position: 3, name: '六三', text: '无妄之灾，或系之牛，行人之得，邑人之灾。', interpretation: '无妄之灾，有人系牛于此，行人得牛，邑人遭灾。', classicComment: '《象》曰：无妄之灾，或系之牛，行人...，阴居初位，无妄之灾，有人系牛于此，行人得。', takashiCase: '某商人占贸易，得天雷无妄之六三。高岛曰：「无妄之灾，或系之牛，行人...」无妄之灾，有人系牛于此，行人得牛，邑人遭。后事平平，无大得失。' }, { position: 4, name: '九四', text: '可贞无咎。', interpretation: '可以守正无灾祸。', classicComment: '《象》曰：可贞无咎。...，阳居初位，可以守正无灾祸。。', takashiCase: '某商人占贸易，得天雷无妄之九四。高岛曰：「可贞无咎。...」可以守正无灾祸。。后果大获其利。' }, { position: 5, name: '九五', text: '无妄之疾，勿药有喜。', interpretation: '无妄之疾，不吃药也会好转。', classicComment: '《象》曰：无妄之疾，勿药有喜。...，阳居初位，无妄之疾，不吃药也会好转。。', takashiCase: '某商人占贸易，得天雷无妄之九五。高岛曰：「无妄之疾，勿药有喜。...」无妄之疾，不吃药也会好转。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '无妄行有眚，无攸利。', interpretation: '无妄而行有灾祸，无所利益。', classicComment: '《象》曰：无妄行有眚，无攸利。...，阳居初位，无妄而行有灾祸，无所利益。。', takashiCase: '某商人占贸易，得天雷无妄之上九。高岛曰：「无妄行有眚，无攸利。...」无妄而行有灾祸，无所利益。。后事平平，无大得失。' }] },
  { id: 26, name: '山天大畜', symbol: '䷙', upperTrigram: 'gen', lowerTrigram: 'qian', number: 26, judgment: '利贞，不家食吉，利涉大川。', image: '大畜，刚健笃实辉光，日新其德。', classicComment: '《彖》曰：山天大畜，利贞，不家食吉，利涉大川。。《象》曰：君子以大畜，刚健笃实辉光，日新其德。。', takashiCase: '某士人因事占问，得山天大畜。高岛嘉右卫门断曰：「利贞，不家食吉，利涉大川。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征大有积蓄之象。天在山中，蕴藏深厚。厚积薄发，大有可为。', career: '事业积累期，资源丰富，实力雄厚。', relationship: '感情深厚稳固，经得起考验。', health: '体质增强，精力充沛。', wealth: '资产大幅增长，财富积累丰厚。' }, lines: [{ position: 1, name: '初九', text: '有厉，利已。', interpretation: '有危险，宜停止。', classicComment: '《象》曰：有厉，利已。...，阳居初位，有危险，宜停止。。', takashiCase: '某商人占贸易，得山天大畜之初九。高岛曰：「有厉，利已。...」有危险，宜停止。。后事败，悔之晚矣。' }, { position: 2, name: '九二', text: '舆说輹。', interpretation: '车身与车轴脱离。', classicComment: '《象》曰：舆说輹。...，阳居初位，车身与车轴脱离。。', takashiCase: '某商人占贸易，得山天大畜之九二。高岛曰：「舆说輹。...」车身与车轴脱离。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '良马逐，利艰贞，日闲舆卫，利有攸往。', interpretation: '良马奔驰，宜艰难守正，每日练习车马防卫，利于前往。', classicComment: '《象》曰：良马逐，利艰贞，日闲舆卫...，阳居初位，良马奔驰，宜艰难守正，每日练习。', takashiCase: '某商人占贸易，得山天大畜之九三。高岛曰：「良马逐，利艰贞，日闲舆卫...」良马奔驰，宜艰难守正，每日练习车马防卫，。后事平平，无大得失。' }, { position: 4, name: '六四', text: '童牛之牿，元吉。', interpretation: '小牛角上绑横木，大吉。', classicComment: '《象》曰：童牛之牿，元吉。...，阴居初位，小牛角上绑横木，大吉。。', takashiCase: '某商人占贸易，得山天大畜之六四。高岛曰：「童牛之牿，元吉。...」小牛角上绑横木，大吉。。后果大获其利。' }, { position: 5, name: '六五', text: '豕之牙，吉。', interpretation: '猪的牙齿，吉祥。', classicComment: '《象》曰：豕之牙，吉。...，阴居初位，猪的牙齿，吉祥。。', takashiCase: '某商人占贸易，得山天大畜之六五。高岛曰：「豕之牙，吉。...」猪的牙齿，吉祥。。后果大获其利。' }, { position: 6, name: '上九', text: '何天之衢，亨。', interpretation: '何等畅通的天上大道，亨通。', classicComment: '《象》曰：何天之衢，亨。...，阳居初位，何等畅通的天上大道，亨通。。', takashiCase: '某商人占贸易，得山天大畜之上九。高岛曰：「何天之衢，亨。...」何等畅通的天上大道，亨通。。后事平平，无大得失。' }] },
  { id: 27, name: '山雷颐', symbol: '䷚', upperTrigram: 'gen', lowerTrigram: 'zhen', number: 27, judgment: '贞吉。观颐，自求口实。', image: '颐，贞正则吉也，观其所养也。', classicComment: '《彖》曰：山雷颐，贞吉。观颐，自求口实。。《象》曰：君子以颐，贞正则吉也，观其所养也。。', takashiCase: '某士人因事占问，得山雷颐。高岛嘉右卫门断曰：「贞吉。观颐，自求口实。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征养育修养之象。山下有雷，春雷萌动。注重养生与修身养性。', career: '事业需注重内在修养和能力提升。', relationship: '感情需用心经营呵护，相互滋养。', health: '特别关注饮食营养和养生保健。', wealth: '合理消费，量入为出。' }, lines: [{ position: 1, name: '初九', text: '舍尔灵龟，观我朵颐，凶。', interpretation: '舍弃你的灵龟，看我鼓腮进食，凶险。', classicComment: '《象》曰：舍尔灵龟，观我朵颐，凶。...，阳居初位，舍弃你的灵龟，看我鼓腮进食，凶。', takashiCase: '某商人占贸易，得山雷颐之初九。高岛曰：「舍尔灵龟，观我朵颐，凶。...」舍弃你的灵龟，看我鼓腮进食，凶险。。后事败，悔之晚矣。' }, { position: 2, name: '六二', text: '颠颐拂经于丘颐，征凶。', interpretation: '颠倒养育违背常理于丘陵养育，前往凶险。', classicComment: '《象》曰：颠颐拂经于丘颐，征凶。...，阴居初位，颠倒养育违背常理于丘陵养育，前。', takashiCase: '某商人占贸易，得山雷颐之六二。高岛曰：「颠颐拂经于丘颐，征凶。...」颠倒养育违背常理于丘陵养育，前往凶险。。后事败，悔之晚矣。' }, { position: 3, name: '六三', text: '拂颐，贞凶，十年勿用，无攸利。', interpretation: '违背养育之道，守正凶险，十年不可用，无所利益。', classicComment: '《象》曰：拂颐，贞凶，十年勿用，无...，阴居初位，违背养育之道，守正凶险，十年不。', takashiCase: '某商人占贸易，得山雷颐之六三。高岛曰：「拂颐，贞凶，十年勿用，无...」违背养育之道，守正凶险，十年不可用，无所。后事败，悔之晚矣。' }, { position: 4, name: '六四', text: '颠颐吉，虎视眈眈，其欲逐逐，无咎。', interpretation: '颠倒养育吉祥，老虎注视的样子，欲望追逐，无灾祸。', classicComment: '《象》曰：颠颐吉，虎视眈眈，其欲逐...，阴居初位，颠倒养育吉祥，老虎注视的样子，。', takashiCase: '某商人占贸易，得山雷颐之六四。高岛曰：「颠颐吉，虎视眈眈，其欲逐...」颠倒养育吉祥，老虎注视的样子，欲望追逐，。后果大获其利。' }, { position: 5, name: '六五', text: '拂经居贞吉，不可涉大川。', interpretation: '违背常理安居守正吉祥，不可渡越大河。', classicComment: '《象》曰：拂经居贞吉，不可涉大川。...，阴居初位，违背常理安居守正吉祥，不可渡越。', takashiCase: '某商人占贸易，得山雷颐之六五。高岛曰：「拂经居贞吉，不可涉大川。...」违背常理安居守正吉祥，不可渡越大河。。后果大获其利。' }, { position: 6, name: '上九', text: '由颐，厉吉，利涉大川。', interpretation: '由它供养，危险吉祥，利于渡越大河。', classicComment: '《象》曰：由颐，厉吉，利涉大川。...，阳居初位，由它供养，危险吉祥，利于渡越大。', takashiCase: '某商人占贸易，得山雷颐之上九。高岛曰：「由颐，厉吉，利涉大川。...」由它供养，危险吉祥，利于渡越大河。。后果大获其利。' }] },
  { id: 28, name: '泽风大过', symbol: '䷛', upperTrigram: 'dui', lowerTrigram: 'xun', number: 28, judgment: '栋桡，利有攸往，亨。', image: '大过，大者过也。', classicComment: '《彖》曰：泽风大过，栋桡，利有攸往，亨。。《象》曰：君子以大过，大者过也。。', takashiCase: '某士人因事占问，得泽风大过。高岛嘉右卫门断曰：「栋桡，利有攸往，亨。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征大为过度之象。泽灭木，栋梁弯曲。非常时期需非常手段。', career: '事业面临重大挑战，需采取非常规措施。', relationship: '感情经历重大考验，需勇气面对。', health: '身体状况异常，需特别关注。', wealth: '财务危机或重大投资机会并存。' }, lines: [{ position: 1, name: '初六', text: '藉用白茅，无咎。', interpretation: '用白茅草垫在下面，无灾祸。', classicComment: '《象》曰：藉用白茅，无咎。...，阴居初位，用白茅草垫在下面，无灾祸。。', takashiCase: '某商人占贸易，得泽风大过之初六。高岛曰：「藉用白茅，无咎。...」用白茅草垫在下面，无灾祸。。后果大获其利。' }, { position: 2, name: '九二', text: '枯杨生稊，老夫得其女妻，无不利。', interpretation: '枯杨树生嫩芽，老夫得少妻，无所不利。', classicComment: '《象》曰：枯杨生稊，老夫得其女妻，...，阳居初位，枯杨树生嫩芽，老夫得少妻，无所。', takashiCase: '某商人占贸易，得泽风大过之九二。高岛曰：「枯杨生稊，老夫得其女妻，...」枯杨树生嫩芽，老夫得少妻，无所不利。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '栋桡凶。', interpretation: '栋梁弯曲，凶险。', classicComment: '《象》曰：栋桡凶。...，阳居初位，栋梁弯曲，凶险。。', takashiCase: '某商人占贸易，得泽风大过之九三。高岛曰：「栋桡凶。...」栋梁弯曲，凶险。。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '栋隆吉，有它吝。', interpretation: '栋梁隆起吉祥，有其他问题有憾惜。', classicComment: '《象》曰：栋隆吉，有它吝。...，阳居初位，栋梁隆起吉祥，有其他问题有憾惜。', takashiCase: '某商人占贸易，得泽风大过之九四。高岛曰：「栋隆吉，有它吝。...」栋梁隆起吉祥，有其他问题有憾惜。。后果大获其利。' }, { position: 5, name: '九五', text: '枯杨生华，老妇得其士夫，无咎无誉。', interpretation: '枯杨树开花，老妇得少夫，无灾祸无赞誉。', classicComment: '《象》曰：枯杨生华，老妇得其士夫，...，阳居初位，枯杨树开花，老妇得少夫，无灾祸。', takashiCase: '某商人占贸易，得泽风大过之九五。高岛曰：「枯杨生华，老妇得其士夫，...」枯杨树开花，老妇得少夫，无灾祸无赞誉。。后果大获其利。' }, { position: 6, name: '上六', text: '过涉灭顶，凶，无咎。', interpretation: '涉水过深淹没头顶，凶险，无灾祸。', classicComment: '《象》曰：过涉灭顶，凶，无咎。...，阴居初位，涉水过深淹没头顶，凶险，无灾祸。', takashiCase: '某商人占贸易，得泽风大过之上六。高岛曰：「过涉灭顶，凶，无咎。...」涉水过深淹没头顶，凶险，无灾祸。。后果大获其利。' }] },
  { id: 29, name: '坎为水', symbol: '䷜', upperTrigram: 'kan', lowerTrigram: 'kan', number: 29, judgment: '习坎，有孚，维心亨，行有尚。', image: '坎，重险也。水流而不盈。', classicComment: '《彖》曰：坎为水，习坎，有孚，维心亨，行有尚。。《象》曰：君子以坎，重险也。水流而不盈。。', takashiCase: '某士人因事占问，得坎为水。高岛嘉右卫门断曰：「习坎，有孚，维心亨，行有尚。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征险陷困难之象。水流不息，险陷重重。需坚定信念，勇往直前。', career: '事业遭遇重重困难，需坚持不懈才能突破。', relationship: '感情经历波折，真心可渡难关。', health: '注意肾脏泌尿系统，防范隐患。', wealth: '资金周转困难，需精打细算。' }, lines: [{ position: 1, name: '初六', text: '习坎，入于坎窞，凶。', interpretation: '重重险陷，落入陷阱深渊，凶险。', classicComment: '《象》曰：习坎，入于坎窞，凶。...，阴居初位，重重险陷，落入陷阱深渊，凶险。。', takashiCase: '某商人占贸易，得坎为水之初六。高岛曰：「习坎，入于坎窞，凶。...」重重险陷，落入陷阱深渊，凶险。。后事败，悔之晚矣。' }, { position: 2, name: '九二', text: '坎有险，求小得。', interpretation: '坎陷有危险，求取小有收获。', classicComment: '《象》曰：坎有险，求小得。...，阳居初位，坎陷有危险，求取小有收获。。', takashiCase: '某商人占贸易，得坎为水之九二。高岛曰：「坎有险，求小得。...」坎陷有危险，求取小有收获。。后事平平，无大得失。' }, { position: 3, name: '六三', text: '来之坎坎，险且枕，入于坎窞，勿用。', interpretation: '来去都是险陷，危险且枕着不安，落入陷阱，不可用。', classicComment: '《象》曰：来之坎坎，险且枕，入于坎...，阴居初位，来去都是险陷，危险且枕着不安，。', takashiCase: '某商人占贸易，得坎为水之六三。高岛曰：「来之坎坎，险且枕，入于坎...」来去都是险陷，危险且枕着不安，落入陷阱，。后事平平，无大得失。' }, { position: 4, name: '六四', text: '樽酒簋贰用缶，纳约自牖，终无咎。', interpretation: '一樽酒两簋饭用瓦器，从窗户递送简约之物，终无灾祸。', classicComment: '《象》曰：樽酒簋贰用缶，纳约自牖，...，阴居初位，一樽酒两簋饭用瓦器，从窗户递送。', takashiCase: '某商人占贸易，得坎为水之六四。高岛曰：「樽酒簋贰用缶，纳约自牖，...」一樽酒两簋饭用瓦器，从窗户递送简约之物，。后果大获其利。' }, { position: 5, name: '九五', text: '坎不盈，祗既平，无咎。', interpretation: '坑坎未满，已平整，无灾祸。', classicComment: '《象》曰：坎不盈，祗既平，无咎。...，阳居初位，坑坎未满，已平整，无灾祸。。', takashiCase: '某商人占贸易，得坎为水之九五。高岛曰：「坎不盈，祗既平，无咎。...」坑坎未满，已平整，无灾祸。。后果大获其利。' }, { position: 6, name: '上六', text: '系用徽纆，寘于丛棘，三岁不得，凶。', interpretation: '用绳索捆绑，置于荆棘丛中，三年不得脱身，凶险。', classicComment: '《象》曰：系用徽纆，寘于丛棘，三岁...，阴居初位，用绳索捆绑，置于荆棘丛中，三年。', takashiCase: '某商人占贸易，得坎为水之上六。高岛曰：「系用徽纆，寘于丛棘，三岁...」用绳索捆绑，置于荆棘丛中，三年不得脱身，。后事败，悔之晚矣。' }] },
  { id: 30, name: '离为火', symbol: '䷝', upperTrigram: 'li', lowerTrigram: 'li', number: 30, judgment: '利贞亨，畜牝牛吉。', image: '离，丽也。日月丽乎天，百谷草木丽乎土。', classicComment: '《彖》曰：离为火，利贞亨，畜牝牛吉。。《象》曰：君子以离，丽也。日月丽乎天，百谷草木。', takashiCase: '某士人因事占问，得离为火。高岛嘉右卫门断曰：「利贞亨，畜牝牛吉。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征光明附丽之象。两火相重，光明盛大。宜彰显才华，发挥光热。', career: '事业光明璀璨，才华得以展现。', relationship: '感情热烈明亮，相互吸引。', health: '精力充沛，眼神有神。', wealth: '前途光明，财富增长可见。' }, lines: [{ position: 1, name: '初九', text: '履错然，敬之无咎。', interpretation: '步履错乱，恭敬对待无灾祸。', classicComment: '《象》曰：履错然，敬之无咎。...，阳居初位，步履错乱，恭敬对待无灾祸。。', takashiCase: '某商人占贸易，得离为火之初九。高岛曰：「履错然，敬之无咎。...」步履错乱，恭敬对待无灾祸。。后果大获其利。' }, { position: 2, name: '六二', text: '黄离元吉。', interpretation: '黄色附着大吉。', classicComment: '《象》曰：黄离元吉。...，阴居初位，黄色附着大吉。。', takashiCase: '某商人占贸易，得离为火之六二。高岛曰：「黄离元吉。...」黄色附着大吉。。后果大获其利。' }, { position: 3, name: '九三', text: '日昃之离，不鼓缶而歌，则大耋之嗟，凶。', interpretation: '夕阳西下的光明，不敲瓦盆唱歌，则老人叹息，凶险。', classicComment: '《象》曰：日昃之离，不鼓缶而歌，则...，阳居初位，夕阳西下的光明，不敲瓦盆唱歌，。', takashiCase: '某商人占贸易，得离为火之九三。高岛曰：「日昃之离，不鼓缶而歌，则...」夕阳西下的光明，不敲瓦盆唱歌，则老人叹息。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '突如其来如，焚如，死如，弃如。', interpretation: '突然来到，燃烧的样子，死亡的样子，抛弃的样子。', classicComment: '《象》曰：突如其来如，焚如，死如，...，阳居初位，突然来到，燃烧的样子，死亡的样。', takashiCase: '某商人占贸易，得离为火之九四。高岛曰：「突如其来如，焚如，死如，...」突然来到，燃烧的样子，死亡的样子，抛弃的。后事平平，无大得失。' }, { position: 5, name: '六五', text: '出涕沱若，戚嗟若，吉。', interpretation: '泪流如雨，悲伤叹息，吉祥。', classicComment: '《象》曰：出涕沱若，戚嗟若，吉。...，阴居初位，泪流如雨，悲伤叹息，吉祥。。', takashiCase: '某商人占贸易，得离为火之六五。高岛曰：「出涕沱若，戚嗟若，吉。...」泪流如雨，悲伤叹息，吉祥。。后果大获其利。' }, { position: 6, name: '上九', text: '王用出征，有嘉折首，获匪其丑，无咎。', interpretation: '君王出征，嘉奖斩首之功，俘获的不是一般丑类，无灾祸。', classicComment: '《象》曰：王用出征，有嘉折首，获匪...，阳居初位，君王出征，嘉奖斩首之功，俘获的。', takashiCase: '某商人占贸易，得离为火之上九。高岛曰：「王用出征，有嘉折首，获匪...」君王出征，嘉奖斩首之功，俘获的不是一般丑。后果大获其利。' }] },
  { id: 31, name: '泽山咸', symbol: '䷞', upperTrigram: 'dui', lowerTrigram: 'gen', number: 31, judgment: '亨，利贞，取女吉。', image: '咸，感也。柔上而刚下，二气感应以相与。', classicComment: '《彖》曰：泽山咸，亨，利贞，取女吉。。《象》曰：君子以咸，感也。柔上而刚下，二气感应。', takashiCase: '某士人因事占问，得泽山咸。高岛嘉右卫门断曰：「亨，利贞，取女吉。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征感应相通之象。山上有泽，相互感应。宜以诚相待，心心相印。', career: '事业宜与人合作，建立良好沟通与信任。', relationship: '感情和谐美满，心意相通，利于婚嫁。', health: '身心舒畅，人际关系和谐有益健康。', wealth: '合作生财，互利共赢。' }, lines: [{ position: 1, name: '初六', text: '咸其拇。', interpretation: '感应到脚拇指。', classicComment: '《象》曰：咸其拇。...，阴居初位，感应到脚拇指。。', takashiCase: '某商人占贸易，得泽山咸之初六。高岛曰：「咸其拇。...」感应到脚拇指。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '咸其腓，凶，居吉。', interpretation: '感应到小腿，凶险，安居吉祥。', classicComment: '《象》曰：咸其腓，凶，居吉。...，阴居初位，感应到小腿，凶险，安居吉祥。。', takashiCase: '某商人占贸易，得泽山咸之六二。高岛曰：「咸其腓，凶，居吉。...」感应到小腿，凶险，安居吉祥。。后果大获其利。' }, { position: 3, name: '九三', text: '咸其股，执其随，往吝。', interpretation: '感应到大腿，执意跟随，前往有憾惜。', classicComment: '《象》曰：咸其股，执其随，往吝。...，阳居初位，感应到大腿，执意跟随，前往有憾。', takashiCase: '某商人占贸易，得泽山咸之九三。高岛曰：「咸其股，执其随，往吝。...」感应到大腿，执意跟随，前往有憾惜。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '贞吉悔亡，憧憧往来，朋从尔思。', interpretation: '守正吉祥悔恨消失，心意往来不定，朋友顺从你的想法。', classicComment: '《象》曰：贞吉悔亡，憧憧往来，朋从...，阳居初位，守正吉祥悔恨消失，心意往来不定。', takashiCase: '某商人占贸易，得泽山咸之九四。高岛曰：「贞吉悔亡，憧憧往来，朋从...」守正吉祥悔恨消失，心意往来不定，朋友顺从。后果大获其利。' }, { position: 5, name: '九五', text: '咸其脢，无悔。', interpretation: '感应到背脊，没有悔恨。', classicComment: '《象》曰：咸其脢，无悔。...，阳居初位，感应到背脊，没有悔恨。。', takashiCase: '某商人占贸易，得泽山咸之九五。高岛曰：「咸其脢，无悔。...」感应到背脊，没有悔恨。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '咸其辅颊舌。', interpretation: '感应到面颊和舌头。', classicComment: '《象》曰：咸其辅颊舌。...，阴居初位，感应到面颊和舌头。。', takashiCase: '某商人占贸易，得泽山咸之上六。高岛曰：「咸其辅颊舌。...」感应到面颊和舌头。。后事平平，无大得失。' }] },
  { id: 32, name: '雷风恒', symbol: '䷟', upperTrigram: 'zhen', lowerTrigram: 'xun', number: 32, judgment: '亨，无咎，利贞，利有攸往。', image: '恒，久也。刚上而柔下，雷风相与，巽而动。', classicComment: '《彖》曰：雷风恒，亨，无咎，利贞，利有攸往。。《象》曰：君子以恒，久也。刚上而柔下，雷风相与。', takashiCase: '某士人因事占问，得雷风恒。高岛嘉右卫门断曰：「亨，无咎，利贞，利有攸往。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征恒久持久之象。雷风相与，长久不变。宜持之以恒，守正不移。', career: '事业需长期坚持，不可半途而废。', relationship: '感情稳定长久，宜坚守承诺。', health: '保持良好习惯，持之以恒有益健康。', wealth: '稳健投资，长期持有。' }, lines: [{ position: 1, name: '初六', text: '浚恒，贞凶，无攸利。', interpretation: '深求恒久，守正凶险，无所利益。', classicComment: '《象》曰：浚恒，贞凶，无攸利。...，阴居初位，深求恒久，守正凶险，无所利益。。', takashiCase: '某商人占贸易，得雷风恒之初六。高岛曰：「浚恒，贞凶，无攸利。...」深求恒久，守正凶险，无所利益。。后事败，悔之晚矣。' }, { position: 2, name: '九二', text: '悔亡。', interpretation: '悔恨消失。', classicComment: '《象》曰：悔亡。...，阳居初位，悔恨消失。。', takashiCase: '某商人占贸易，得雷风恒之九二。高岛曰：「悔亡。...」悔恨消失。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '不恒其德，或承之羞，贞吝。', interpretation: '不能恒久保持德行，或许承受羞辱，守正有憾惜。', classicComment: '《象》曰：不恒其德，或承之羞，贞吝...，阳居初位，不能恒久保持德行，或许承受羞辱。', takashiCase: '某商人占贸易，得雷风恒之九三。高岛曰：「不恒其德，或承之羞，贞吝...」不能恒久保持德行，或许承受羞辱，守正有憾。后事平平，无大得失。' }, { position: 4, name: '九四', text: '田无禽。', interpretation: '田猎没有捕获禽兽。', classicComment: '《象》曰：田无禽。...，阳居初位，田猎没有捕获禽兽。。', takashiCase: '某商人占贸易，得雷风恒之九四。高岛曰：「田无禽。...」田猎没有捕获禽兽。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '恒其德，贞妇人吉，夫子凶。', interpretation: '恒久保持德行，妇人守正吉祥，男子凶险。', classicComment: '《象》曰：恒其德，贞妇人吉，夫子凶...，阴居初位，恒久保持德行，妇人守正吉祥，男。', takashiCase: '某商人占贸易，得雷风恒之六五。高岛曰：「恒其德，贞妇人吉，夫子凶...」恒久保持德行，妇人守正吉祥，男子凶险。。后果大获其利。' }, { position: 6, name: '上六', text: '振恒，凶。', interpretation: '振动不安于恒久，凶险。', classicComment: '《象》曰：振恒，凶。...，阴居初位，振动不安于恒久，凶险。。', takashiCase: '某商人占贸易，得雷风恒之上六。高岛曰：「振恒，凶。...」振动不安于恒久，凶险。。后事败，悔之晚矣。' }] },
  { id: 33, name: '天山遁', symbol: '䷠', upperTrigram: 'qian', lowerTrigram: 'gen', number: 33, judgment: '亨，小利贞。', image: '遁，退也。刚当位而应，与时行也。', classicComment: '《彖》曰：天山遁，亨，小利贞。。《象》曰：君子以遁，退也。刚当位而应，与时行也。', takashiCase: '某士人因事占问，得天山遁。高岛嘉右卫门断曰：「亨，小利贞。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征退避隐遁之象。天下有山，君子退避。宜知进退，适时隐退。', career: '事业宜暂时退让，韬光养晦。', relationship: '感情需要空间，不宜强求。', health: '注意休息，避免过度劳累。', wealth: '保守理财，减少开支。' }, lines: [{ position: 1, name: '初六', text: '遁尾，厉，勿用有攸往。', interpretation: '退避在末尾，危险，不宜有所前往。', classicComment: '《象》曰：遁尾，厉，勿用有攸往。...，阴居初位，退避在末尾，危险，不宜有所前往。', takashiCase: '某商人占贸易，得天山遁之初六。高岛曰：「遁尾，厉，勿用有攸往。...」退避在末尾，危险，不宜有所前往。。后事败，悔之晚矣。' }, { position: 2, name: '六二', text: '执之用黄牛之革，莫之胜说。', interpretation: '用黄牛皮捆绑，不能解脱。', classicComment: '《象》曰：执之用黄牛之革，莫之胜说...，阴居初位，用黄牛皮捆绑，不能解脱。。', takashiCase: '某商人占贸易，得天山遁之六二。高岛曰：「执之用黄牛之革，莫之胜说...」用黄牛皮捆绑，不能解脱。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '系遁，有疾厉，畜臣妾吉。', interpretation: '系恋退避，有疾病危险，畜养臣妾吉祥。', classicComment: '《象》曰：系遁，有疾厉，畜臣妾吉。...，阳居初位，系恋退避，有疾病危险，畜养臣妾。', takashiCase: '某商人占贸易，得天山遁之九三。高岛曰：「系遁，有疾厉，畜臣妾吉。...」系恋退避，有疾病危险，畜养臣妾吉祥。。后果大获其利。' }, { position: 4, name: '九四', text: '好遁，君子吉，小人否。', interpretation: '喜好退避，君子吉祥，小人否塞。', classicComment: '《象》曰：好遁，君子吉，小人否。...，阳居初位，喜好退避，君子吉祥，小人否塞。。', takashiCase: '某商人占贸易，得天山遁之九四。高岛曰：「好遁，君子吉，小人否。...」喜好退避，君子吉祥，小人否塞。。后果大获其利。' }, { position: 5, name: '九五', text: '嘉遁，贞吉。', interpretation: '美好的退避，守正吉祥。', classicComment: '《象》曰：嘉遁，贞吉。...，阳居初位，美好的退避，守正吉祥。。', takashiCase: '某商人占贸易，得天山遁之九五。高岛曰：「嘉遁，贞吉。...」美好的退避，守正吉祥。。后果大获其利。' }, { position: 6, name: '上九', text: '肥遁，无不利。', interpretation: '宽裕地退避，无所不利。', classicComment: '《象》曰：肥遁，无不利。...，阳居初位，宽裕地退避，无所不利。。', takashiCase: '某商人占贸易，得天山遁之上九。高岛曰：「肥遁，无不利。...」宽裕地退避，无所不利。。后事平平，无大得失。' }] },
  { id: 34, name: '雷天大壮', symbol: '䷡', upperTrigram: 'zhen', lowerTrigram: 'qian', number: 34, judgment: '利贞。', image: '大壮，大者壮也。刚以动，故壮。', classicComment: '《彖》曰：雷天大壮，利贞。。《象》曰：君子以大壮，大者壮也。刚以动，故壮。。', takashiCase: '某士人因事占问，得雷天大壮。高岛嘉右卫门断曰：「利贞。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征刚强盛壮之象。雷在天上，声势浩大。宜守正用壮，不可妄动。', career: '事业强盛，但需谨慎行事，避免冒进。', relationship: '感情热烈，但需注意方式方法。', health: '精力旺盛，注意节制。', wealth: '财运旺盛，但需稳健。' }, lines: [{ position: 1, name: '初九', text: '壮于趾，征凶，有孚。', interpretation: '强壮于脚趾，前往凶险，有诚信。', classicComment: '《象》曰：壮于趾，征凶，有孚。...，阳居初位，强壮于脚趾，前往凶险，有诚信。。', takashiCase: '某商人占贸易，得雷天大壮之初九。高岛曰：「壮于趾，征凶，有孚。...」强壮于脚趾，前往凶险，有诚信。。后事败，悔之晚矣。' }, { position: 2, name: '九二', text: '贞吉。', interpretation: '守正吉祥。', classicComment: '《象》曰：贞吉。...，阳居初位，守正吉祥。。', takashiCase: '某商人占贸易，得雷天大壮之九二。高岛曰：「贞吉。...」守正吉祥。。后果大获其利。' }, { position: 3, name: '九三', text: '小人用壮，君子用罔，贞厉。羝羊触藩，羸其角。', interpretation: '小人用强壮，君子用无为，守正有危险。公羊触藩篱，卡住角。', classicComment: '《象》曰：小人用壮，君子用罔，贞厉...，阳居初位，小人用强壮，君子用无为，守正有。', takashiCase: '某商人占贸易，得雷天大壮之九三。高岛曰：「小人用壮，君子用罔，贞厉...」小人用强壮，君子用无为，守正有危险。公羊。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '贞吉悔亡，藩决不羸，壮于大舆之輹。', interpretation: '守正吉祥悔恨消失，藩篱冲破不卡住，强壮于大车的车轴。', classicComment: '《象》曰：贞吉悔亡，藩决不羸，壮于...，阳居初位，守正吉祥悔恨消失，藩篱冲破不卡。', takashiCase: '某商人占贸易，得雷天大壮之九四。高岛曰：「贞吉悔亡，藩决不羸，壮于...」守正吉祥悔恨消失，藩篱冲破不卡住，强壮于。后果大获其利。' }, { position: 5, name: '六五', text: '丧羊于易，无悔。', interpretation: '在田畔丢失羊，没有悔恨。', classicComment: '《象》曰：丧羊于易，无悔。...，阴居初位，在田畔丢失羊，没有悔恨。。', takashiCase: '某商人占贸易，得雷天大壮之六五。高岛曰：「丧羊于易，无悔。...」在田畔丢失羊，没有悔恨。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '羝羊触藩，不能退，不能遂，无攸利，艰则吉。', interpretation: '公羊触藩篱，不能退不能进，无所利益，艰难则吉祥。', classicComment: '《象》曰：羝羊触藩，不能退，不能遂...，阴居初位，公羊触藩篱，不能退不能进，无所。', takashiCase: '某商人占贸易，得雷天大壮之上六。高岛曰：「羝羊触藩，不能退，不能遂...」公羊触藩篱，不能退不能进，无所利益，艰难。后果大获其利。' }] },
  { id: 35, name: '火地晋', symbol: '䷢', upperTrigram: 'li', lowerTrigram: 'kun', number: 35, judgment: '康侯用锡马蕃庶，昼日三接。', image: '晋，进也。明出地上，顺而丽乎大明。', classicComment: '《彖》曰：火地晋，康侯用锡马蕃庶，昼日三接。。《象》曰：君子以晋，进也。明出地上，顺而丽乎大。', takashiCase: '某士人因事占问，得火地晋。高岛嘉右卫门断曰：「康侯用锡马蕃庶，昼日三接。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征进取上升之象。日出地上，光明盛大。宜积极进取，大展宏图。', career: '事业蒸蒸日上，贵人相助，大有可为。', relationship: '感情发展顺利，光明正大。', health: '身心愉悦，精力充沛。', wealth: '财运亨通，收入增长。' }, lines: [{ position: 1, name: '初六', text: '晋如摧如，贞吉。罔孚，裕无咎。', interpretation: '进取如受挫折，守正吉祥。没有诚信，宽裕无灾祸。', classicComment: '《象》曰：晋如摧如，贞吉。罔孚，裕...，阴居初位，进取如受挫折，守正吉祥。没有诚。', takashiCase: '某商人占贸易，得火地晋之初六。高岛曰：「晋如摧如，贞吉。罔孚，裕...」进取如受挫折，守正吉祥。没有诚信，宽裕无。后果大获其利。' }, { position: 2, name: '六二', text: '晋如愁如，贞吉。受兹介福，于其王母。', interpretation: '进取如忧愁，守正吉祥。承受大福，来自王母。', classicComment: '《象》曰：晋如愁如，贞吉。受兹介福...，阴居初位，进取如忧愁，守正吉祥。承受大福。', takashiCase: '某商人占贸易，得火地晋之六二。高岛曰：「晋如愁如，贞吉。受兹介福...」进取如忧愁，守正吉祥。承受大福，来自王母。后果大获其利。' }, { position: 3, name: '六三', text: '众允，悔亡。', interpretation: '众人允许，悔恨消失。', classicComment: '《象》曰：众允，悔亡。...，阴居初位，众人允许，悔恨消失。。', takashiCase: '某商人占贸易，得火地晋之六三。高岛曰：「众允，悔亡。...」众人允许，悔恨消失。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '晋如鼫鼠，贞厉。', interpretation: '进取如鼫鼠，守正有危险。', classicComment: '《象》曰：晋如鼫鼠，贞厉。...，阳居初位，进取如鼫鼠，守正有危险。。', takashiCase: '某商人占贸易，得火地晋之九四。高岛曰：「晋如鼫鼠，贞厉。...」进取如鼫鼠，守正有危险。。后事败，悔之晚矣。' }, { position: 5, name: '六五', text: '悔亡，失得勿恤，往吉无不利。', interpretation: '悔恨消失，不要忧虑得失，前往吉祥无所不利。', classicComment: '《象》曰：悔亡，失得勿恤，往吉无不...，阴居初位，悔恨消失，不要忧虑得失，前往吉。', takashiCase: '某商人占贸易，得火地晋之六五。高岛曰：「悔亡，失得勿恤，往吉无不...」悔恨消失，不要忧虑得失，前往吉祥无所不利。后果大获其利。' }, { position: 6, name: '上九', text: '晋其角，维用伐邑，厉吉无咎，贞吝。', interpretation: '进取到角尖，用于征伐城邑，危险吉祥无灾祸，守正有憾惜。', classicComment: '《象》曰：晋其角，维用伐邑，厉吉无...，阳居初位，进取到角尖，用于征伐城邑，危险。', takashiCase: '某商人占贸易，得火地晋之上九。高岛曰：「晋其角，维用伐邑，厉吉无...」进取到角尖，用于征伐城邑，危险吉祥无灾祸。后果大获其利。' }] },
  { id: 36, name: '地火明夷', symbol: '䷣', upperTrigram: 'kun', lowerTrigram: 'li', number: 36, judgment: '利艰贞。', image: '明夷，明入地中。内文明而外柔顺，以蒙大难。', classicComment: '《彖》曰：地火明夷，利艰贞。。《象》曰：君子以明夷，明入地中。内文明而外柔顺。', takashiCase: '某士人因事占问，得地火明夷。高岛嘉右卫门断曰：「利艰贞。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征光明受损之象。日入地中，光明被掩。宜韬光养晦，守正待时。', career: '事业受阻，宜低调行事，等待时机。', relationship: '感情需隐藏真心，不宜张扬。', health: '注意情绪调节，避免抑郁。', wealth: '财运低迷，宜保守理财。' }, lines: [{ position: 1, name: '初九', text: '明夷于飞，垂其翼。君子于行，三日不食，有攸往，主人有言。', interpretation: '光明受损时飞翔，垂下翅膀。君子出行，三天不吃饭。', classicComment: '《象》曰：明夷于飞，垂其翼。君子于...，阳居初位，光明受损时飞翔，垂下翅膀。君子。', takashiCase: '某商人占贸易，得地火明夷之初九。高岛曰：「明夷于飞，垂其翼。君子于...」光明受损时飞翔，垂下翅膀。君子出行，三天。后事平平，无大得失。' }, { position: 2, name: '六二', text: '明夷，夷于左股，用拯马壮，吉。', interpretation: '光明受损，伤于左大腿，用强壮的马拯救，吉祥。', classicComment: '《象》曰：明夷，夷于左股，用拯马壮...，阴居初位，光明受损，伤于左大腿，用强壮的。', takashiCase: '某商人占贸易，得地火明夷之六二。高岛曰：「明夷，夷于左股，用拯马壮...」光明受损，伤于左大腿，用强壮的马拯救，吉。后果大获其利。' }, { position: 3, name: '九三', text: '明夷于南狩，得其大首，不可疾贞。', interpretation: '光明受损时向南狩猎，得到大头目，不可急于守正。', classicComment: '《象》曰：明夷于南狩，得其大首，不...，阳居初位，光明受损时向南狩猎，得到大头目。', takashiCase: '某商人占贸易，得地火明夷之九三。高岛曰：「明夷于南狩，得其大首，不...」光明受损时向南狩猎，得到大头目，不可急于。后事平平，无大得失。' }, { position: 4, name: '六四', text: '入于左腹，获明夷之心，于出门庭。', interpretation: '进入左腹，获得光明受损的心意，走出家门。', classicComment: '《象》曰：入于左腹，获明夷之心，于...，阴居初位，进入左腹，获得光明受损的心意，。', takashiCase: '某商人占贸易，得地火明夷之六四。高岛曰：「入于左腹，获明夷之心，于...」进入左腹，获得光明受损的心意，走出家门。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '箕子之明夷，利贞。', interpretation: '箕子的光明受损，利于守正。', classicComment: '《象》曰：箕子之明夷，利贞。...，阴居初位，箕子的光明受损，利于守正。。', takashiCase: '某商人占贸易，得地火明夷之六五。高岛曰：「箕子之明夷，利贞。...」箕子的光明受损，利于守正。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '不明晦，初登于天，后入于地。', interpretation: '不光明而昏暗，起初登天，后来入地。', classicComment: '《象》曰：不明晦，初登于天，后入于...，阴居初位，不光明而昏暗，起初登天，后来入。', takashiCase: '某商人占贸易，得地火明夷之上六。高岛曰：「不明晦，初登于天，后入于...」不光明而昏暗，起初登天，后来入地。。后事平平，无大得失。' }] },
  { id: 37, name: '风火家人', symbol: '䷤', upperTrigram: 'xun', lowerTrigram: 'li', number: 37, judgment: '利女贞。', image: '家人，女正位乎内，男正位乎外，男女正，天地之大义也。', classicComment: '《彖》曰：风火家人，利女贞。。《象》曰：君子以家人，女正位乎内，男正位乎外，。', takashiCase: '某士人因事占问，得风火家人。高岛嘉右卫门断曰：「利女贞。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征家庭和睦之象。风自火出，家人相亲。宜正家风，和睦相处。', career: '事业需团队合作，如家人般互助。', relationship: '感情和家庭和谐美满。', health: '家庭和睦有益身心健康。', wealth: '家庭理财，稳健积累。' }, lines: [{ position: 1, name: '初九', text: '闲有家，悔亡。', interpretation: '防范于未然治理家庭，悔恨消失。', classicComment: '《象》曰：闲有家，悔亡。...，阳居初位，防范于未然治理家庭，悔恨消失。。', takashiCase: '某商人占贸易，得风火家人之初九。高岛曰：「闲有家，悔亡。...」防范于未然治理家庭，悔恨消失。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '无攸遂，在中馈，贞吉。', interpretation: '无所成就，主持家中饮食，守正吉祥。', classicComment: '《象》曰：无攸遂，在中馈，贞吉。...，阴居初位，无所成就，主持家中饮食，守正吉。', takashiCase: '某商人占贸易，得风火家人之六二。高岛曰：「无攸遂，在中馈，贞吉。...」无所成就，主持家中饮食，守正吉祥。。后果大获其利。' }, { position: 3, name: '九三', text: '家人嗃嗃，悔厉吉；妇子嘻嘻，终吝。', interpretation: '家人严厉，悔恨危险吉祥；妇孺嬉笑，最终有憾惜。', classicComment: '《象》曰：家人嗃嗃，悔厉吉；妇子嘻...，阳居初位，家人严厉，悔恨危险吉祥；妇孺嬉。', takashiCase: '某商人占贸易，得风火家人之九三。高岛曰：「家人嗃嗃，悔厉吉；妇子嘻...」家人严厉，悔恨危险吉祥；妇孺嬉笑，最终有。后果大获其利。' }, { position: 4, name: '六四', text: '富家，大吉。', interpretation: '富裕家庭，大吉。', classicComment: '《象》曰：富家，大吉。...，阴居初位，富裕家庭，大吉。。', takashiCase: '某商人占贸易，得风火家人之六四。高岛曰：「富家，大吉。...」富裕家庭，大吉。。后果大获其利。' }, { position: 5, name: '九五', text: '王假有家，勿恤吉。', interpretation: '君王来到家中，不要忧虑吉祥。', classicComment: '《象》曰：王假有家，勿恤吉。...，阳居初位，君王来到家中，不要忧虑吉祥。。', takashiCase: '某商人占贸易，得风火家人之九五。高岛曰：「王假有家，勿恤吉。...」君王来到家中，不要忧虑吉祥。。后果大获其利。' }, { position: 6, name: '上九', text: '有孚威如，终吉。', interpretation: '有诚信威严的样子，最终吉祥。', classicComment: '《象》曰：有孚威如，终吉。...，阳居初位，有诚信威严的样子，最终吉祥。。', takashiCase: '某商人占贸易，得风火家人之上九。高岛曰：「有孚威如，终吉。...」有诚信威严的样子，最终吉祥。。后果大获其利。' }] },
  { id: 38, name: '火泽睽', symbol: '䷥', upperTrigram: 'li', lowerTrigram: 'dui', number: 38, judgment: '小事吉。', image: '睽，火动而上，泽动而下；二女同居，其志不同行。', classicComment: '《彖》曰：火泽睽，小事吉。。《象》曰：君子以睽，火动而上，泽动而下；二女同。', takashiCase: '某士人因事占问，得火泽睽。高岛嘉右卫门断曰：「小事吉。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征乖离背离之象。火炎上而泽水下，相背而行。宜求同存异，化解矛盾。', career: '工作中有分歧，需沟通协调。', relationship: '感情有隔阂，需坦诚相待。', health: '注意情绪波动，保持平和。', wealth: '财务有分歧，需协商解决。' }, lines: [{ position: 1, name: '初九', text: '悔亡，丧马勿逐，自复；见恶人无咎。', interpretation: '悔恨消失，丢失马不要追逐，自己会回来；见到恶人无灾祸。', classicComment: '《象》曰：悔亡，丧马勿逐，自复；见...，阳居初位，悔恨消失，丢失马不要追逐，自己。', takashiCase: '某商人占贸易，得火泽睽之初九。高岛曰：「悔亡，丧马勿逐，自复；见...」悔恨消失，丢失马不要追逐，自己会回来；见。后果大获其利。' }, { position: 2, name: '九二', text: '遇主于巷，无咎。', interpretation: '在巷中遇到主人，无灾祸。', classicComment: '《象》曰：遇主于巷，无咎。...，阳居初位，在巷中遇到主人，无灾祸。。', takashiCase: '某商人占贸易，得火泽睽之九二。高岛曰：「遇主于巷，无咎。...」在巷中遇到主人，无灾祸。。后果大获其利。' }, { position: 3, name: '六三', text: '见舆曳，其牛掣，其人天且劓，无初有终。', interpretation: '看到车被拖，牛被牵，那人被刺额割鼻，没有开始但有结果。', classicComment: '《象》曰：见舆曳，其牛掣，其人天且...，阴居初位，看到车被拖，牛被牵，那人被刺额。', takashiCase: '某商人占贸易，得火泽睽之六三。高岛曰：「见舆曳，其牛掣，其人天且...」看到车被拖，牛被牵，那人被刺额割鼻，没有。后事平平，无大得失。' }, { position: 4, name: '九四', text: '睽孤，遇元夫，交孚，厉无咎。', interpretation: '乖离孤独，遇到善人，诚信交往，危险无灾祸。', classicComment: '《象》曰：睽孤，遇元夫，交孚，厉无...，阳居初位，乖离孤独，遇到善人，诚信交往，。', takashiCase: '某商人占贸易，得火泽睽之九四。高岛曰：「睽孤，遇元夫，交孚，厉无...」乖离孤独，遇到善人，诚信交往，危险无灾祸。后果大获其利。' }, { position: 5, name: '六五', text: '悔亡，厥宗噬肤，往何咎。', interpretation: '悔恨消失，同宗之人吃肉，前往有什么灾祸。', classicComment: '《象》曰：悔亡，厥宗噬肤，往何咎。...，阴居初位，悔恨消失，同宗之人吃肉，前往有。', takashiCase: '某商人占贸易，得火泽睽之六五。高岛曰：「悔亡，厥宗噬肤，往何咎。...」悔恨消失，同宗之人吃肉，前往有什么灾祸。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '睽孤，见豕负涂，载鬼一车，先张之弧，后说之弧，匪寇婚媾，往遇雨则吉。', interpretation: '乖离孤独，看到猪背上有泥，载着一车鬼，不是盗贼是求婚，前往遇雨则吉祥。', classicComment: '《象》曰：睽孤，见豕负涂，载鬼一车...，阳居初位，乖离孤独，看到猪背上有泥，载着。', takashiCase: '某商人占贸易，得火泽睽之上九。高岛曰：「睽孤，见豕负涂，载鬼一车...」乖离孤独，看到猪背上有泥，载着一车鬼，不。后果大获其利。' }] },
  { id: 39, name: '水山蹇', symbol: '䷦', upperTrigram: 'kan', lowerTrigram: 'gen', number: 39, judgment: '利西南，不利东北；利见大人，贞吉。', image: '蹇，难也，险在前也。见险而能止，知矣哉。', classicComment: '《彖》曰：水山蹇，利西南，不利东北；利见大人，贞吉。。《象》曰：君子以蹇，难也，险在前也。见险而能止。', takashiCase: '某士人因事占问，得水山蹇。高岛嘉右卫门断曰：「利西南，不利东北；利见大人，贞吉。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征艰难险阻之象。山上有水，行路艰难。宜知难而进，寻求贵人。', career: '事业遇到困难，需寻求帮助。', relationship: '感情有阻碍，需耐心克服。', health: '注意关节骨骼，小心意外。', wealth: '财务困难，需谨慎应对。' }, lines: [{ position: 1, name: '初六', text: '往蹇，来誉。', interpretation: '前往困难，回来有赞誉。', classicComment: '《象》曰：往蹇，来誉。...，阴居初位，前往困难，回来有赞誉。。', takashiCase: '某商人占贸易，得水山蹇之初六。高岛曰：「往蹇，来誉。...」前往困难，回来有赞誉。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '王臣蹇蹇，匪躬之故。', interpretation: '王臣艰难重重，不是为了自身。', classicComment: '《象》曰：王臣蹇蹇，匪躬之故。...，阴居初位，王臣艰难重重，不是为了自身。。', takashiCase: '某商人占贸易，得水山蹇之六二。高岛曰：「王臣蹇蹇，匪躬之故。...」王臣艰难重重，不是为了自身。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '往蹇来反。', interpretation: '前往困难，回来反归。', classicComment: '《象》曰：往蹇来反。...，阳居初位，前往困难，回来反归。。', takashiCase: '某商人占贸易，得水山蹇之九三。高岛曰：「往蹇来反。...」前往困难，回来反归。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '往蹇来连。', interpretation: '前往困难，回来连接。', classicComment: '《象》曰：往蹇来连。...，阴居初位，前往困难，回来连接。。', takashiCase: '某商人占贸易，得水山蹇之六四。高岛曰：「往蹇来连。...」前往困难，回来连接。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '大蹇朋来。', interpretation: '大困难时朋友来。', classicComment: '《象》曰：大蹇朋来。...，阳居初位，大困难时朋友来。。', takashiCase: '某商人占贸易，得水山蹇之九五。高岛曰：「大蹇朋来。...」大困难时朋友来。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '往蹇来硕，吉；利见大人。', interpretation: '前往困难，回来有硕果，吉祥；利于见到大人。', classicComment: '《象》曰：往蹇来硕，吉；利见大人。...，阴居初位，前往困难，回来有硕果，吉祥；利。', takashiCase: '某商人占贸易，得水山蹇之上六。高岛曰：「往蹇来硕，吉；利见大人。...」前往困难，回来有硕果，吉祥；利于见到大人。后果大获其利。' }] },
  { id: 40, name: '雷水解', symbol: '䷧', upperTrigram: 'zhen', lowerTrigram: 'kan', number: 40, judgment: '利西南，无所往，其来复吉。有攸往，夙吉。', image: '解，险以动，动而免乎险，解。', classicComment: '《彖》曰：雷水解，利西南，无所往，其来复吉。有攸往，夙吉。。《象》曰：君子以解，险以动，动而免乎险，解。。', takashiCase: '某士人因事占问，得雷水解。高岛嘉右卫门断曰：「利西南，无所往，其来复吉。有攸往，夙吉。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征解除困难之象。雷雨作解，万物复苏。宜把握时机，化解矛盾。', career: '事业困难即将解除，迎来转机。', relationship: '感情误会消除，重归于好。', health: '疾病将愈，身体恢复。', wealth: '财务问题解决，资金周转。' }, lines: [{ position: 1, name: '初六', text: '无咎。', interpretation: '无灾祸。', classicComment: '《象》曰：无咎。...，阴居初位，无灾祸。。', takashiCase: '某商人占贸易，得雷水解之初六。高岛曰：「无咎。...」无灾祸。。后果大获其利。' }, { position: 2, name: '九二', text: '田获三狐，得黄矢，贞吉。', interpretation: '田猎捕获三只狐狸，得到黄色箭矢，守正吉祥。', classicComment: '《象》曰：田获三狐，得黄矢，贞吉。...，阳居初位，田猎捕获三只狐狸，得到黄色箭矢。', takashiCase: '某商人占贸易，得雷水解之九二。高岛曰：「田获三狐，得黄矢，贞吉。...」田猎捕获三只狐狸，得到黄色箭矢，守正吉祥。后果大获其利。' }, { position: 3, name: '六三', text: '负且乘，致寇至，贞吝。', interpretation: '背着东西乘车，招致盗贼到来，守正有憾惜。', classicComment: '《象》曰：负且乘，致寇至，贞吝。...，阴居初位，背着东西乘车，招致盗贼到来，守。', takashiCase: '某商人占贸易，得雷水解之六三。高岛曰：「负且乘，致寇至，贞吝。...」背着东西乘车，招致盗贼到来，守正有憾惜。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '解而拇，朋至斯孚。', interpretation: '解开你的拇指，朋友来到这里有诚信。', classicComment: '《象》曰：解而拇，朋至斯孚。...，阳居初位，解开你的拇指，朋友来到这里有诚。', takashiCase: '某商人占贸易，得雷水解之九四。高岛曰：「解而拇，朋至斯孚。...」解开你的拇指，朋友来到这里有诚信。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '君子维有解，吉；有孚于小人。', interpretation: '君子只有解除，吉祥；对小人也有诚信。', classicComment: '《象》曰：君子维有解，吉；有孚于小...，阴居初位，君子只有解除，吉祥；对小人也有。', takashiCase: '某商人占贸易，得雷水解之六五。高岛曰：「君子维有解，吉；有孚于小...」君子只有解除，吉祥；对小人也有诚信。。后果大获其利。' }, { position: 6, name: '上六', text: '公用射隼于高墉之上，获之，无不利。', interpretation: '公侯在高墙上射隼，捕获它，无所不利。', classicComment: '《象》曰：公用射隼于高墉之上，获之...，阴居初位，公侯在高墙上射隼，捕获它，无所。', takashiCase: '某商人占贸易，得雷水解之上六。高岛曰：「公用射隼于高墉之上，获之...」公侯在高墙上射隼，捕获它，无所不利。。后事平平，无大得失。' }] },
  { id: 41, name: '山泽损', symbol: '䷨', upperTrigram: 'gen', lowerTrigram: 'dui', number: 41, judgment: '有孚，元吉，无咎，可贞，利有攸往。曷之用？二簋可用享。', image: '损，损下益上，其道上行。', classicComment: '《彖》曰：山泽损，有孚，元吉，无咎，可贞，利有攸往。曷之用。《象》曰：君子以损，损下益上，其道上行。。', takashiCase: '某士人因事占问，得山泽损。高岛嘉右卫门断曰：「有孚，元吉，无咎，可贞，利有攸往。曷之用」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征减损克制之象。山下有泽，损己利人。宜克己奉公，适度付出。', career: '事业需付出努力，可能暂时牺牲利益。', relationship: '感情需互相包容，适度付出。', health: '注意节制，避免过度消耗。', wealth: '可能需要支出，但长远有利。' }, lines: [{ position: 1, name: '初九', text: '已事遄往，无咎，酌损之。', interpretation: '停下事情迅速前往，无灾祸，酌情减损。', classicComment: '《象》曰：已事遄往，无咎，酌损之。...，阳居初位，停下事情迅速前往，无灾祸，酌情。', takashiCase: '某商人占贸易，得山泽损之初九。高岛曰：「已事遄往，无咎，酌损之。...」停下事情迅速前往，无灾祸，酌情减损。。后果大获其利。' }, { position: 2, name: '九二', text: '利贞，征凶，弗损益之。', interpretation: '利于守正，前往凶险，不减损而增益它。', classicComment: '《象》曰：利贞，征凶，弗损益之。...，阳居初位，利于守正，前往凶险，不减损而增。', takashiCase: '某商人占贸易，得山泽损之九二。高岛曰：「利贞，征凶，弗损益之。...」利于守正，前往凶险，不减损而增益它。。后事败，悔之晚矣。' }, { position: 3, name: '六三', text: '三人行，则损一人；一人行，则得其友。', interpretation: '三人同行，则减损一人；一人独行，则得到朋友。', classicComment: '《象》曰：三人行，则损一人；一人行...，阴居初位，三人同行，则减损一人；一人独行。', takashiCase: '某商人占贸易，得山泽损之六三。高岛曰：「三人行，则损一人；一人行...」三人同行，则减损一人；一人独行，则得到朋。后事平平，无大得失。' }, { position: 4, name: '六四', text: '损其疾，使遄有喜，无咎。', interpretation: '减损他的疾病，使迅速有喜事，无灾祸。', classicComment: '《象》曰：损其疾，使遄有喜，无咎。...，阴居初位，减损他的疾病，使迅速有喜事，无。', takashiCase: '某商人占贸易，得山泽损之六四。高岛曰：「损其疾，使遄有喜，无咎。...」减损他的疾病，使迅速有喜事，无灾祸。。后果大获其利。' }, { position: 5, name: '六五', text: '或益之，十朋之龟弗克违，元吉。', interpretation: '有人增益他，十朋的龟卜不能违背，大吉。', classicComment: '《象》曰：或益之，十朋之龟弗克违，...，阴居初位，有人增益他，十朋的龟卜不能违背。', takashiCase: '某商人占贸易，得山泽损之六五。高岛曰：「或益之，十朋之龟弗克违，...」有人增益他，十朋的龟卜不能违背，大吉。。后果大获其利。' }, { position: 6, name: '上九', text: '弗损益之，无咎，贞吉，利有攸往，得臣无家。', interpretation: '不减损而增益他，无灾祸，守正吉祥，利于前往，得到臣仆没有家。', classicComment: '《象》曰：弗损益之，无咎，贞吉，利...，阳居初位，不减损而增益他，无灾祸，守正吉。', takashiCase: '某商人占贸易，得山泽损之上九。高岛曰：「弗损益之，无咎，贞吉，利...」不减损而增益他，无灾祸，守正吉祥，利于前。后果大获其利。' }] },
  { id: 42, name: '风雷益', symbol: '䷩', upperTrigram: 'xun', lowerTrigram: 'zhen', number: 42, judgment: '利有攸往，利涉大川。', image: '益，损上益下，民说无疆，自上下下，其道大光。', classicComment: '《彖》曰：风雷益，利有攸往，利涉大川。。《象》曰：君子以益，损上益下，民说无疆，自上下。', takashiCase: '某士人因事占问，得风雷益。高岛嘉右卫门断曰：「利有攸往，利涉大川。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征增益受益之象。风雷相助，相得益彰。宜积极进取，广结善缘。', career: '事业大有收益，贵人相助。', relationship: '感情互相增益，共同成长。', health: '身心受益，精力充沛。', wealth: '财运亨通，收益丰厚。' }, lines: [{ position: 1, name: '初九', text: '利用为大作，元吉，无咎。', interpretation: '利于做大事，大吉，无灾祸。', classicComment: '《象》曰：利用为大作，元吉，无咎。...，阳居初位，利于做大事，大吉，无灾祸。。', takashiCase: '某商人占贸易，得风雷益之初九。高岛曰：「利用为大作，元吉，无咎。...」利于做大事，大吉，无灾祸。。后果大获其利。' }, { position: 2, name: '六二', text: '或益之，十朋之龟弗克违，永贞吉。王用享于帝，吉。', interpretation: '有人增益他，十朋的龟卜不能违背，永远守正吉祥。君王祭祀天帝，吉祥。', classicComment: '《象》曰：或益之，十朋之龟弗克违，...，阴居初位，有人增益他，十朋的龟卜不能违背。', takashiCase: '某商人占贸易，得风雷益之六二。高岛曰：「或益之，十朋之龟弗克违，...」有人增益他，十朋的龟卜不能违背，永远守正。后果大获其利。' }, { position: 3, name: '六三', text: '益之用凶事，无咎。有孚中行，告公用圭。', interpretation: '增益用于凶事，无灾祸。有诚信中道而行，用圭璧告公。', classicComment: '《象》曰：益之用凶事，无咎。有孚中...，阴居初位，增益用于凶事，无灾祸。有诚信中。', takashiCase: '某商人占贸易，得风雷益之六三。高岛曰：「益之用凶事，无咎。有孚中...」增益用于凶事，无灾祸。有诚信中道而行，用。后果大获其利。' }, { position: 4, name: '六四', text: '中行，告公从，利用为依迁国。', interpretation: '中道而行，告公顺从，利于依附迁国。', classicComment: '《象》曰：中行，告公从，利用为依迁...，阴居初位，中道而行，告公顺从，利于依附迁。', takashiCase: '某商人占贸易，得风雷益之六四。高岛曰：「中行，告公从，利用为依迁...」中道而行，告公顺从，利于依附迁国。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '有孚惠心，勿问之矣，惠我德。大吉。', interpretation: '有诚信惠爱之心，不用问了，惠爱我的德行。大吉。', classicComment: '《象》曰：有孚惠心，勿问之矣，惠我...，阳居初位，有诚信惠爱之心，不用问了，惠爱。', takashiCase: '某商人占贸易，得风雷益之九五。高岛曰：「有孚惠心，勿问之矣，惠我...」有诚信惠爱之心，不用问了，惠爱我的德行。。后果大获其利。' }, { position: 6, name: '上九', text: '莫益之，或击之，立心勿恒，凶。', interpretation: '没有人增益他，有人攻击他，立心不恒久，凶险。', classicComment: '《象》曰：莫益之，或击之，立心勿恒...，阳居初位，没有人增益他，有人攻击他，立心。', takashiCase: '某商人占贸易，得风雷益之上九。高岛曰：「莫益之，或击之，立心勿恒...」没有人增益他，有人攻击他，立心不恒久，凶。后事败，悔之晚矣。' }] },
  { id: 43, name: '泽天夬', symbol: '䷪', upperTrigram: 'dui', lowerTrigram: 'qian', number: 43, judgment: '扬于王庭，孚号，有厉，告自邑，不利即戎，利有攸往。', image: '夬，决也，刚决柔也。君子道长，小人道忧。', classicComment: '《彖》曰：泽天夬，扬于王庭，孚号，有厉，告自邑，不利即戎，。《象》曰：君子以夬，决也，刚决柔也。君子道长，。', takashiCase: '某士人因事占问，得泽天夬。高岛嘉右卫门断曰：「扬于王庭，孚号，有厉，告自邑，不利即戎，」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征决断果敢之象。泽水涨满，决堤而泻。宜果断决策，排除障碍。', career: '事业需要果断决策，不可犹豫。', relationship: '感情需明确态度，果断处理。', health: '注意排除体内毒素，排毒养生。', wealth: '财务需果断处理，清理不良资产。' }, lines: [{ position: 1, name: '初九', text: '壮于前趾，往不胜为咎。', interpretation: '强壮于前脚趾，前往不能胜利是灾祸。', classicComment: '《象》曰：壮于前趾，往不胜为咎。...，阳居初位，强壮于前脚趾，前往不能胜利是灾。', takashiCase: '某商人占贸易，得泽天夬之初九。高岛曰：「壮于前趾，往不胜为咎。...」强壮于前脚趾，前往不能胜利是灾祸。。后事平平，无大得失。' }, { position: 2, name: '九二', text: '惕号，莫夜有戎，勿恤。', interpretation: '警惕呼号，夜间有兵戎，不要忧虑。', classicComment: '《象》曰：惕号，莫夜有戎，勿恤。...，阳居初位，警惕呼号，夜间有兵戎，不要忧虑。', takashiCase: '某商人占贸易，得泽天夬之九二。高岛曰：「惕号，莫夜有戎，勿恤。...」警惕呼号，夜间有兵戎，不要忧虑。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '壮于頄，有凶。君子夬夬，独行遇雨，若濡有愠，无咎。', interpretation: '强壮于面颊，有凶险。君子决断果敢，独行遇雨，如被淋湿有愠怒，无灾祸。', classicComment: '《象》曰：壮于頄，有凶。君子夬夬，...，阳居初位，强壮于面颊，有凶险。君子决断果。', takashiCase: '某商人占贸易，得泽天夬之九三。高岛曰：「壮于頄，有凶。君子夬夬，...」强壮于面颊，有凶险。君子决断果敢，独行遇。后果大获其利。' }, { position: 4, name: '九四', text: '臀无肤，其行次且。牵羊悔亡，闻言不信。', interpretation: '臀部没有皮肤，行走困难。牵羊悔恨消失，听到话不相信。', classicComment: '《象》曰：臀无肤，其行次且。牵羊悔...，阳居初位，臀部没有皮肤，行走困难。牵羊悔。', takashiCase: '某商人占贸易，得泽天夬之九四。高岛曰：「臀无肤，其行次且。牵羊悔...」臀部没有皮肤，行走困难。牵羊悔恨消失，听。后事平平，无大得失。' }, { position: 5, name: '九五', text: '苋陆夬夬，中行无咎。', interpretation: '山羊决断果敢，中道而行无灾祸。', classicComment: '《象》曰：苋陆夬夬，中行无咎。...，阳居初位，山羊决断果敢，中道而行无灾祸。。', takashiCase: '某商人占贸易，得泽天夬之九五。高岛曰：「苋陆夬夬，中行无咎。...」山羊决断果敢，中道而行无灾祸。。后果大获其利。' }, { position: 6, name: '上六', text: '无号，终有凶。', interpretation: '没有呼号，最终有凶险。', classicComment: '《象》曰：无号，终有凶。...，阴居初位，没有呼号，最终有凶险。。', takashiCase: '某商人占贸易，得泽天夬之上六。高岛曰：「无号，终有凶。...」没有呼号，最终有凶险。。后事败，悔之晚矣。' }] },
  { id: 44, name: '天风姤', symbol: '䷫', upperTrigram: 'qian', lowerTrigram: 'xun', number: 44, judgment: '女壮，勿用取女。', image: '姤，遇也，柔遇刚也。', classicComment: '《彖》曰：天风姤，女壮，勿用取女。。《象》曰：君子以姤，遇也，柔遇刚也。。', takashiCase: '某士人因事占问，得天风姤。高岛嘉右卫门断曰：「女壮，勿用取女。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征相遇邂逅之象。天下有风，无物不遇。宜谨慎交往，防范小人。', career: '职场可能遇到新的机遇或人物。', relationship: '感情可能有新的相遇，需谨慎。', health: '注意防范外来侵扰。', wealth: '财务可能有意外变化。' }, lines: [{ position: 1, name: '初六', text: '系于金柅，贞吉，有攸往，见凶，羸豕孚蹢躅。', interpretation: '系在金属刹车器上，守正吉祥，有所前往，见到凶险，瘦猪徘徊不前。', classicComment: '《象》曰：系于金柅，贞吉，有攸往，...，阴居初位，系在金属刹车器上，守正吉祥，有。', takashiCase: '某商人占贸易，得天风姤之初六。高岛曰：「系于金柅，贞吉，有攸往，...」系在金属刹车器上，守正吉祥，有所前往，见。后果大获其利。' }, { position: 2, name: '九二', text: '包有鱼，无咎，不利宾。', interpretation: '包里有鱼，无灾祸，不利于招待宾客。', classicComment: '《象》曰：包有鱼，无咎，不利宾。...，阳居初位，包里有鱼，无灾祸，不利于招待宾。', takashiCase: '某商人占贸易，得天风姤之九二。高岛曰：「包有鱼，无咎，不利宾。...」包里有鱼，无灾祸，不利于招待宾客。。后果大获其利。' }, { position: 3, name: '九三', text: '臀无肤，其行次且，厉，无大咎。', interpretation: '臀部没有皮肤，行走困难，危险，无大灾祸。', classicComment: '《象》曰：臀无肤，其行次且，厉，无...，阳居初位，臀部没有皮肤，行走困难，危险，。', takashiCase: '某商人占贸易，得天风姤之九三。高岛曰：「臀无肤，其行次且，厉，无...」臀部没有皮肤，行走困难，危险，无大灾祸。。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '包无鱼，起凶。', interpretation: '包里没有鱼，兴起凶险。', classicComment: '《象》曰：包无鱼，起凶。...，阳居初位，包里没有鱼，兴起凶险。。', takashiCase: '某商人占贸易，得天风姤之九四。高岛曰：「包无鱼，起凶。...」包里没有鱼，兴起凶险。。后事败，悔之晚矣。' }, { position: 5, name: '九五', text: '以杞包瓜，含章，有陨自天。', interpretation: '用杞柳包瓜，内含美质，有陨落自天而来。', classicComment: '《象》曰：以杞包瓜，含章，有陨自天...，阳居初位，用杞柳包瓜，内含美质，有陨落自。', takashiCase: '某商人占贸易，得天风姤之九五。高岛曰：「以杞包瓜，含章，有陨自天...」用杞柳包瓜，内含美质，有陨落自天而来。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '姤其角，吝，无咎。', interpretation: '相遇于角尖，有憾惜，无灾祸。', classicComment: '《象》曰：姤其角，吝，无咎。...，阳居初位，相遇于角尖，有憾惜，无灾祸。。', takashiCase: '某商人占贸易，得天风姤之上九。高岛曰：「姤其角，吝，无咎。...」相遇于角尖，有憾惜，无灾祸。。后果大获其利。' }] },
  { id: 45, name: '泽地萃', symbol: '䷬', upperTrigram: 'dui', lowerTrigram: 'kun', number: 45, judgment: '亨。王假有庙，利见大人，亨，利贞。用大牲吉，利有攸往。', image: '萃，聚也；顺以说，刚中而应，故聚也。', classicComment: '《彖》曰：泽地萃，亨。王假有庙，利见大人，亨，利贞。用大牲。《象》曰：君子以萃，聚也；顺以说，刚中而应，故。', takashiCase: '某士人因事占问，得泽地萃。高岛嘉右卫门断曰：「亨。王假有庙，利见大人，亨，利贞。用大牲」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征聚集会合之象。泽水汇聚于地，万物聚集。宜团结合作，共谋发展。', career: '事业宜团队合作，聚集资源。', relationship: '感情和谐团聚，利于婚嫁。', health: '身心愉悦，社交有益健康。', wealth: '合作生财，聚集财富。' }, lines: [{ position: 1, name: '初六', text: '有孚不终，乃乱乃萃，若号一握为笑，勿恤，往无咎。', interpretation: '有诚信不能坚持，于是混乱于是聚集，如果呼号一握手就笑，不要忧虑，前往无灾祸。', classicComment: '《象》曰：有孚不终，乃乱乃萃，若号...，阴居初位，有诚信不能坚持，于是混乱于是聚。', takashiCase: '某商人占贸易，得泽地萃之初六。高岛曰：「有孚不终，乃乱乃萃，若号...」有诚信不能坚持，于是混乱于是聚集，如果呼。后果大获其利。' }, { position: 2, name: '六二', text: '引吉，无咎，孚乃利用禴。', interpretation: '引导吉祥，无灾祸，诚信则利于用薄祭。', classicComment: '《象》曰：引吉，无咎，孚乃利用禴。...，阴居初位，引导吉祥，无灾祸，诚信则利于用。', takashiCase: '某商人占贸易，得泽地萃之六二。高岛曰：「引吉，无咎，孚乃利用禴。...」引导吉祥，无灾祸，诚信则利于用薄祭。。后果大获其利。' }, { position: 3, name: '六三', text: '萃如嗟如，无攸利，往无咎，小吝。', interpretation: '聚集如叹息，无所利益，前往无灾祸，小有憾惜。', classicComment: '《象》曰：萃如嗟如，无攸利，往无咎...，阴居初位，聚集如叹息，无所利益，前往无灾。', takashiCase: '某商人占贸易，得泽地萃之六三。高岛曰：「萃如嗟如，无攸利，往无咎...」聚集如叹息，无所利益，前往无灾祸，小有憾。后果大获其利。' }, { position: 4, name: '九四', text: '大吉，无咎。', interpretation: '大吉，无灾祸。', classicComment: '《象》曰：大吉，无咎。...，阳居初位，大吉，无灾祸。。', takashiCase: '某商人占贸易，得泽地萃之九四。高岛曰：「大吉，无咎。...」大吉，无灾祸。。后果大获其利。' }, { position: 5, name: '九五', text: '萃有位，无咎。匪孚，元永贞，悔亡。', interpretation: '聚集有位置，无灾祸。没有诚信，开始永远守正，悔恨消失。', classicComment: '《象》曰：萃有位，无咎。匪孚，元永...，阳居初位，聚集有位置，无灾祸。没有诚信，。', takashiCase: '某商人占贸易，得泽地萃之九五。高岛曰：「萃有位，无咎。匪孚，元永...」聚集有位置，无灾祸。没有诚信，开始永远守。后果大获其利。' }, { position: 6, name: '上六', text: '赍咨涕洟，无咎。', interpretation: '叹息流涕，无灾祸。', classicComment: '《象》曰：赍咨涕洟，无咎。...，阴居初位，叹息流涕，无灾祸。。', takashiCase: '某商人占贸易，得泽地萃之上六。高岛曰：「赍咨涕洟，无咎。...」叹息流涕，无灾祸。。后果大获其利。' }] },
  { id: 46, name: '地风升', symbol: '䷭', upperTrigram: 'kun', lowerTrigram: 'xun', number: 46, judgment: '元亨，用见大人，勿恤，南征吉。', image: '升，柔以时升，巽而顺，刚中而应，是以大亨。', classicComment: '《彖》曰：地风升，元亨，用见大人，勿恤，南征吉。。《象》曰：君子以升，柔以时升，巽而顺，刚中而应。', takashiCase: '某士人因事占问，得地风升。高岛嘉右卫门断曰：「元亨，用见大人，勿恤，南征吉。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征上升进阶之象。地中生木，日渐成长。宜积极进取，稳步上升。', career: '事业蒸蒸日上，职位晋升。', relationship: '感情发展顺利，逐步深入。', health: '身体逐渐康复，精力恢复。', wealth: '财运上升，收入增长。' }, lines: [{ position: 1, name: '初六', text: '允升，大吉。', interpretation: '允许上升，大吉。', classicComment: '《象》曰：允升，大吉。...，阴居初位，允许上升，大吉。。', takashiCase: '某商人占贸易，得地风升之初六。高岛曰：「允升，大吉。...」允许上升，大吉。。后果大获其利。' }, { position: 2, name: '九二', text: '孚乃利用禴，无咎。', interpretation: '诚信则利于用薄祭，无灾祸。', classicComment: '《象》曰：孚乃利用禴，无咎。...，阳居初位，诚信则利于用薄祭，无灾祸。。', takashiCase: '某商人占贸易，得地风升之九二。高岛曰：「孚乃利用禴，无咎。...」诚信则利于用薄祭，无灾祸。。后果大获其利。' }, { position: 3, name: '九三', text: '升虚邑。', interpretation: '上升到空虚的城邑。', classicComment: '《象》曰：升虚邑。...，阳居初位，上升到空虚的城邑。。', takashiCase: '某商人占贸易，得地风升之九三。高岛曰：「升虚邑。...」上升到空虚的城邑。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '王用亨于岐山，吉无咎。', interpretation: '君王在岐山祭祀，吉祥无灾祸。', classicComment: '《象》曰：王用亨于岐山，吉无咎。...，阴居初位，君王在岐山祭祀，吉祥无灾祸。。', takashiCase: '某商人占贸易，得地风升之六四。高岛曰：「王用亨于岐山，吉无咎。...」君王在岐山祭祀，吉祥无灾祸。。后果大获其利。' }, { position: 5, name: '六五', text: '贞吉，升阶。', interpretation: '守正吉祥，登上台阶。', classicComment: '《象》曰：贞吉，升阶。...，阴居初位，守正吉祥，登上台阶。。', takashiCase: '某商人占贸易，得地风升之六五。高岛曰：「贞吉，升阶。...」守正吉祥，登上台阶。。后果大获其利。' }, { position: 6, name: '上六', text: '冥升，利于不息之贞。', interpretation: '昏暗地上升，利于不息地守正。', classicComment: '《象》曰：冥升，利于不息之贞。...，阴居初位，昏暗地上升，利于不息地守正。。', takashiCase: '某商人占贸易，得地风升之上六。高岛曰：「冥升，利于不息之贞。...」昏暗地上升，利于不息地守正。。后事平平，无大得失。' }] },
  { id: 47, name: '泽水困', symbol: '䷮', upperTrigram: 'dui', lowerTrigram: 'kan', number: 47, judgment: '亨，贞，大人吉，无咎，有言不信。', image: '困，刚掩也。险以说，困而不失其所，亨。', classicComment: '《彖》曰：泽水困，亨，贞，大人吉，无咎，有言不信。。《象》曰：君子以困，刚掩也。险以说，困而不失其。', takashiCase: '某士人因事占问，得泽水困。高岛嘉右卫门断曰：「亨，贞，大人吉，无咎，有言不信。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征困顿艰难之象。泽无水，困乏之极。宜坚守正道，等待转机。', career: '事业遭遇困境，需坚持等待。', relationship: '感情面临考验，需互相支持。', health: '注意精神压力，保持乐观。', wealth: '财务紧张，需开源节流。' }, lines: [{ position: 1, name: '初六', text: '臀困于株木，入于幽谷，三岁不觌。', interpretation: '臀部困于树桩，进入幽深山谷，三年不见人。', classicComment: '《象》曰：臀困于株木，入于幽谷，三...，阴居初位，臀部困于树桩，进入幽深山谷，三。', takashiCase: '某商人占贸易，得泽水困之初六。高岛曰：「臀困于株木，入于幽谷，三...」臀部困于树桩，进入幽深山谷，三年不见人。。后事平平，无大得失。' }, { position: 2, name: '九二', text: '困于酒食，朱绂方来，利用亨祀，征凶，无咎。', interpretation: '困于酒食，红色官服刚来，利于祭祀，前往凶险，无灾祸。', classicComment: '《象》曰：困于酒食，朱绂方来，利用...，阳居初位，困于酒食，红色官服刚来，利于祭。', takashiCase: '某商人占贸易，得泽水困之九二。高岛曰：「困于酒食，朱绂方来，利用...」困于酒食，红色官服刚来，利于祭祀，前往凶。后果大获其利。' }, { position: 3, name: '六三', text: '困于石，据于蒺藜，入于其宫，不见其妻，凶。', interpretation: '困于石头，依靠蒺藜，进入宫室，不见妻子，凶险。', classicComment: '《象》曰：困于石，据于蒺藜，入于其...，阴居初位，困于石头，依靠蒺藜，进入宫室，。', takashiCase: '某商人占贸易，得泽水困之六三。高岛曰：「困于石，据于蒺藜，入于其...」困于石头，依靠蒺藜，进入宫室，不见妻子，。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '来徐徐，困于金车，吝，有终。', interpretation: '缓缓而来，困于金车，有憾惜，有结果。', classicComment: '《象》曰：来徐徐，困于金车，吝，有...，阳居初位，缓缓而来，困于金车，有憾惜，有。', takashiCase: '某商人占贸易，得泽水困之九四。高岛曰：「来徐徐，困于金车，吝，有...」缓缓而来，困于金车，有憾惜，有结果。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '劓刖，困于赤绂，乃徐有说，利用祭祀。', interpretation: '割鼻断足，困于红色官服，于是渐渐解脱，利于祭祀。', classicComment: '《象》曰：劓刖，困于赤绂，乃徐有说...，阳居初位，割鼻断足，困于红色官服，于是渐。', takashiCase: '某商人占贸易，得泽水困之九五。高岛曰：「劓刖，困于赤绂，乃徐有说...」割鼻断足，困于红色官服，于是渐渐解脱，利。后事平平，无大得失。' }, { position: 6, name: '上六', text: '困于葛藟，于臲卼，曰动悔。有悔，吉。', interpretation: '困于葛藤，不安的样子，说动则有悔恨。有悔恨，吉祥。', classicComment: '《象》曰：困于葛藟，于臲卼，曰动悔...，阴居初位，困于葛藤，不安的样子，说动则有。', takashiCase: '某商人占贸易，得泽水困之上六。高岛曰：「困于葛藟，于臲卼，曰动悔...」困于葛藤，不安的样子，说动则有悔恨。有悔。后果大获其利。' }] },
  { id: 48, name: '水风井', symbol: '䷯', upperTrigram: 'kan', lowerTrigram: 'xun', number: 48, judgment: '改邑不改井，无丧无得，往来井井。汔至，亦未繘井，羸其瓶，凶。', image: '井，巽乎水而上水，井；井养而不穷也。', classicComment: '《彖》曰：水风井，改邑不改井，无丧无得，往来井井。汔至，亦。《象》曰：君子以井，巽乎水而上水，井；井养而不。', takashiCase: '某士人因事占问，得水风井。高岛嘉右卫门断曰：「改邑不改井，无丧无得，往来井井。汔至，亦」此卦凶险，宜守不宜攻，当以静制动。后果验。', interpretation: { summary: '此卦象征水井滋养之象。木上有水，源源不断。宜修身养德，利泽他人。', career: '事业如井水，源源不断，稳步发展。', relationship: '感情如井水，深厚绵长。', health: '注意肾脏保养，多喝水。', wealth: '财运稳定，细水长流。' }, lines: [{ position: 1, name: '初六', text: '井泥不食，旧井无禽。', interpretation: '井泥浑浊不能吃，旧井没有禽兽。', classicComment: '《象》曰：井泥不食，旧井无禽。...，阴居初位，井泥浑浊不能吃，旧井没有禽兽。。', takashiCase: '某商人占贸易，得水风井之初六。高岛曰：「井泥不食，旧井无禽。...」井泥浑浊不能吃，旧井没有禽兽。。后事平平，无大得失。' }, { position: 2, name: '九二', text: '井谷射射鲋，瓮敝漏。', interpretation: '井谷中射小鱼，瓮破漏。', classicComment: '《象》曰：井谷射射鲋，瓮敝漏。...，阳居初位，井谷中射小鱼，瓮破漏。。', takashiCase: '某商人占贸易，得水风井之九二。高岛曰：「井谷射射鲋，瓮敝漏。...」井谷中射小鱼，瓮破漏。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '井渫不食，为我心恻，可用汲，王明，并受其福。', interpretation: '井水清洁不吃，为我心悲伤，可以汲水，君王明察，都受到他的福气。', classicComment: '《象》曰：井渫不食，为我心恻，可用...，阳居初位，井水清洁不吃，为我心悲伤，可以。', takashiCase: '某商人占贸易，得水风井之九三。高岛曰：「井渫不食，为我心恻，可用...」井水清洁不吃，为我心悲伤，可以汲水，君王。后事平平，无大得失。' }, { position: 4, name: '六四', text: '井甃，无咎。', interpretation: '井壁砌砖，无灾祸。', classicComment: '《象》曰：井甃，无咎。...，阴居初位，井壁砌砖，无灾祸。。', takashiCase: '某商人占贸易，得水风井之六四。高岛曰：「井甃，无咎。...」井壁砌砖，无灾祸。。后果大获其利。' }, { position: 5, name: '九五', text: '井冽，寒泉食。', interpretation: '井水清凉，寒泉可吃。', classicComment: '《象》曰：井冽，寒泉食。...，阳居初位，井水清凉，寒泉可吃。。', takashiCase: '某商人占贸易，得水风井之九五。高岛曰：「井冽，寒泉食。...」井水清凉，寒泉可吃。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '井收勿幕，有孚元吉。', interpretation: '井水收起不要盖，有诚信大吉。', classicComment: '《象》曰：井收勿幕，有孚元吉。...，阴居初位，井水收起不要盖，有诚信大吉。。', takashiCase: '某商人占贸易，得水风井之上六。高岛曰：「井收勿幕，有孚元吉。...」井水收起不要盖，有诚信大吉。。后果大获其利。' }] },
  { id: 49, name: '泽火革', symbol: '䷰', upperTrigram: 'dui', lowerTrigram: 'li', number: 49, judgment: '己日乃孚，元亨利贞，悔亡。', image: '革，水火相息，二女同居，其志不相得，曰革。', classicComment: '《彖》曰：泽火革，己日乃孚，元亨利贞，悔亡。。《象》曰：君子以革，水火相息，二女同居，其志不。', takashiCase: '某士人因事占问，得泽火革。高岛嘉右卫门断曰：「己日乃孚，元亨利贞，悔亡。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征变革改变之象。泽中有火，水火相息。宜顺应时势，勇于变革。', career: '事业需要变革创新，迎接新机遇。', relationship: '感情可能有变化，需适应调整。', health: '注意生活习惯的改变，积极调整。', wealth: '财务策略需要调整，适应变化。' }, lines: [{ position: 1, name: '初九', text: '巩用黄牛之革。', interpretation: '用黄牛皮捆绑牢固。', classicComment: '《象》曰：巩用黄牛之革。...，阳居初位，用黄牛皮捆绑牢固。。', takashiCase: '某商人占贸易，得泽火革之初九。高岛曰：「巩用黄牛之革。...」用黄牛皮捆绑牢固。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '己日乃革之，征吉，无咎。', interpretation: '己日才变革它，前往吉祥，无灾祸。', classicComment: '《象》曰：己日乃革之，征吉，无咎。...，阴居初位，己日才变革它，前往吉祥，无灾祸。', takashiCase: '某商人占贸易，得泽火革之六二。高岛曰：「己日乃革之，征吉，无咎。...」己日才变革它，前往吉祥，无灾祸。。后果大获其利。' }, { position: 3, name: '九三', text: '征凶，贞厉，革言三就，有孚。', interpretation: '前往凶险，守正危险，变革言论三次成就，有诚信。', classicComment: '《象》曰：征凶，贞厉，革言三就，有...，阳居初位，前往凶险，守正危险，变革言论三。', takashiCase: '某商人占贸易，得泽火革之九三。高岛曰：「征凶，贞厉，革言三就，有...」前往凶险，守正危险，变革言论三次成就，有。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '悔亡，有孚改命，吉。', interpretation: '悔恨消失，有诚信改变命运，吉祥。', classicComment: '《象》曰：悔亡，有孚改命，吉。...，阳居初位，悔恨消失，有诚信改变命运，吉祥。', takashiCase: '某商人占贸易，得泽火革之九四。高岛曰：「悔亡，有孚改命，吉。...」悔恨消失，有诚信改变命运，吉祥。。后果大获其利。' }, { position: 5, name: '九五', text: '大人虎变，未占有孚。', interpretation: '大人如虎变，没有占卜有诚信。', classicComment: '《象》曰：大人虎变，未占有孚。...，阳居初位，大人如虎变，没有占卜有诚信。。', takashiCase: '某商人占贸易，得泽火革之九五。高岛曰：「大人虎变，未占有孚。...」大人如虎变，没有占卜有诚信。。后事平平，无大得失。' }, { position: 6, name: '上六', text: '君子豹变，小人革面，征凶，居贞吉。', interpretation: '君子如豹变，小人改变面貌，前往凶险，安居守正吉祥。', classicComment: '《象》曰：君子豹变，小人革面，征凶...，阴居初位，君子如豹变，小人改变面貌，前往。', takashiCase: '某商人占贸易，得泽火革之上六。高岛曰：「君子豹变，小人革面，征凶...」君子如豹变，小人改变面貌，前往凶险，安居。后果大获其利。' }] },
  { id: 50, name: '火风鼎', symbol: '䷱', upperTrigram: 'li', lowerTrigram: 'xun', number: 50, judgment: '元吉，亨。', image: '鼎，象也。以木巽火，亨饪也。', classicComment: '《彖》曰：火风鼎，元吉，亨。。《象》曰：君子以鼎，象也。以木巽火，亨饪也。。', takashiCase: '某士人因事占问，得火风鼎。高岛嘉右卫门断曰：「元吉，亨。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征鼎新变革之象。木上有火，烹饪成食。宜革故鼎新，成就大业。', career: '事业如鼎，稳固发展，大有成就。', relationship: '感情如鼎，稳固和谐。', health: '注意饮食健康，营养均衡。', wealth: '财运稳固，财富积累。' }, lines: [{ position: 1, name: '初六', text: '鼎颠趾，利出否，得妾以其子，无咎。', interpretation: '鼎颠倒脚趾，利于倒出废物，得到妾和她的儿子，无灾祸。', classicComment: '《象》曰：鼎颠趾，利出否，得妾以其...，阴居初位，鼎颠倒脚趾，利于倒出废物，得到。', takashiCase: '某商人占贸易，得火风鼎之初六。高岛曰：「鼎颠趾，利出否，得妾以其...」鼎颠倒脚趾，利于倒出废物，得到妾和她的儿。后果大获其利。' }, { position: 2, name: '九二', text: '鼎有实，我仇有疾，不我能即，吉。', interpretation: '鼎中有食物，我的配偶有病，不能接近我，吉祥。', classicComment: '《象》曰：鼎有实，我仇有疾，不我能...，阳居初位，鼎中有食物，我的配偶有病，不能。', takashiCase: '某商人占贸易，得火风鼎之九二。高岛曰：「鼎有实，我仇有疾，不我能...」鼎中有食物，我的配偶有病，不能接近我，吉。后果大获其利。' }, { position: 3, name: '九三', text: '鼎耳革，其行塞，雉膏不食，方雨亏悔，终吉。', interpretation: '鼎耳改变，行走受阻，野鸡肉不吃，正要下雨悔恨消失，最终吉祥。', classicComment: '《象》曰：鼎耳革，其行塞，雉膏不食...，阳居初位，鼎耳改变，行走受阻，野鸡肉不吃。', takashiCase: '某商人占贸易，得火风鼎之九三。高岛曰：「鼎耳革，其行塞，雉膏不食...」鼎耳改变，行走受阻，野鸡肉不吃，正要下雨。后果大获其利。' }, { position: 4, name: '九四', text: '鼎折足，覆公餗，其形渥，凶。', interpretation: '鼎足折断，倾覆公侯的美食，形状湿漉，凶险。', classicComment: '《象》曰：鼎折足，覆公餗，其形渥，...，阳居初位，鼎足折断，倾覆公侯的美食，形状。', takashiCase: '某商人占贸易，得火风鼎之九四。高岛曰：「鼎折足，覆公餗，其形渥，...」鼎足折断，倾覆公侯的美食，形状湿漉，凶险。后事败，悔之晚矣。' }, { position: 5, name: '六五', text: '鼎黄耳金铉，利贞。', interpretation: '鼎有黄色耳朵和金属扛鼎器，利于守正。', classicComment: '《象》曰：鼎黄耳金铉，利贞。...，阴居初位，鼎有黄色耳朵和金属扛鼎器，利于。', takashiCase: '某商人占贸易，得火风鼎之六五。高岛曰：「鼎黄耳金铉，利贞。...」鼎有黄色耳朵和金属扛鼎器，利于守正。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '鼎玉铉，大吉，无不利。', interpretation: '鼎有玉石扛鼎器，大吉，无所不利。', classicComment: '《象》曰：鼎玉铉，大吉，无不利。...，阳居初位，鼎有玉石扛鼎器，大吉，无所不利。', takashiCase: '某商人占贸易，得火风鼎之上九。高岛曰：「鼎玉铉，大吉，无不利。...」鼎有玉石扛鼎器，大吉，无所不利。。后果大获其利。' }] },
  { id: 51, name: '震为雷', symbol: '䷲', upperTrigram: 'zhen', lowerTrigram: 'zhen', number: 51, judgment: '亨。震来虩虩，笑言哑哑。震惊百里，不丧匕鬯。', image: '震，动也。震惊百里，惊远而惧迩也。', classicComment: '《彖》曰：震为雷，亨。震来虩虩，笑言哑哑。震惊百里，不丧匕。《象》曰：君子以震，动也。震惊百里，惊远而惧迩。', takashiCase: '某士人因事占问，得震为雷。高岛嘉右卫门断曰：「亨。震来虩虩，笑言哑哑。震惊百里，不丧匕」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征震动惊动之象。两雷相重，震动剧烈。宜沉着应对，化险为夷。', career: '事业可能有变动，需冷静应对。', relationship: '感情可能有波折，需稳定情绪。', health: '注意神经系统，避免惊吓。', wealth: '财务可能有波动，需谨慎。' }, lines: [{ position: 1, name: '初九', text: '震来虩虩，后笑言哑哑，吉。', interpretation: '震动来时恐惧，后来笑言哑哑，吉祥。', classicComment: '《象》曰：震来虩虩，后笑言哑哑，吉...，阳居初位，震动来时恐惧，后来笑言哑哑，吉。', takashiCase: '某商人占贸易，得震为雷之初九。高岛曰：「震来虩虩，后笑言哑哑，吉...」震动来时恐惧，后来笑言哑哑，吉祥。。后果大获其利。' }, { position: 2, name: '六二', text: '震来厉，亿丧贝，跻于九陵，勿逐，七日得。', interpretation: '震动来时危险，丧失大量财贝，登上九陵，不要追逐，七天后得到。', classicComment: '《象》曰：震来厉，亿丧贝，跻于九陵...，阴居初位，震动来时危险，丧失大量财贝，登。', takashiCase: '某商人占贸易，得震为雷之六二。高岛曰：「震来厉，亿丧贝，跻于九陵...」震动来时危险，丧失大量财贝，登上九陵，不。后事败，悔之晚矣。' }, { position: 3, name: '六三', text: '震苏苏，震行无眚。', interpretation: '震动恐惧不安，震动前行无灾祸。', classicComment: '《象》曰：震苏苏，震行无眚。...，阴居初位，震动恐惧不安，震动前行无灾祸。。', takashiCase: '某商人占贸易，得震为雷之六三。高岛曰：「震苏苏，震行无眚。...」震动恐惧不安，震动前行无灾祸。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '震遂泥。', interpretation: '震动陷入泥中。', classicComment: '《象》曰：震遂泥。...，阳居初位，震动陷入泥中。。', takashiCase: '某商人占贸易，得震为雷之九四。高岛曰：「震遂泥。...」震动陷入泥中。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '震往来厉，亿无丧，有事。', interpretation: '震动往来危险，没有丧失，有事发生。', classicComment: '《象》曰：震往来厉，亿无丧，有事。...，阴居初位，震动往来危险，没有丧失，有事发。', takashiCase: '某商人占贸易，得震为雷之六五。高岛曰：「震往来厉，亿无丧，有事。...」震动往来危险，没有丧失，有事发生。。后事败，悔之晚矣。' }, { position: 6, name: '上六', text: '震索索，视矍矍，征凶。震不于其躬，于其邻，无咎。婚媾有言。', interpretation: '震动恐惧颤抖，目光惊恐，前往凶险。震动不在自己身上，在邻居身上，无灾祸。', classicComment: '《象》曰：震索索，视矍矍，征凶。震...，阴居初位，震动恐惧颤抖，目光惊恐，前往凶。', takashiCase: '某商人占贸易，得震为雷之上六。高岛曰：「震索索，视矍矍，征凶。震...」震动恐惧颤抖，目光惊恐，前往凶险。震动不。后果大获其利。' }] },
  { id: 52, name: '艮为山', symbol: '䷳', upperTrigram: 'gen', lowerTrigram: 'gen', number: 52, judgment: '艮其背，不获其身，行其庭，不见其人，无咎。', image: '艮，止也。时止则止，时行则行，动静不失其时。', classicComment: '《彖》曰：艮为山，艮其背，不获其身，行其庭，不见其人，无咎。《象》曰：君子以艮，止也。时止则止，时行则行，。', takashiCase: '某士人因事占问，得艮为山。高岛嘉右卫门断曰：「艮其背，不获其身，行其庭，不见其人，无咎」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征静止停止之象。两山相重，稳重静止。宜适可而止，知止不殆。', career: '事业宜暂停休息，不宜冒进。', relationship: '感情需要冷静，保持距离。', health: '注意休息，静养身心。', wealth: '财务宜保守，不宜投资。' }, lines: [{ position: 1, name: '初六', text: '艮其趾，无咎，利永贞。', interpretation: '停止脚趾，无灾祸，利于永远守正。', classicComment: '《象》曰：艮其趾，无咎，利永贞。...，阴居初位，停止脚趾，无灾祸，利于永远守正。', takashiCase: '某商人占贸易，得艮为山之初六。高岛曰：「艮其趾，无咎，利永贞。...」停止脚趾，无灾祸，利于永远守正。。后果大获其利。' }, { position: 2, name: '六二', text: '艮其腓，不拯其随，其心不快。', interpretation: '停止小腿，不拯救他的跟随者，他的心不快乐。', classicComment: '《象》曰：艮其腓，不拯其随，其心不...，阴居初位，停止小腿，不拯救他的跟随者，他。', takashiCase: '某商人占贸易，得艮为山之六二。高岛曰：「艮其腓，不拯其随，其心不...」停止小腿，不拯救他的跟随者，他的心不快乐。后事平平，无大得失。' }, { position: 3, name: '九三', text: '艮其限，列其夤，厉薰心。', interpretation: '停止腰部，撕裂脊背肉，危险熏心。', classicComment: '《象》曰：艮其限，列其夤，厉薰心。...，阳居初位，停止腰部，撕裂脊背肉，危险熏心。', takashiCase: '某商人占贸易，得艮为山之九三。高岛曰：「艮其限，列其夤，厉薰心。...」停止腰部，撕裂脊背肉，危险熏心。。后事败，悔之晚矣。' }, { position: 4, name: '六四', text: '艮其身，无咎。', interpretation: '停止身体，无灾祸。', classicComment: '《象》曰：艮其身，无咎。...，阴居初位，停止身体，无灾祸。。', takashiCase: '某商人占贸易，得艮为山之六四。高岛曰：「艮其身，无咎。...」停止身体，无灾祸。。后果大获其利。' }, { position: 5, name: '六五', text: '艮其辅，言有序，悔亡。', interpretation: '停止面颊，言语有序，悔恨消失。', classicComment: '《象》曰：艮其辅，言有序，悔亡。...，阴居初位，停止面颊，言语有序，悔恨消失。。', takashiCase: '某商人占贸易，得艮为山之六五。高岛曰：「艮其辅，言有序，悔亡。...」停止面颊，言语有序，悔恨消失。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '敦艮，吉。', interpretation: '敦厚停止，吉祥。', classicComment: '《象》曰：敦艮，吉。...，阳居初位，敦厚停止，吉祥。。', takashiCase: '某商人占贸易，得艮为山之上九。高岛曰：「敦艮，吉。...」敦厚停止，吉祥。。后果大获其利。' }] },
  { id: 53, name: '风山渐', symbol: '䷴', upperTrigram: 'xun', lowerTrigram: 'gen', number: 53, judgment: '女归吉，利贞。', image: '渐，进也。女归吉也。进得位，往有功也。', classicComment: '《彖》曰：风山渐，女归吉，利贞。。《象》曰：君子以渐，进也。女归吉也。进得位，往。', takashiCase: '某士人因事占问，得风山渐。高岛嘉右卫门断曰：「女归吉，利贞。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征渐进稳步之象。山上有木，逐渐成长。宜循序渐进，稳步发展。', career: '事业宜稳步发展，不可急躁。', relationship: '感情宜循序渐进，利于婚嫁。', health: '身体逐渐康复，需要耐心。', wealth: '财运稳步增长，积少成多。' }, lines: [{ position: 1, name: '初六', text: '鸿渐于干，小子厉，有言，无咎。', interpretation: '鸿雁渐进于水边，小子危险，有言语，无灾祸。', classicComment: '《象》曰：鸿渐于干，小子厉，有言，...，阴居初位，鸿雁渐进于水边，小子危险，有言。', takashiCase: '某商人占贸易，得风山渐之初六。高岛曰：「鸿渐于干，小子厉，有言，...」鸿雁渐进于水边，小子危险，有言语，无灾祸。后果大获其利。' }, { position: 2, name: '六二', text: '鸿渐于磐，饮食衎衎，吉。', interpretation: '鸿雁渐进于磐石，饮食和乐，吉祥。', classicComment: '《象》曰：鸿渐于磐，饮食衎衎，吉。...，阴居初位，鸿雁渐进于磐石，饮食和乐，吉祥。', takashiCase: '某商人占贸易，得风山渐之六二。高岛曰：「鸿渐于磐，饮食衎衎，吉。...」鸿雁渐进于磐石，饮食和乐，吉祥。。后果大获其利。' }, { position: 3, name: '九三', text: '鸿渐于陆，夫征不复，妇孕不育，凶；利御寇。', interpretation: '鸿雁渐进于陆地，丈夫出征不回来，妇女怀孕不生育，凶险；利于抵御盗贼。', classicComment: '《象》曰：鸿渐于陆，夫征不复，妇孕...，阳居初位，鸿雁渐进于陆地，丈夫出征不回来。', takashiCase: '某商人占贸易，得风山渐之九三。高岛曰：「鸿渐于陆，夫征不复，妇孕...」鸿雁渐进于陆地，丈夫出征不回来，妇女怀孕。后事败，悔之晚矣。' }, { position: 4, name: '六四', text: '鸿渐于木，或得其桷，无咎。', interpretation: '鸿雁渐进于树木，或许得到平枝，无灾祸。', classicComment: '《象》曰：鸿渐于木，或得其桷，无咎...，阴居初位，鸿雁渐进于树木，或许得到平枝，。', takashiCase: '某商人占贸易，得风山渐之六四。高岛曰：「鸿渐于木，或得其桷，无咎...」鸿雁渐进于树木，或许得到平枝，无灾祸。。后果大获其利。' }, { position: 5, name: '九五', text: '鸿渐于陵，妇三岁不孕，终莫之胜，吉。', interpretation: '鸿雁渐进于丘陵，妇女三年不怀孕，最终没有人胜过她，吉祥。', classicComment: '《象》曰：鸿渐于陵，妇三岁不孕，终...，阳居初位，鸿雁渐进于丘陵，妇女三年不怀孕。', takashiCase: '某商人占贸易，得风山渐之九五。高岛曰：「鸿渐于陵，妇三岁不孕，终...」鸿雁渐进于丘陵，妇女三年不怀孕，最终没有。后果大获其利。' }, { position: 6, name: '上九', text: '鸿渐于陆，其羽可用为仪，吉。', interpretation: '鸿雁渐进于陆地，它的羽毛可以用作仪仗，吉祥。', classicComment: '《象》曰：鸿渐于陆，其羽可用为仪，...，阳居初位，鸿雁渐进于陆地，它的羽毛可以用。', takashiCase: '某商人占贸易，得风山渐之上九。高岛曰：「鸿渐于陆，其羽可用为仪，...」鸿雁渐进于陆地，它的羽毛可以用作仪仗，吉。后果大获其利。' }] },
  { id: 54, name: '雷泽归妹', symbol: '䷵', upperTrigram: 'zhen', lowerTrigram: 'dui', number: 54, judgment: '征凶，无攸利。', image: '归妹，天地之大义也。天地不交，而万物不兴。', classicComment: '《彖》曰：雷泽归妹，征凶，无攸利。。《象》曰：君子以归妹，天地之大义也。天地不交，。', takashiCase: '某士人因事占问，得雷泽归妹。高岛嘉右卫门断曰：「征凶，无攸利。」此卦凶险，宜守不宜攻，当以静制动。后果验。', interpretation: { summary: '此卦象征少女出嫁之象。泽上有雷，归嫁之象。宜谨慎行事，不宜冒进。', career: '事业可能有变动，需谨慎。', relationship: '感情可能有变化，需注意分寸。', health: '注意情绪调节，保持平和。', wealth: '财务不宜冒险，保守为宜。' }, lines: [{ position: 1, name: '初九', text: '归妹以娣，跛能履，征吉。', interpretation: '少女出嫁做妾，跛脚能走路，前往吉祥。', classicComment: '《象》曰：归妹以娣，跛能履，征吉。...，阳居初位，少女出嫁做妾，跛脚能走路，前往。', takashiCase: '某商人占贸易，得雷泽归妹之初九。高岛曰：「归妹以娣，跛能履，征吉。...」少女出嫁做妾，跛脚能走路，前往吉祥。。后果大获其利。' }, { position: 2, name: '九二', text: '眇能视，利幽人之贞。', interpretation: '眼盲能看，利于隐士守正。', classicComment: '《象》曰：眇能视，利幽人之贞。...，阳居初位，眼盲能看，利于隐士守正。。', takashiCase: '某商人占贸易，得雷泽归妹之九二。高岛曰：「眇能视，利幽人之贞。...」眼盲能看，利于隐士守正。。后事平平，无大得失。' }, { position: 3, name: '六三', text: '归妹以须，反归以娣。', interpretation: '少女出嫁等待，返回做妾。', classicComment: '《象》曰：归妹以须，反归以娣。...，阴居初位，少女出嫁等待，返回做妾。。', takashiCase: '某商人占贸易，得雷泽归妹之六三。高岛曰：「归妹以须，反归以娣。...」少女出嫁等待，返回做妾。。后事平平，无大得失。' }, { position: 4, name: '九四', text: '归妹愆期，迟归有时。', interpretation: '少女出嫁延期，晚嫁有时机。', classicComment: '《象》曰：归妹愆期，迟归有时。...，阳居初位，少女出嫁延期，晚嫁有时机。。', takashiCase: '某商人占贸易，得雷泽归妹之九四。高岛曰：「归妹愆期，迟归有时。...」少女出嫁延期，晚嫁有时机。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '帝乙归妹，其君之袂，不如其娣之袂良，月几望，吉。', interpretation: '帝乙嫁女，君夫人的衣袖不如妾的衣袖好，月亮接近满月，吉祥。', classicComment: '《象》曰：帝乙归妹，其君之袂，不如...，阴居初位，帝乙嫁女，君夫人的衣袖不如妾的。', takashiCase: '某商人占贸易，得雷泽归妹之六五。高岛曰：「帝乙归妹，其君之袂，不如...」帝乙嫁女，君夫人的衣袖不如妾的衣袖好，月。后果大获其利。' }, { position: 6, name: '上六', text: '女承筐无实，士刲羊无血，无攸利。', interpretation: '女子捧筐没有实物，男子杀羊没有血，无所利益。', classicComment: '《象》曰：女承筐无实，士刲羊无血，...，阴居初位，女子捧筐没有实物，男子杀羊没有。', takashiCase: '某商人占贸易，得雷泽归妹之上六。高岛曰：「女承筐无实，士刲羊无血，...」女子捧筐没有实物，男子杀羊没有血，无所利。后事平平，无大得失。' }] },
  { id: 55, name: '雷火丰', symbol: '䷶', upperTrigram: 'zhen', lowerTrigram: 'li', number: 55, judgment: '亨，王假之，勿忧，宜日中。', image: '丰，大也。明以动，故丰。', classicComment: '《彖》曰：雷火丰，亨，王假之，勿忧，宜日中。。《象》曰：君子以丰，大也。明以动，故丰。。', takashiCase: '某士人因事占问，得雷火丰。高岛嘉右卫门断曰：「亨，王假之，勿忧，宜日中。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征丰盛盛大之象。雷电皆至，光明盛大。宜把握时机，大展宏图。', career: '事业鼎盛，大有成就。', relationship: '感情热烈，丰盛美满。', health: '精力充沛，状态良好。', wealth: '财运亨通，收入丰厚。' }, lines: [{ position: 1, name: '初九', text: '遇其配主，虽旬无咎，往有尚。', interpretation: '遇到他的配偶主人，虽然十天无灾祸，前往有尊崇。', classicComment: '《象》曰：遇其配主，虽旬无咎，往有...，阳居初位，遇到他的配偶主人，虽然十天无灾。', takashiCase: '某商人占贸易，得雷火丰之初九。高岛曰：「遇其配主，虽旬无咎，往有...」遇到他的配偶主人，虽然十天无灾祸，前往有。后果大获其利。' }, { position: 2, name: '六二', text: '丰其蔀，日中见斗，往得疑疾，有孚发若，吉。', interpretation: '丰盛遮蔽，中午见到北斗星，前往得到疑病，有诚信启发，吉祥。', classicComment: '《象》曰：丰其蔀，日中见斗，往得疑...，阴居初位，丰盛遮蔽，中午见到北斗星，前往。', takashiCase: '某商人占贸易，得雷火丰之六二。高岛曰：「丰其蔀，日中见斗，往得疑...」丰盛遮蔽，中午见到北斗星，前往得到疑病，。后果大获其利。' }, { position: 3, name: '九三', text: '丰其沛，日中见沫，折其右肱，无咎。', interpretation: '丰盛遮蔽，中午见到小星，折断右臂，无灾祸。', classicComment: '《象》曰：丰其沛，日中见沫，折其右...，阳居初位，丰盛遮蔽，中午见到小星，折断右。', takashiCase: '某商人占贸易，得雷火丰之九三。高岛曰：「丰其沛，日中见沫，折其右...」丰盛遮蔽，中午见到小星，折断右臂，无灾祸。后果大获其利。' }, { position: 4, name: '九四', text: '丰其蔀，日中见斗，遇其夷主，吉。', interpretation: '丰盛遮蔽，中午见到北斗星，遇到他的平辈主人，吉祥。', classicComment: '《象》曰：丰其蔀，日中见斗，遇其夷...，阳居初位，丰盛遮蔽，中午见到北斗星，遇到。', takashiCase: '某商人占贸易，得雷火丰之九四。高岛曰：「丰其蔀，日中见斗，遇其夷...」丰盛遮蔽，中午见到北斗星，遇到他的平辈主。后果大获其利。' }, { position: 5, name: '六五', text: '来章，有庆誉，吉。', interpretation: '来有文采，有喜庆赞誉，吉祥。', classicComment: '《象》曰：来章，有庆誉，吉。...，阴居初位，来有文采，有喜庆赞誉，吉祥。。', takashiCase: '某商人占贸易，得雷火丰之六五。高岛曰：「来章，有庆誉，吉。...」来有文采，有喜庆赞誉，吉祥。。后果大获其利。' }, { position: 6, name: '上六', text: '丰其屋，蔀其家，窥其户，阒其无人，三岁不觌，凶。', interpretation: '丰盛房屋，遮蔽家庭，从门缝看，寂静无人，三年不见人，凶险。', classicComment: '《象》曰：丰其屋，蔀其家，窥其户，...，阴居初位，丰盛房屋，遮蔽家庭，从门缝看，。', takashiCase: '某商人占贸易，得雷火丰之上六。高岛曰：「丰其屋，蔀其家，窥其户，...」丰盛房屋，遮蔽家庭，从门缝看，寂静无人，。后事败，悔之晚矣。' }] },
  { id: 56, name: '火山旅', symbol: '䷷', upperTrigram: 'li', lowerTrigram: 'gen', number: 56, judgment: '小亨，旅贞吉。', image: '旅，小亨，柔得中乎外，而顺乎刚，止而丽乎明。', classicComment: '《彖》曰：火山旅，小亨，旅贞吉。。《象》曰：君子以旅，小亨，柔得中乎外，而顺乎刚。', takashiCase: '某士人因事占问，得火山旅。高岛嘉右卫门断曰：「小亨，旅贞吉。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征旅行羁旅之象。山上有火，行旅不止。宜谨慎出行，随遇而安。', career: '事业可能有变动，需灵活应对。', relationship: '感情不稳定，需多沟通。', health: '注意出行安全，避免劳累。', wealth: '财务不稳定，需谨慎理财。' }, lines: [{ position: 1, name: '初六', text: '旅琐琐，斯其所取灾。', interpretation: '旅行琐碎，这是他自取灾祸。', classicComment: '《象》曰：旅琐琐，斯其所取灾。...，阴居初位，旅行琐碎，这是他自取灾祸。。', takashiCase: '某商人占贸易，得火山旅之初六。高岛曰：「旅琐琐，斯其所取灾。...」旅行琐碎，这是他自取灾祸。。后事平平，无大得失。' }, { position: 2, name: '六二', text: '旅即次，怀其资，得童仆贞。', interpretation: '旅行到客舍，怀藏资财，得到童仆守正。', classicComment: '《象》曰：旅即次，怀其资，得童仆贞...，阴居初位，旅行到客舍，怀藏资财，得到童仆。', takashiCase: '某商人占贸易，得火山旅之六二。高岛曰：「旅即次，怀其资，得童仆贞...」旅行到客舍，怀藏资财，得到童仆守正。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '旅焚其次，丧其童仆，贞厉。', interpretation: '旅行烧掉客舍，丧失童仆，守正危险。', classicComment: '《象》曰：旅焚其次，丧其童仆，贞厉...，阳居初位，旅行烧掉客舍，丧失童仆，守正危。', takashiCase: '某商人占贸易，得火山旅之九三。高岛曰：「旅焚其次，丧其童仆，贞厉...」旅行烧掉客舍，丧失童仆，守正危险。。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '旅于处，得其资斧，我心不快。', interpretation: '旅行停留，得到资财斧头，我心不快乐。', classicComment: '《象》曰：旅于处，得其资斧，我心不...，阳居初位，旅行停留，得到资财斧头，我心不。', takashiCase: '某商人占贸易，得火山旅之九四。高岛曰：「旅于处，得其资斧，我心不...」旅行停留，得到资财斧头，我心不快乐。。后事平平，无大得失。' }, { position: 5, name: '六五', text: '射雉一矢亡，终以誉命。', interpretation: '射野鸡丢失一支箭，最终得到赞誉命令。', classicComment: '《象》曰：射雉一矢亡，终以誉命。...，阴居初位，射野鸡丢失一支箭，最终得到赞誉。', takashiCase: '某商人占贸易，得火山旅之六五。高岛曰：「射雉一矢亡，终以誉命。...」射野鸡丢失一支箭，最终得到赞誉命令。。后事平平，无大得失。' }, { position: 6, name: '上九', text: '鸟焚其巢，旅人先笑后号咷，丧牛于易，凶。', interpretation: '鸟烧掉巢穴，旅人先笑后哭，在田畔丢失牛，凶险。', classicComment: '《象》曰：鸟焚其巢，旅人先笑后号咷...，阳居初位，鸟烧掉巢穴，旅人先笑后哭，在田。', takashiCase: '某商人占贸易，得火山旅之上九。高岛曰：「鸟焚其巢，旅人先笑后号咷...」鸟烧掉巢穴，旅人先笑后哭，在田畔丢失牛，。后事败，悔之晚矣。' }] },
  { id: 57, name: '巽为风', symbol: '䷸', upperTrigram: 'xun', lowerTrigram: 'xun', number: 57, judgment: '小亨，利有攸往，利见大人。', image: '巽，入也。刚巽乎中正而志行，柔皆顺乎刚。', classicComment: '《彖》曰：巽为风，小亨，利有攸往，利见大人。。《象》曰：君子以巽，入也。刚巽乎中正而志行，柔。', takashiCase: '某士人因事占问，得巽为风。高岛嘉右卫门断曰：「小亨，利有攸往，利见大人。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征顺从渗透之象。两风相重，无孔不入。宜顺势而为，谦逊行事。', career: '事业宜顺应形势，灵活变通。', relationship: '感情需互相包容，谦逊相处。', health: '注意呼吸系统，保持通风。', wealth: '财运平稳，需耐心经营。' }, lines: [{ position: 1, name: '初六', text: '进退，利武人之贞。', interpretation: '进退不定，利于武人守正。', classicComment: '《象》曰：进退，利武人之贞。...，阴居初位，进退不定，利于武人守正。。', takashiCase: '某商人占贸易，得巽为风之初六。高岛曰：「进退，利武人之贞。...」进退不定，利于武人守正。。后事平平，无大得失。' }, { position: 2, name: '九二', text: '巽在床下，用史巫纷若，吉无咎。', interpretation: '顺从在床下，用史官巫师纷纷，吉祥无灾祸。', classicComment: '《象》曰：巽在床下，用史巫纷若，吉...，阳居初位，顺从在床下，用史官巫师纷纷，吉。', takashiCase: '某商人占贸易，得巽为风之九二。高岛曰：「巽在床下，用史巫纷若，吉...」顺从在床下，用史官巫师纷纷，吉祥无灾祸。。后果大获其利。' }, { position: 3, name: '九三', text: '频巽，吝。', interpretation: '频繁顺从，有憾惜。', classicComment: '《象》曰：频巽，吝。...，阳居初位，频繁顺从，有憾惜。。', takashiCase: '某商人占贸易，得巽为风之九三。高岛曰：「频巽，吝。...」频繁顺从，有憾惜。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '悔亡，田获三品。', interpretation: '悔恨消失，田猎获得三种物品。', classicComment: '《象》曰：悔亡，田获三品。...，阴居初位，悔恨消失，田猎获得三种物品。。', takashiCase: '某商人占贸易，得巽为风之六四。高岛曰：「悔亡，田获三品。...」悔恨消失，田猎获得三种物品。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '贞吉悔亡，无不利。无初有终，先庚三日，后庚三日，吉。', interpretation: '守正吉祥悔恨消失，无所不利。没有开始有结果，庚前三日，庚后三日，吉祥。', classicComment: '《象》曰：贞吉悔亡，无不利。无初有...，阳居初位，守正吉祥悔恨消失，无所不利。没。', takashiCase: '某商人占贸易，得巽为风之九五。高岛曰：「贞吉悔亡，无不利。无初有...」守正吉祥悔恨消失，无所不利。没有开始有结。后果大获其利。' }, { position: 6, name: '上九', text: '巽在床下，丧其资斧，贞凶。', interpretation: '顺从在床下，丧失资财斧头，守正凶险。', classicComment: '《象》曰：巽在床下，丧其资斧，贞凶...，阳居初位，顺从在床下，丧失资财斧头，守正。', takashiCase: '某商人占贸易，得巽为风之上九。高岛曰：「巽在床下，丧其资斧，贞凶...」顺从在床下，丧失资财斧头，守正凶险。。后事败，悔之晚矣。' }] },
  { id: 58, name: '兑为泽', symbol: '䷹', upperTrigram: 'dui', lowerTrigram: 'dui', number: 58, judgment: '亨，利贞。', image: '兑，说也。刚中而柔外，说以利贞。', classicComment: '《彖》曰：兑为泽，亨，利贞。。《象》曰：君子以兑，说也。刚中而柔外，说以利贞。', takashiCase: '某士人因事占问，得兑为泽。高岛嘉右卫门断曰：「亨，利贞。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征喜悦和乐之象。两泽相连，喜悦相通。宜和悦相处，广结善缘。', career: '事业顺利，人际关系和谐。', relationship: '感情和谐美满，喜悦甜蜜。', health: '心情愉悦，身心健康。', wealth: '财运顺畅，收入稳定。' }, lines: [{ position: 1, name: '初九', text: '和兑，吉。', interpretation: '和悦，吉祥。', classicComment: '《象》曰：和兑，吉。...，阳居初位，和悦，吉祥。。', takashiCase: '某商人占贸易，得兑为泽之初九。高岛曰：「和兑，吉。...」和悦，吉祥。。后果大获其利。' }, { position: 2, name: '九二', text: '孚兑，吉，悔亡。', interpretation: '诚信喜悦，吉祥，悔恨消失。', classicComment: '《象》曰：孚兑，吉，悔亡。...，阳居初位，诚信喜悦，吉祥，悔恨消失。。', takashiCase: '某商人占贸易，得兑为泽之九二。高岛曰：「孚兑，吉，悔亡。...」诚信喜悦，吉祥，悔恨消失。。后果大获其利。' }, { position: 3, name: '六三', text: '来兑，凶。', interpretation: '来求喜悦，凶险。', classicComment: '《象》曰：来兑，凶。...，阴居初位，来求喜悦，凶险。。', takashiCase: '某商人占贸易，得兑为泽之六三。高岛曰：「来兑，凶。...」来求喜悦，凶险。。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '商兑，未宁，介疾有喜。', interpretation: '商议喜悦，未安宁，有疾病有喜事。', classicComment: '《象》曰：商兑，未宁，介疾有喜。...，阳居初位，商议喜悦，未安宁，有疾病有喜事。', takashiCase: '某商人占贸易，得兑为泽之九四。高岛曰：「商兑，未宁，介疾有喜。...」商议喜悦，未安宁，有疾病有喜事。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '孚于剥，有厉。', interpretation: '诚信于剥蚀，有危险。', classicComment: '《象》曰：孚于剥，有厉。...，阳居初位，诚信于剥蚀，有危险。。', takashiCase: '某商人占贸易，得兑为泽之九五。高岛曰：「孚于剥，有厉。...」诚信于剥蚀，有危险。。后事败，悔之晚矣。' }, { position: 6, name: '上六', text: '引兑。', interpretation: '引导喜悦。', classicComment: '《象》曰：引兑。...，阴居初位，引导喜悦。。', takashiCase: '某商人占贸易，得兑为泽之上六。高岛曰：「引兑。...」引导喜悦。。后事平平，无大得失。' }] },
  { id: 59, name: '风水涣', symbol: '䷺', upperTrigram: 'xun', lowerTrigram: 'kan', number: 59, judgment: '亨。王假有庙，利涉大川，利贞。', image: '涣，亨。刚来而不穷，柔得位乎外而上同。', classicComment: '《彖》曰：风水涣，亨。王假有庙，利涉大川，利贞。。《象》曰：君子以涣，亨。刚来而不穷，柔得位乎外。', takashiCase: '某士人因事占问，得风水涣。高岛嘉右卫门断曰：「亨。王假有庙，利涉大川，利贞。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征涣散离散之象。风行水上，涣散四方。宜化解矛盾，重新凝聚。', career: '事业可能有变动，需灵活应对。', relationship: '感情可能有疏离，需加强沟通。', health: '注意情绪调节，避免涣散。', wealth: '财务需重新规划，避免散乱。' }, lines: [{ position: 1, name: '初六', text: '用拯马壮，吉。', interpretation: '用强壮的马拯救，吉祥。', classicComment: '《象》曰：用拯马壮，吉。...，阴居初位，用强壮的马拯救，吉祥。。', takashiCase: '某商人占贸易，得风水涣之初六。高岛曰：「用拯马壮，吉。...」用强壮的马拯救，吉祥。。后果大获其利。' }, { position: 2, name: '九二', text: '涣奔其机，悔亡。', interpretation: '涣散奔向他的几案，悔恨消失。', classicComment: '《象》曰：涣奔其机，悔亡。...，阳居初位，涣散奔向他的几案，悔恨消失。。', takashiCase: '某商人占贸易，得风水涣之九二。高岛曰：「涣奔其机，悔亡。...」涣散奔向他的几案，悔恨消失。。后事平平，无大得失。' }, { position: 3, name: '六三', text: '涣其躬，无悔。', interpretation: '涣散他的身体，没有悔恨。', classicComment: '《象》曰：涣其躬，无悔。...，阴居初位，涣散他的身体，没有悔恨。。', takashiCase: '某商人占贸易，得风水涣之六三。高岛曰：「涣其躬，无悔。...」涣散他的身体，没有悔恨。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '涣其群，元吉。涣有丘，匪夷所思。', interpretation: '涣散他的群体，大吉。涣散有丘陵，不是平常所能想。', classicComment: '《象》曰：涣其群，元吉。涣有丘，匪...，阴居初位，涣散他的群体，大吉。涣散有丘陵。', takashiCase: '某商人占贸易，得风水涣之六四。高岛曰：「涣其群，元吉。涣有丘，匪...」涣散他的群体，大吉。涣散有丘陵，不是平常。后果大获其利。' }, { position: 5, name: '九五', text: '涣汗其大号，涣王居，无咎。', interpretation: '涣散如汗他的大号令，涣散君王的居所，无灾祸。', classicComment: '《象》曰：涣汗其大号，涣王居，无咎...，阳居初位，涣散如汗他的大号令，涣散君王的。', takashiCase: '某商人占贸易，得风水涣之九五。高岛曰：「涣汗其大号，涣王居，无咎...」涣散如汗他的大号令，涣散君王的居所，无灾。后果大获其利。' }, { position: 6, name: '上九', text: '涣其血，去逖出，无咎。', interpretation: '涣散他的血，远离出去，无灾祸。', classicComment: '《象》曰：涣其血，去逖出，无咎。...，阳居初位，涣散他的血，远离出去，无灾祸。。', takashiCase: '某商人占贸易，得风水涣之上九。高岛曰：「涣其血，去逖出，无咎。...」涣散他的血，远离出去，无灾祸。。后果大获其利。' }] },
  { id: 60, name: '水泽节', symbol: '䷻', upperTrigram: 'kan', lowerTrigram: 'dui', number: 60, judgment: '亨。苦节不可贞。', image: '节，止也。刚柔分，而刚得中。', classicComment: '《彖》曰：水泽节，亨。苦节不可贞。。《象》曰：君子以节，止也。刚柔分，而刚得中。。', takashiCase: '某士人因事占问，得水泽节。高岛嘉右卫门断曰：「亨。苦节不可贞。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征节制适度之象。泽上有水，适度调节。宜有所节制，不可过度。', career: '事业需适度发展，不可冒进。', relationship: '感情需适度付出，不可过度。', health: '注意饮食起居有节，适度运动。', wealth: '财务需有计划，量入为出。' }, lines: [{ position: 1, name: '初九', text: '不出户庭，无咎。', interpretation: '不出家门，无灾祸。', classicComment: '《象》曰：不出户庭，无咎。...，阳居初位，不出家门，无灾祸。。', takashiCase: '某商人占贸易，得水泽节之初九。高岛曰：「不出户庭，无咎。...」不出家门，无灾祸。。后果大获其利。' }, { position: 2, name: '九二', text: '不出门庭，凶。', interpretation: '不出庭院门，凶险。', classicComment: '《象》曰：不出门庭，凶。...，阳居初位，不出庭院门，凶险。。', takashiCase: '某商人占贸易，得水泽节之九二。高岛曰：「不出门庭，凶。...」不出庭院门，凶险。。后事败，悔之晚矣。' }, { position: 3, name: '六三', text: '不节若，则嗟若，无咎。', interpretation: '不节制，则叹息，无灾祸。', classicComment: '《象》曰：不节若，则嗟若，无咎。...，阴居初位，不节制，则叹息，无灾祸。。', takashiCase: '某商人占贸易，得水泽节之六三。高岛曰：「不节若，则嗟若，无咎。...」不节制，则叹息，无灾祸。。后果大获其利。' }, { position: 4, name: '六四', text: '安节，亨。', interpretation: '安于节制，亨通。', classicComment: '《象》曰：安节，亨。...，阴居初位，安于节制，亨通。。', takashiCase: '某商人占贸易，得水泽节之六四。高岛曰：「安节，亨。...」安于节制，亨通。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '甘节，吉；往有尚。', interpretation: '甘美节制，吉祥；前往有尊崇。', classicComment: '《象》曰：甘节，吉；往有尚。...，阳居初位，甘美节制，吉祥；前往有尊崇。。', takashiCase: '某商人占贸易，得水泽节之九五。高岛曰：「甘节，吉；往有尚。...」甘美节制，吉祥；前往有尊崇。。后果大获其利。' }, { position: 6, name: '上六', text: '苦节，贞凶，悔亡。', interpretation: '苦苦节制，守正凶险，悔恨消失。', classicComment: '《象》曰：苦节，贞凶，悔亡。...，阴居初位，苦苦节制，守正凶险，悔恨消失。。', takashiCase: '某商人占贸易，得水泽节之上六。高岛曰：「苦节，贞凶，悔亡。...」苦苦节制，守正凶险，悔恨消失。。后事败，悔之晚矣。' }] },
  { id: 61, name: '风泽中孚', symbol: '䷼', upperTrigram: 'xun', lowerTrigram: 'dui', number: 61, judgment: '豚鱼吉，利涉大川，利贞。', image: '中孚，柔在内而刚得中。说而巽，孚，乃化邦也。', classicComment: '《彖》曰：风泽中孚，豚鱼吉，利涉大川，利贞。。《象》曰：君子以中孚，柔在内而刚得中。说而巽，。', takashiCase: '某士人因事占问，得风泽中孚。高岛嘉右卫门断曰：「豚鱼吉，利涉大川，利贞。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征诚信感化之象。泽上有风，诚信感通。宜以诚待人，建立信任。', career: '事业需以诚信为本，建立良好信誉。', relationship: '感情需真诚相待，互相信任。', health: '身心需要诚信面对，积极调养。', wealth: '财务需诚信经营，稳步发展。' }, lines: [{ position: 1, name: '初九', text: '虞吉，有它不燕。', interpretation: '安虞吉祥，有其他不安宁。', classicComment: '《象》曰：虞吉，有它不燕。...，阳居初位，安虞吉祥，有其他不安宁。。', takashiCase: '某商人占贸易，得风泽中孚之初九。高岛曰：「虞吉，有它不燕。...」安虞吉祥，有其他不安宁。。后果大获其利。' }, { position: 2, name: '九二', text: '鸣鹤在阴，其子和之，我有好爵，吾与尔靡之。', interpretation: '鹤在阴处鸣叫，它的儿子应和，我有好酒，我与你共享。', classicComment: '《象》曰：鸣鹤在阴，其子和之，我有...，阳居初位，鹤在阴处鸣叫，它的儿子应和，我。', takashiCase: '某商人占贸易，得风泽中孚之九二。高岛曰：「鸣鹤在阴，其子和之，我有...」鹤在阴处鸣叫，它的儿子应和，我有好酒，我。后事平平，无大得失。' }, { position: 3, name: '六三', text: '得敌，或鼓或罢，或泣或歌。', interpretation: '得到敌人，或击鼓或停止，或哭泣或歌唱。', classicComment: '《象》曰：得敌，或鼓或罢，或泣或歌...，阴居初位，得到敌人，或击鼓或停止，或哭泣。', takashiCase: '某商人占贸易，得风泽中孚之六三。高岛曰：「得敌，或鼓或罢，或泣或歌...」得到敌人，或击鼓或停止，或哭泣或歌唱。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '月几望，马匹亡，无咎。', interpretation: '月亮接近满月，马匹丢失，无灾祸。', classicComment: '《象》曰：月几望，马匹亡，无咎。...，阴居初位，月亮接近满月，马匹丢失，无灾祸。', takashiCase: '某商人占贸易，得风泽中孚之六四。高岛曰：「月几望，马匹亡，无咎。...」月亮接近满月，马匹丢失，无灾祸。。后果大获其利。' }, { position: 5, name: '九五', text: '有孚挛如，无咎。', interpretation: '有诚信紧密相连，无灾祸。', classicComment: '《象》曰：有孚挛如，无咎。...，阳居初位，有诚信紧密相连，无灾祸。。', takashiCase: '某商人占贸易，得风泽中孚之九五。高岛曰：「有孚挛如，无咎。...」有诚信紧密相连，无灾祸。。后果大获其利。' }, { position: 6, name: '上九', text: '翰音登于天，贞凶。', interpretation: '鸡鸣声登于天，守正凶险。', classicComment: '《象》曰：翰音登于天，贞凶。...，阳居初位，鸡鸣声登于天，守正凶险。。', takashiCase: '某商人占贸易，得风泽中孚之上九。高岛曰：「翰音登于天，贞凶。...」鸡鸣声登于天，守正凶险。。后事败，悔之晚矣。' }] },
  { id: 62, name: '雷山小过', symbol: '䷽', upperTrigram: 'zhen', lowerTrigram: 'gen', number: 62, judgment: '亨，利贞，可小事，不可大事。飞鸟遗之音，不宜上宜下，大吉。', image: '小过，小者过也。过以利贞，与时行也。', classicComment: '《彖》曰：雷山小过，亨，利贞，可小事，不可大事。飞鸟遗之音，。《象》曰：君子以小过，小者过也。过以利贞，与时。', takashiCase: '某士人因事占问，得雷山小过。高岛嘉右卫门断曰：「亨，利贞，可小事，不可大事。飞鸟遗之音，」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征小有过越之象。山上有雷，小有过失。宜谨慎小事，不可大意。', career: '事业宜谨慎行事，不可冒进。', relationship: '感情需注意细节，避免小过失。', health: '注意小病小恙，及时调理。', wealth: '财务需注意小开支，积少成多。' }, lines: [{ position: 1, name: '初六', text: '飞鸟以凶。', interpretation: '飞鸟因此凶险。', classicComment: '《象》曰：飞鸟以凶。...，阴居初位，飞鸟因此凶险。。', takashiCase: '某商人占贸易，得雷山小过之初六。高岛曰：「飞鸟以凶。...」飞鸟因此凶险。。后事败，悔之晚矣。' }, { position: 2, name: '六二', text: '过其祖，遇其妣；不及其君，遇其臣；无咎。', interpretation: '越过他的祖父，遇到他的祖母；不及他的君王，遇到他的臣子；无灾祸。', classicComment: '《象》曰：过其祖，遇其妣；不及其君...，阴居初位，越过他的祖父，遇到他的祖母；不。', takashiCase: '某商人占贸易，得雷山小过之六二。高岛曰：「过其祖，遇其妣；不及其君...」越过他的祖父，遇到他的祖母；不及他的君王。后果大获其利。' }, { position: 3, name: '九三', text: '弗过防之，从或戕之，凶。', interpretation: '不过分防备它，跟随或许杀害它，凶险。', classicComment: '《象》曰：弗过防之，从或戕之，凶。...，阳居初位，不过分防备它，跟随或许杀害它，。', takashiCase: '某商人占贸易，得雷山小过之九三。高岛曰：「弗过防之，从或戕之，凶。...」不过分防备它，跟随或许杀害它，凶险。。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '无咎，弗过遇之。往厉必戒，勿用永贞。', interpretation: '无灾祸，不过分遇到它。前往危险必须戒备，不要永远守正。', classicComment: '《象》曰：无咎，弗过遇之。往厉必戒...，阳居初位，无灾祸，不过分遇到它。前往危险。', takashiCase: '某商人占贸易，得雷山小过之九四。高岛曰：「无咎，弗过遇之。往厉必戒...」无灾祸，不过分遇到它。前往危险必须戒备，。后果大获其利。' }, { position: 5, name: '六五', text: '密云不雨，自我西郊，公弋取彼在穴。', interpretation: '密云不下雨，来自我西郊，公侯射取它在洞穴中。', classicComment: '《象》曰：密云不雨，自我西郊，公弋...，阴居初位，密云不下雨，来自我西郊，公侯射。', takashiCase: '某商人占贸易，得雷山小过之六五。高岛曰：「密云不雨，自我西郊，公弋...」密云不下雨，来自我西郊，公侯射取它在洞穴。后事平平，无大得失。' }, { position: 6, name: '上六', text: '弗遇过之，飞鸟离之，凶，是谓灾眚。', interpretation: '不遇到而越过它，飞鸟离开它，凶险，这叫做灾祸。', classicComment: '《象》曰：弗遇过之，飞鸟离之，凶，...，阴居初位，不遇到而越过它，飞鸟离开它，凶。', takashiCase: '某商人占贸易，得雷山小过之上六。高岛曰：「弗遇过之，飞鸟离之，凶，...」不遇到而越过它，飞鸟离开它，凶险，这叫做。后事败，悔之晚矣。' }] },
  { id: 63, name: '水火既济', symbol: '䷾', upperTrigram: 'kan', lowerTrigram: 'li', number: 63, judgment: '亨，小利贞，初吉终乱。', image: '既济，亨，小者亨也。利贞，刚柔正而位当也。', classicComment: '《彖》曰：水火既济，亨，小利贞，初吉终乱。。《象》曰：君子以既济，亨，小者亨也。利贞，刚柔。', takashiCase: '某士人因事占问，得水火既济。高岛嘉右卫门断曰：「亨，小利贞，初吉终乱。」此卦大吉，凡事亨通，宜乘时进取。后果验。', interpretation: { summary: '此卦象征事已成之象。水在火上，烹饪成功。宜居安思危，防微杜渐。', career: '事业已成功，需保持谨慎。', relationship: '感情圆满，需珍惜维护。', health: '身体状态良好，需保持。', wealth: '财运亨通，需稳健理财。' }, lines: [{ position: 1, name: '初九', text: '曳其轮，濡其尾，无咎。', interpretation: '拖曳车轮，沾湿尾巴，无灾祸。', classicComment: '《象》曰：曳其轮，濡其尾，无咎。...，阳居初位，拖曳车轮，沾湿尾巴，无灾祸。。', takashiCase: '某商人占贸易，得水火既济之初九。高岛曰：「曳其轮，濡其尾，无咎。...」拖曳车轮，沾湿尾巴，无灾祸。。后果大获其利。' }, { position: 2, name: '六二', text: '妇丧其茀，勿逐，七日得。', interpretation: '妇人丢失她的车帘，不要追逐，七天后得到。', classicComment: '《象》曰：妇丧其茀，勿逐，七日得。...，阴居初位，妇人丢失她的车帘，不要追逐，七。', takashiCase: '某商人占贸易，得水火既济之六二。高岛曰：「妇丧其茀，勿逐，七日得。...」妇人丢失她的车帘，不要追逐，七天后得到。。后事平平，无大得失。' }, { position: 3, name: '九三', text: '高宗伐鬼方，三年克之，小人勿用。', interpretation: '高宗征伐鬼方，三年攻克它，小人不可用。', classicComment: '《象》曰：高宗伐鬼方，三年克之，小...，阳居初位，高宗征伐鬼方，三年攻克它，小人。', takashiCase: '某商人占贸易，得水火既济之九三。高岛曰：「高宗伐鬼方，三年克之，小...」高宗征伐鬼方，三年攻克它，小人不可用。。后事平平，无大得失。' }, { position: 4, name: '六四', text: '繻有衣袽，终日戒。', interpretation: '彩绸有破衣，整天戒备。', classicComment: '《象》曰：繻有衣袽，终日戒。...，阴居初位，彩绸有破衣，整天戒备。。', takashiCase: '某商人占贸易，得水火既济之六四。高岛曰：「繻有衣袽，终日戒。...」彩绸有破衣，整天戒备。。后事平平，无大得失。' }, { position: 5, name: '九五', text: '东邻杀牛，不如西邻之禴祭，实受其福。', interpretation: '东邻杀牛祭祀，不如西邻的薄祭，实在受到它的福气。', classicComment: '《象》曰：东邻杀牛，不如西邻之禴祭...，阳居初位，东邻杀牛祭祀，不如西邻的薄祭，。', takashiCase: '某商人占贸易，得水火既济之九五。高岛曰：「东邻杀牛，不如西邻之禴祭...」东邻杀牛祭祀，不如西邻的薄祭，实在受到它。后事平平，无大得失。' }, { position: 6, name: '上六', text: '濡其首，厉。', interpretation: '沾湿头部，危险。', classicComment: '《象》曰：濡其首，厉。...，阴居初位，沾湿头部，危险。。', takashiCase: '某商人占贸易，得水火既济之上六。高岛曰：「濡其首，厉。...」沾湿头部，危险。。后事败，悔之晚矣。' }] },
  { id: 64, name: '火水未济', symbol: '䷿', upperTrigram: 'li', lowerTrigram: 'kan', number: 64, judgment: '亨，小狐汔济，濡其尾，无攸利。', image: '未济，亨，柔得中也。小狐汔济，未出中也。', classicComment: '《彖》曰：火水未济，亨，小狐汔济，濡其尾，无攸利。。《象》曰：君子以未济，亨，柔得中也。小狐汔济，。', takashiCase: '某士人因事占问，得火水未济。高岛嘉右卫门断曰：「亨，小狐汔济，濡其尾，无攸利。」此卦宜守正待时，不可妄动。后果验。', interpretation: { summary: '此卦象征事未成之象。火在水上，未能烹饪。宜坚持努力，终将成功。', career: '事业尚未成功，需继续努力。', relationship: '感情尚未成熟，需耐心培养。', health: '身体尚未康复，需继续调养。', wealth: '财运尚未到来，需坚持等待。' }, lines: [{ position: 1, name: '初六', text: '濡其尾，吝。', interpretation: '沾湿尾巴，有憾惜。', classicComment: '《象》曰：濡其尾，吝。...，阴居初位，沾湿尾巴，有憾惜。。', takashiCase: '某商人占贸易，得火水未济之初六。高岛曰：「濡其尾，吝。...」沾湿尾巴，有憾惜。。后事平平，无大得失。' }, { position: 2, name: '九二', text: '曳其轮，贞吉。', interpretation: '拖曳车轮，守正吉祥。', classicComment: '《象》曰：曳其轮，贞吉。...，阳居初位，拖曳车轮，守正吉祥。。', takashiCase: '某商人占贸易，得火水未济之九二。高岛曰：「曳其轮，贞吉。...」拖曳车轮，守正吉祥。。后果大获其利。' }, { position: 3, name: '六三', text: '未济，征凶，利涉大川。', interpretation: '未能渡过，前往凶险，利于渡越大河。', classicComment: '《象》曰：未济，征凶，利涉大川。...，阴居初位，未能渡过，前往凶险，利于渡越大。', takashiCase: '某商人占贸易，得火水未济之六三。高岛曰：「未济，征凶，利涉大川。...」未能渡过，前往凶险，利于渡越大河。。后事败，悔之晚矣。' }, { position: 4, name: '九四', text: '贞吉，悔亡，震用伐鬼方，三年有赏于大国。', interpretation: '守正吉祥悔恨消失，震动用于征伐鬼方，三年有赏于大国。', classicComment: '《象》曰：贞吉，悔亡，震用伐鬼方，...，阳居初位，守正吉祥悔恨消失，震动用于征伐。', takashiCase: '某商人占贸易，得火水未济之九四。高岛曰：「贞吉，悔亡，震用伐鬼方，...」守正吉祥悔恨消失，震动用于征伐鬼方，三年。后果大获其利。' }, { position: 5, name: '六五', text: '贞吉，无悔，君子之光，有孚，吉。', interpretation: '守正吉祥，没有悔恨，君子的光辉，有诚信，吉祥。', classicComment: '《象》曰：贞吉，无悔，君子之光，有...，阴居初位，守正吉祥，没有悔恨，君子的光辉。', takashiCase: '某商人占贸易，得火水未济之六五。高岛曰：「贞吉，无悔，君子之光，有...」守正吉祥，没有悔恨，君子的光辉，有诚信，。后果大获其利。' }, { position: 6, name: '上九', text: '有孚于饮酒，无咎，濡其首，有孚失是。', interpretation: '有诚信于饮酒，无灾祸，沾湿头部，有诚信失去正道。', classicComment: '《象》曰：有孚于饮酒，无咎，濡其首...，阳居初位，有诚信于饮酒，无灾祸，沾湿头部。', takashiCase: '某商人占贸易，得火水未济之上九。高岛曰：「有孚于饮酒，无咎，濡其首...」有诚信于饮酒，无灾祸，沾湿头部，有诚信失。后果大获其利。' }] },
];

export function getHexagramById(id: number): Hexagram | null {
  return HEXAGRAMS.find(h => h.id === id) || null;
}

export function getHexagramByTrigrams(upperId: string, lowerId: string): Hexagram | null {
  return HEXAGRAMS.find(h => h.upperTrigram === upperId && h.lowerTrigram === lowerId) || null;
}

export function searchHexagrams(keyword: string): Hexagram[] {
  return HEXAGRAMS.filter(h =>
    h.name.includes(keyword) ||
    h.number === parseInt(keyword)
  );
}

